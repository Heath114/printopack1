---
// Global footer: newsletter band + deep navy footer with columns, QR, offices, legal.
const year = new Date().getFullYear();
const offices = ["Kuwait", "Jordan", "Egypt", "Sudan", "Tunisia", "Algeria"];
---
<!-- newsletter band -->
<section class="news-band">
  <div class="wrap" style="text-align:center">
    <span class="eyebrow plain" data-reveal style="color:var(--gold)">Stay ahead</span>
    <h2 data-reveal style="margin:14px 0 8px">News from Printopack</h2>
    <p class="lede" data-reveal style="margin:0 auto 28px">Be the first to hear about new capabilities, certifications and exhibitions.</p>
    <form class="news-form" data-reveal onsubmit="return false">
      <input type="email" placeholder="Your email address" required />
      <button class="btn btn-solid" type="submit">Subscribe</button>
    </form>
  </div>
</section>

<footer class="site-footer on-deep">
  <div class="wrap-wide">
    <div class="foot-grid">
      <div class="foot-brand">
        <a href="/" class="wordmark">PRINTO<span>·</span>PACK</a>
        <p>Flexible packaging, printed and finished in Jeddah for brands across 26+ countries since 1997.</p>
        <div class="qr">
          <div class="qr-box" aria-hidden="true">
            <svg viewBox="0 0 100 100"><rect width="100" height="100" fill="none"/><g fill="currentColor"><rect x="6" y="6" width="26" height="26"/><rect x="12" y="12" width="14" height="14" fill="var(--navy-deep)"/><rect x="68" y="6" width="26" height="26"/><rect x="74" y="12" width="14" height="14" fill="var(--navy-deep)"/><rect x="6" y="68" width="26" height="26"/><rect x="12" y="74" width="14" height="14" fill="var(--navy-deep)"/><rect x="42" y="6" width="8" height="8"/><rect x="54" y="14" width="8" height="8"/><rect x="42" y="26" width="8" height="8"/><rect x="60" y="42" width="8" height="8"/><rect x="42" y="42" width="8" height="8"/><rect x="74" y="42" width="8" height="8"/><rect x="86" y="42" width="8" height="8"/><rect x="42" y="54" width="8" height="8"/><rect x="42" y="68" width="8" height="8"/><rect x="54" y="60" width="8" height="8"/><rect x="66" y="66" width="8" height="8"/><rect x="78" y="60" width="8" height="8"/><rect x="86" y="72" width="8" height="8"/><rect x="66" y="84" width="8" height="8"/><rect x="54" y="84" width="8" height="8"/><rect x="42" y="84" width="8" height="8"/></g></svg>
          </div>
          <span>Scan for our<br>digital profile</span>
        </div>
      </div>

      <div class="foot-col">
        <h4>Company</h4>
        <a href="/about">About Us</a>
        <a href="/team">Our Team</a>
        <a href="/careers">Careers</a>
        <a href="/quality">Social Responsibility</a>
      </div>
      <div class="foot-col">
        <h4>Explore</h4>
        <a href="/products">Products</a>
        <a href="/quality">Quality System</a>
        <a href="/factory">Factory</a>
        <a href="/gallery">Gallery</a>
        <a href="/news">News &amp; Events</a>
      </div>
      <div class="foot-col foot-visit">
        <h4>Visit Us</h4>
        <p>Industrial Area 5, Unit 10, 8508<br>Jeddah 22428, Saudi Arabia</p>
        <a href="mailto:info@printopack.com.sa">info@printopack.com.sa</a>
        <a href="tel:+966126081074">+966 12 608 1074</a>
        <div class="offices">
          <span class="offices-label">Regional offices</span>
          <div class="offices-list">{offices.map((o) => <span>{o}</span>)}</div>
        </div>
      </div>
    </div>

    <div class="foot-bottom">
      <span>© {year} Printopack, Saudi Modern Packaging Factory Co. Ltd. All rights reserved.</span>
      <div class="foot-legal">
        <a href="/privacy">Privacy</a>
        <a href="/conditions">Conditions</a>
        <a href="https://www.linkedin.com/company/80331793/" target="_blank" rel="noopener">LinkedIn</a>
        <a href="#" target="_blank" rel="noopener">Facebook</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .news-band{background:var(--cream);border-top:1px solid var(--line)}
  .news-form{display:flex;gap:10px;max-width:480px;margin-inline:auto}
  .news-form input{flex:1;padding:16px 18px;border:1px solid var(--line);background:var(--paper);font:inherit;font-size:15px;border-radius:var(--radius)}
  .news-form input:focus{outline:none;border-color:var(--navy)}

  .site-footer{padding-block:clamp(56px,7vw,84px) 32px}
  .foot-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1.4fr;gap:48px;padding-bottom:52px;border-bottom:1px solid var(--line-dark)}
  .foot-brand .wordmark{color:var(--paper);font-size:24px;display:inline-block;margin-bottom:18px}
  .foot-brand .wordmark span{color:var(--gold-bright)}
  .foot-brand > p{color:rgba(250,246,238,.6);max-width:34ch;font-size:15px}
  .qr{display:flex;align-items:center;gap:16px;margin-top:28px}
  .qr-box{width:78px;height:78px;background:var(--paper);border-radius:6px;padding:9px;color:var(--navy);flex:none}
  .qr-box svg{width:100%;height:100%}
  .qr span{font-size:12.5px;color:rgba(250,246,238,.55);letter-spacing:.02em;line-height:1.5}

  .foot-col h4{font-family:var(--display);font-size:12px;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:var(--gold-bright);margin-bottom:20px}
  .foot-col a,.foot-visit p{display:block;color:rgba(250,246,238,.82);font-size:15px;margin-bottom:13px;max-width:none}
  .foot-col a:hover{color:var(--gold-bright)}
  .foot-visit p{color:rgba(250,246,238,.6)}
  .offices{margin-top:24px}
  .offices-label{font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:rgba(250,246,238,.4)}
  .offices-list{display:flex;flex-wrap:wrap;gap:8px 14px;margin-top:12px}
  .offices-list span{font-size:13.5px;color:rgba(250,246,238,.7)}

  .foot-bottom{display:flex;justify-content:space-between;align-items:center;padding-top:26px;flex-wrap:wrap;gap:14px}
  .foot-bottom > span{font-size:12.5px;color:rgba(250,246,238,.45)}
  .foot-legal{display:flex;gap:22px}
  .foot-legal a{font-size:12.5px;color:rgba(250,246,238,.6)}
  .foot-legal a:hover{color:var(--gold-bright)}

  @media(max-width:900px){.foot-grid{grid-template-columns:1fr 1fr;gap:36px}}
  @media(max-width:560px){.foot-grid{grid-template-columns:1fr}.news-form{flex-direction:column}}
</style>
