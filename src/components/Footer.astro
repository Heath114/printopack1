---
import Bi from './Bi.astro';
// Global footer: newsletter band + deep navy footer with columns, QR, offices, legal.
const year = new Date().getFullYear();
const offices = [
  { en: "Kuwait", ar: "الكويت" }, { en: "Jordan", ar: "الأردن" }, { en: "Egypt", ar: "مصر" },
  { en: "Sudan", ar: "السودان" }, { en: "Tunisia", ar: "تونس" }, { en: "Algeria", ar: "الجزائر" },
];
---
<!-- newsletter band -->
<section class="news-band">
  <div class="wrap" style="text-align:center">
    <span class="eyebrow plain" style="color:var(--gold)"><Bi en="Stay ahead" ar="ابقَ على اطّلاع" /></span>
    <h2 style="margin:14px 0 8px"><Bi en="News from Printopack" ar="أخبار برنتوباك" /></h2>
    <p class="lede" style="margin:0 auto 28px"><Bi en="Be the first to hear about new capabilities, certifications and exhibitions." ar="كن أول من يعلم بأحدث الإمكانات والشهادات والمعارض." /></p>
    <form class="news-form" onsubmit="return false">
      <input type="email" placeholder="Your email address" data-ph-ar="بريدك الإلكتروني" required />
      <button class="btn btn-solid" type="submit"><Bi en="Subscribe" ar="اشترك" /></button>
    </form>
  </div>
</section>

<footer class="site-footer on-deep">
  <div class="wrap-wide">
    <div class="foot-grid">
      <div class="foot-brand">
        <a href="/" class="wordmark" aria-label="Printopack home"><img src="/images/printopack-logo-white.png" alt="Printopack, Saudi Modern Packaging Factory" width="1600" height="562" /></a>
        <p><Bi en="Flexible packaging, printed and finished in Jeddah for brands across 26+ countries since 1997." ar="تغليف مرن، يُطبع ويُجهّز في جدة لعلامات تجارية في أكثر من 26 دولة منذ عام 1997." /></p>
        <div class="qr">
          <div class="qr-box" aria-hidden="true">
            <img src="/images/printopack-qr.png" alt="Printopack QR code" width="451" height="451" />
          </div>
          <span><Bi en="Scan for our digital profile" ar="امسح للوصول إلى ملفنا الرقمي" /></span>
        </div>
      </div>

      <div class="foot-col">
        <h4><Bi en="Company" ar="الشركة" /></h4>
        <a href="/about"><Bi en="About Us" ar="من نحن" /></a>
        <a href="/team"><Bi en="Our Team" ar="فريق العمل" /></a>
        <a href="/careers"><Bi en="Careers" ar="الوظائف" /></a>
        <a href="/responsibility"><Bi en="Social Responsibility" ar="المسؤولية الاجتماعية" /></a>
      </div>
      <div class="foot-col">
        <h4><Bi en="Explore" ar="استكشف" /></h4>
        <a href="/products"><Bi en="Products" ar="المنتجات" /></a>
        <a href="/quality"><Bi en="Quality System" ar="نظام الجودة" /></a>
        <a href="/factory"><Bi en="Factory" ar="أقسام المصنع" /></a>
        <a href="/gallery"><Bi en="Gallery" ar="معرض الصور" /></a>
        <a href="/news"><Bi en="News & Events" ar="الأخبار والأحداث" /></a>
      </div>
      <div class="foot-col foot-visit">
        <h4><Bi en="Visit Us" ar="زورونا" /></h4>
        <p><Bi en="Industrial Area 5, Unit 10, 8508, Jeddah 22428, Saudi Arabia" ar="المنطقة الصناعية 5، وحدة 10، 8508، جدة 22428، السعودية" /></p>
        <a href="mailto:info@printopack.com.sa">info@printopack.com.sa</a>
        <a href="tel:+966126081074" dir="ltr">+966 12 608 1074</a>
        <div class="offices">
          <span class="offices-label"><Bi en="Regional offices" ar="المكاتب الإقليمية" /></span>
          <div class="offices-list">{offices.map((o) => <span><Bi en={o.en} ar={o.ar} /></span>)}</div>
        </div>
      </div>
    </div>

    <div class="foot-bottom">
      <span>© {year} <Bi en="Printopack, Saudi Modern Packaging Factory Co. Ltd. All rights reserved." ar="برنتوباك، مصنع التغليف السعودي الحديث المحدود. جميع الحقوق محفوظة." /></span>
      <div class="foot-legal">
        <a href="/privacy"><Bi en="Privacy" ar="الخصوصية" /></a>
        <a href="/conditions"><Bi en="Conditions" ar="الشروط" /></a>
        <a href="https://www.linkedin.com/company/80331793/" target="_blank" rel="noopener">LinkedIn</a>
        <a href="#" target="_blank" rel="noopener">Facebook</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .news-band{background:var(--cream);border-top:1px solid var(--line)}
  .news-form{display:flex;gap:10px;max-width:480px;margin-inline:auto}
  .news-form input{flex:1;padding:16px 18px;border:1px solid var(--line);background:var(--paper);font:inherit;font-size:15px;border-radius:var(--radius)}
  .news-form input:focus{outline:none;border-color:var(--navy)}

  .site-footer{padding-block:clamp(56px,7vw,84px) 32px}
  .foot-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1.4fr;gap:48px;padding-bottom:52px;border-bottom:1px solid var(--line-dark)}
  .foot-brand .wordmark{display:inline-block;margin-bottom:18px}
  .foot-brand .wordmark img{height:52px;width:auto;display:block}
  .foot-brand > p{color:rgba(250,246,238,.6);max-width:34ch;font-size:15px}
  .qr{display:flex;align-items:center;gap:16px;margin-top:28px}
  .qr-box{width:78px;height:78px;background:var(--paper);border-radius:6px;padding:9px;color:var(--navy);flex:none}
  .qr-box svg,.qr-box img{width:100%;height:100%;display:block}
  .qr span{font-size:12.5px;color:rgba(250,246,238,.55);letter-spacing:.02em;line-height:1.5}

  .foot-col h4{font-family:var(--display);font-size:12px;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:var(--gold-bright);margin-bottom:20px}
  .foot-col a,.foot-visit p{display:block;color:rgba(250,246,238,.82);font-size:15px;margin-bottom:13px;max-width:none}
  .foot-col a:hover{color:var(--gold-bright)}
  .foot-visit p{color:rgba(250,246,238,.6)}
  .offices{margin-top:24px}
  .offices-label{font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:rgba(250,246,238,.4)}
  .offices-list{display:flex;flex-wrap:wrap;gap:8px 14px;margin-top:12px}
  .offices-list span{font-size:13.5px;color:rgba(250,246,238,.7)}

  .foot-bottom{display:flex;justify-content:space-between;align-items:center;padding-top:26px;flex-wrap:wrap;gap:14px}
  .foot-bottom > span{font-size:12.5px;color:rgba(250,246,238,.45)}
  .foot-legal{display:flex;gap:22px}
  .foot-legal a{font-size:12.5px;color:rgba(250,246,238,.6)}
  .foot-legal a:hover{color:var(--gold-bright)}

  @media(max-width:900px){.foot-grid{grid-template-columns:1fr 1fr;gap:36px}}
  @media(max-width:560px){.foot-grid{grid-template-columns:1fr}.news-form{flex-direction:column}}
</style>
