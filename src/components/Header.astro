---
import Bi from './Bi.astro';
// Global header. The client's seven main routes (his 7-page sitemap). Labels are
// bilingual { en, ar }; the Arabic is Nasser's own wording from his brief.
const nav = [
  {
    label: { en: "About Us", ar: "من نحن" }, href: "/about",
    mega: {
      links: [
        { label: { en: "The Company", ar: "الشركة" }, href: "/company" },
        { label: { en: "Factory Departments", ar: "أقسام المصنع" }, href: "/factory" },
        { label: { en: "Our Team", ar: "فريق العمل" }, href: "/team" },
        { label: { en: "Social Responsibility", ar: "المسؤولية الاجتماعية" }, href: "/responsibility" },
      ],
      featured: [
        { img: "/images/dept-1.jpg", label: { en: "Rotogravure", ar: "الطباعة الروتوغرافية" }, href: "/factory" },
        { img: "/images/factory.jpg", label: { en: "Our Plant", ar: "مصنعنا" }, href: "/about" },
      ],
    },
  },
  { label: { en: "Products", ar: "المنتجات" }, href: "/products" },
  {
    label: { en: "Quality System", ar: "نظام الجودة" }, href: "/quality",
    mega: {
      links: [
        { label: { en: "Quality Certificates", ar: "شهادات الجودة" }, href: "/quality/certificates" },
        { label: { en: "Quality Assurance", ar: "ضمان الجودة" }, href: "/quality/assurance" },
        { label: { en: "Lab & Testing", ar: "المختبر والفحص" }, href: "/quality/lab" },
      ],
      featured: [
        { img: "/images/factory-solvent.jpg", label: { en: "Certified", ar: "معتمدون" }, href: "/quality/certificates" },
        { img: "/images/dept-3.jpg", label: { en: "Tested", ar: "مفحوص" }, href: "/quality/lab" },
      ],
    },
  },
  { label: { en: "Success Partners", ar: "شركاء النجاح" }, href: "/partners" },
  { label: { en: "Careers", ar: "الوظائف" }, href: "/careers" },
  {
    label: { en: "News & Gallery", ar: "الأخبار والمعرض" }, href: "/news-gallery",
    mega: {
      links: [
        { label: { en: "News & Events", ar: "الأخبار والأحداث" }, href: "/news" },
        { label: { en: "Gallery", ar: "معرض الصور" }, href: "/gallery" },
      ],
      featured: [
        { img: "/images/lineup.jpg", label: { en: "Latest news", ar: "أحدث الأخبار" }, href: "/news" },
        { img: "/images/dept-2.jpg", label: { en: "Gallery", ar: "معرض الصور" }, href: "/gallery" },
      ],
    },
  },
  { label: { en: "Contact", ar: "التواصل" }, href: "/contact" },
];
---
<!-- Utility strip: surfaced contact details + social, in navy chrome. Scrolls away;
     the nav below stays sticky. Adds brand color at the very top of the page. -->
<div class="hdr-utility">
  <div class="wrap-wide util-inner">
    <div class="util-contact">
      <a href="tel:+966126081074" class="util-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M4 5c0 9 6 15 15 15l2.5-3.5-4.5-2-1.8 1.8a12 12 0 0 1-5.3-5.3L7.7 9 5.7 4.5 4 5z"/></svg>
        <span dir="ltr">+966 12 608 1074</span>
      </a>
      <a href="mailto:info@printopack.com.sa" class="util-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="5" width="18" height="14" rx="1.5"/><path d="M3.5 6.5 12 13l8.5-6.5"/></svg>
        <span>info@printopack.com.sa</span>
      </a>
      <span class="util-item util-addr">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 21s7-5.4 7-11a7 7 0 1 0-14 0c0 5.6 7 11 7 11z"/><circle cx="12" cy="10" r="2.5"/></svg>
        <span><Bi en="Industrial Area 5, Jeddah, Saudi Arabia" ar="المنطقة الصناعية 5، جدة، السعودية" /></span>
      </span>
    </div>
    <div class="util-social">
      <span class="util-follow"><Bi en="Follow us" ar="تابعنا" /></span>
      <a href="https://www.linkedin.com/company/80331793/" target="_blank" rel="noopener" aria-label="LinkedIn">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M4.98 3.5A2.5 2.5 0 1 1 5 8.5a2.5 2.5 0 0 1 0-5zM3 9h4v12H3zM9 9h3.8v1.7h.05c.53-1 1.83-2.05 3.77-2.05 4.03 0 4.78 2.65 4.78 6.1V21h-4v-5.4c0-1.3 0-2.95-1.8-2.95s-2.08 1.4-2.08 2.85V21H9z"/></svg>
      </a>
      <a href="#" target="_blank" rel="noopener" aria-label="Facebook">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M14 9h3V6h-3c-2.2 0-3.5 1.5-3.5 3.7V11H8v3h2.5v7h3v-7H16l.5-3h-3V9.9c0-.6.3-.9 1-.9z"/></svg>
      </a>
      <a href="#" target="_blank" rel="noopener" aria-label="Instagram">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="3.5" y="3.5" width="17" height="17" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.2" cy="6.8" r="1" fill="currentColor" stroke="none"/></svg>
      </a>
    </div>
  </div>
</div>

<header class="site-header">
  <div class="wrap-wide hdr-top">
    <button class="hdr-icon hdr-left" aria-label="Search">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
      <span><Bi en="Search" ar="البحث" /></span>
    </button>
    <a href="/" class="wordmark" aria-label="Printopack home"><img src="/images/printopack-logo.png" alt="Printopack, Saudi Modern Packaging Factory" width="1600" height="562" /></a>
    <div class="hdr-right">
      <button class="lang" aria-label="Switch language">ع</button>
      <!-- Two distinct logins: customers go to their POS portal, staff to the CMS -->
      <a href="https://printopack.azurewebsites.net/" target="_blank" rel="noopener" class="hdr-icon" title="Existing customers: orders, statements and documents">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 3.6-6.5 8-6.5s8 2.5 8 6.5"/></svg>
        <span><Bi en="Customer Login" ar="دخول العملاء" /></span>
      </a>
      <a href="/admin/" target="_blank" rel="noopener" class="hdr-icon hdr-admin" title="Printopack staff: site administration">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 3l7 3v5c0 4.4-3 8.4-7 10-4-1.6-7-5.6-7-10V6z"/><path d="M9.2 12l2 2 3.6-4"/></svg>
        <span><Bi en="Admin" ar="الإدارة" /></span>
      </a>
      <!-- Unified QR: the client's fourth header control. Opens a small still panel
           with the scannable code linking to Printopack's digital profile. -->
      <div class="hdr-qr">
        <button class="hdr-icon qr-btn" aria-label="Show QR code" aria-expanded="false" aria-controls="qr-pop">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><path d="M14 14h3v3M20 14v.01M14 20h.01M17 20h3v-3" stroke-linecap="round"/></svg>
          <span>QR</span>
        </button>
        <div class="qr-pop" id="qr-pop" hidden>
          <div class="qr-pop-box" aria-hidden="true">
            <img src="/images/printopack-qr.png" alt="Printopack QR code" width="451" height="451" />
          </div>
          <span class="qr-pop-cap"><Bi en="Scan for Printopack's digital profile" ar="امسح للوصول إلى الملف الرقمي لبرنتوباك" /></span>
        </div>
      </div>
    </div>
    <button class="burger" aria-label="Menu" aria-expanded="false" aria-controls="mobile-nav"><span></span><span></span><span></span></button>
  </div>

  <nav class="hdr-nav">
    <ul class="wrap-wide">
      {nav.map((item) => (
        <li class={item.mega ? "has-mega" : ""}>
          <a href={item.href}><Bi en={item.label.en} ar={item.label.ar} /></a>
          {item.mega && (
            <div class="mega">
              <div class="mega-inner wrap-wide">
                <div class="mega-links">
                  <span class="mega-kicker"><Bi en="Explore" ar="استكشف" /></span>
                  {item.mega.links.map((l) => <a href={l.href}><Bi en={l.label.en} ar={l.label.ar} /></a>)}
                  <a href={item.href} class="mega-all"><Bi en="View all" ar="عرض الكل" /> &rarr;</a>
                </div>
                <div class="mega-feature">
                  {item.mega.featured.map((f) => (
                    <a href={f.href} class="mega-card">
                      <span class="mega-card-img"><img src={f.img} alt={f.label.en} /></span>
                      <span class="mega-card-label"><Bi en={f.label.en} ar={f.label.ar} /></span>
                    </a>
                  ))}
                </div>
              </div>
            </div>
          )}
        </li>
      ))}
    </ul>
  </nav>
</header>

<!-- mobile nav panel (burger, <=720px). Lives outside <header> because its
     backdrop-filter creates a containing block that would trap position:fixed. -->
<nav class="mobile-nav" id="mobile-nav" aria-label="Mobile" hidden>
  {nav.map((item) => (
    <div class="mnav-group">
      <a href={item.href} class="mnav-link"><Bi en={item.label.en} ar={item.label.ar} /></a>
      {item.mega && item.mega.links.map((l) => <a href={l.href} class="mnav-sub"><Bi en={l.label.en} ar={l.label.ar} /></a>)}
    </div>
  ))}
  <div class="mnav-group mnav-logins">
    <a href="https://printopack.azurewebsites.net/" target="_blank" rel="noopener" class="mnav-link"><Bi en="Customer Login" ar="دخول العملاء" /></a>
    <a href="/admin/" target="_blank" rel="noopener" class="mnav-sub"><Bi en="Site administration" ar="إدارة الموقع" /></a>
  </div>
  <div class="mnav-qr">
    <div class="mnav-qr-box"><img src="/images/printopack-qr.png" alt="Printopack QR code" width="451" height="451" /></div>
    <span class="mnav-qr-cap"><Bi en="Scan for Printopack's digital profile" ar="امسح للوصول إلى الملف الرقمي لبرنتوباك" /></span>
  </div>
</nav>

<style>
  /* utility strip */
  .hdr-utility{background:var(--navy-deep);color:rgba(250,246,238,.82)}
  .util-inner{display:flex;align-items:center;justify-content:space-between;gap:20px;min-height:42px;padding-block:6px}
  .util-contact{display:flex;align-items:center;gap:26px;flex-wrap:wrap}
  .util-item{display:inline-flex;align-items:center;gap:8px;font-size:12.5px;letter-spacing:.02em;color:rgba(250,246,238,.82)}
  a.util-item:hover{color:var(--gold-bright)}
  .util-item svg{width:15px;height:15px;color:var(--gold-bright);flex:none}
  .util-social{display:flex;align-items:center;gap:14px}
  .util-follow{font-family:var(--display);font-size:11px;font-weight:500;letter-spacing:.18em;text-transform:uppercase;color:rgba(250,246,238,.45)}
  .util-social a{display:inline-flex;color:rgba(250,246,238,.72)}
  .util-social a:hover{color:var(--gold-bright)}
  .util-social svg{width:16px;height:16px}
  @media(max-width:980px){.util-addr{display:none}}
  @media(max-width:640px){.util-follow{display:none}.util-inner{gap:12px}.util-contact{gap:16px}.util-item span{font-size:12px}}
  @media(max-width:440px){.util-social{display:none}.util-contact{gap:14px;justify-content:center;width:100%}}

  .site-header{position:sticky;top:0;z-index:60;background:color-mix(in srgb, var(--paper) 92%, transparent);backdrop-filter:blur(12px);border-bottom:1px solid var(--line)}
  .hdr-top{display:grid;grid-template-columns:1fr auto 1fr;align-items:center;height:82px}
  .hdr-icon{display:inline-flex;align-items:center;gap:9px;font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);font-family:var(--display);font-weight:500}
  .hdr-icon:hover{color:var(--ink)}
  .hdr-icon svg{width:19px;height:19px}
  .hdr-right{display:flex;align-items:center;gap:22px;justify-content:flex-end}
  .hdr-admin{color:var(--faint)}
  .hdr-admin:hover{color:var(--gold)}
  .lang{font-family:var(--display);font-size:14px;font-weight:600;color:var(--muted);letter-spacing:.05em}
  .lang:hover{color:var(--gold)}

  /* QR control + popover */
  .hdr-qr{position:relative}
  .qr-btn[aria-expanded="true"]{color:var(--gold)}
  .qr-pop{position:absolute;top:calc(100% + 16px);right:0;z-index:70;background:var(--paper);border:1px solid var(--line);box-shadow:0 24px 44px rgba(14,35,64,.16);border-radius:var(--radius);padding:18px;width:190px;text-align:center}
  .qr-pop::before{content:"";position:absolute;top:-6px;right:22px;width:11px;height:11px;background:var(--paper);border-left:1px solid var(--line);border-top:1px solid var(--line);transform:rotate(45deg)}
  .qr-pop-box{width:150px;height:150px;margin-inline:auto;background:var(--paper)}
  .qr-pop-box svg,.qr-pop-box img{width:100%;height:100%;display:block}
  .qr-pop-cap{display:block;margin-top:12px;font-family:var(--display);font-size:11.5px;letter-spacing:.06em;color:var(--muted);line-height:1.5}
  .wordmark{display:inline-flex;align-items:center}
  .wordmark img{height:46px;width:auto;display:block}

  .hdr-nav{border-top:1px solid var(--line-soft)}
  .hdr-nav > ul{display:flex;justify-content:center;gap:clamp(20px,3vw,46px)}
  .hdr-nav li{position:static}
  .hdr-nav li > a{display:block;padding:17px 2px;font-family:var(--display);font-size:13px;font-weight:500;letter-spacing:.1em;text-transform:uppercase;color:var(--ink);position:relative}
  .hdr-nav li > a::after{content:"";position:absolute;left:0;right:0;bottom:0;height:2px;background:var(--gold);opacity:0}
  .hdr-nav li:hover > a{color:var(--navy)}
  .hdr-nav li:hover > a::after{opacity:1}

  /* mega */
  .mega{position:absolute;left:0;right:0;top:100%;background:var(--paper);border-top:1px solid var(--line);border-bottom:1px solid var(--line);box-shadow:0 30px 50px rgba(14,35,64,.08);opacity:0;visibility:hidden;z-index:5}
  .has-mega:hover .mega{opacity:1;visibility:visible}
  .mega-inner{display:grid;grid-template-columns:1fr 1fr;gap:60px;padding-block:44px}
  .mega-links{display:flex;flex-direction:column;gap:2px}
  .mega-kicker{font-family:var(--display);font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);margin-bottom:16px}
  .mega-links > a{font-family:var(--display);font-size:22px;font-weight:300;color:var(--ink);padding:9px 0;width:fit-content}
  .mega-links > a:hover{color:var(--gold)}
  .mega-all{margin-top:14px;font-size:13px!important;letter-spacing:.1em;text-transform:uppercase;color:var(--muted)!important}
  .mega-feature{display:grid;grid-template-columns:1fr 1fr;gap:22px}
  .mega-card-img{display:block;aspect-ratio:4/3;overflow:hidden;background:var(--cream)}
  .mega-card-img img{width:100%;height:100%;object-fit:cover}
  .mega-card-label{display:block;margin-top:12px;font-family:var(--display);font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:var(--muted)}

  .burger{display:none;flex-direction:column;gap:5px;padding:6px;justify-self:end}
  .burger span{width:24px;height:1.5px;background:var(--ink)}
  .burger.open span:nth-child(1){transform:translateY(6.5px) rotate(45deg)}
  .burger.open span:nth-child(2){opacity:0}
  .burger.open span:nth-child(3){transform:translateY(-6.5px) rotate(-45deg)}

  /* mobile nav panel */
  .mobile-nav{display:none}

  @media(max-width:1080px){
    .hdr-nav > ul{gap:20px;overflow-x:auto;justify-content:flex-start}
    .mega{display:none}
  }
  @media(max-width:720px){
    .hdr-top{grid-template-columns:auto 1fr auto auto;gap:14px;height:68px}
    .hdr-right{gap:18px}
    .hdr-left span,.hdr-icon span{display:none}
    /* declutter the top bar: customer login, admin and QR live inside the menu on mobile */
    .hdr-right .hdr-icon,.hdr-qr{display:none}
    .lang{font-size:16px}
    .wordmark img{height:36px}
    .hdr-nav{display:none}
    .burger{display:flex}
    .mobile-nav:not([hidden]){display:block;position:fixed;top:68px;left:0;right:0;bottom:0;background:var(--paper);overflow-y:auto;padding:22px var(--gutter) 48px;border-top:1px solid var(--line);z-index:55}
    .mnav-group{border-bottom:1px solid var(--line-soft);padding:8px 0}
    .mnav-link{display:block;font-family:var(--display);font-size:23px;font-weight:300;color:var(--ink);padding:12px 0}
    .mnav-sub{display:block;font-family:var(--display);font-size:14px;color:var(--muted);letter-spacing:.04em;padding:8px 0 8px 18px}
    .mnav-qr{display:flex;align-items:center;gap:16px;padding-top:26px}
    .mnav-qr-box{width:92px;height:92px;background:var(--paper);border:1px solid var(--line);border-radius:8px;padding:5px;flex:none}
    .mnav-qr-box img{width:100%;height:100%;display:block}
    .mnav-qr-cap{font-family:var(--display);font-size:13px;color:var(--muted);line-height:1.5;max-width:22ch}
  }
</style>

<script>
  // Burger toggle for the mobile nav panel. No motion: instant show/hide.
  const burger = document.querySelector('.burger');
  const panel = document.getElementById('mobile-nav');
  burger?.addEventListener('click', () => {
    if (!panel) return;
    const open = panel.hasAttribute('hidden');
    panel.toggleAttribute('hidden', !open);
    burger.classList.toggle('open', open);
    burger.setAttribute('aria-expanded', String(open));
    document.body.style.overflow = open ? 'hidden' : '';
  });
  // If the viewport leaves burger territory while the panel is open, reset state.
  matchMedia('(min-width: 721px)').addEventListener('change', (m) => {
    if (m.matches && panel && !panel.hasAttribute('hidden')) {
      panel.setAttribute('hidden', '');
      burger?.classList.remove('open');
      burger?.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }
  });

  // QR popover: click to toggle, close on outside-click or Escape. No motion.
  const qrBtn = document.querySelector('.qr-btn');
  const qrPop = document.getElementById('qr-pop');
  const setQr = (open) => {
    if (!qrPop || !qrBtn) return;
    qrPop.toggleAttribute('hidden', !open);
    qrBtn.setAttribute('aria-expanded', String(open));
  };
  qrBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    setQr(qrPop?.hasAttribute('hidden') ?? false);
  });
  document.addEventListener('click', (e) => {
    if (qrPop && !qrPop.hasAttribute('hidden') && !e.target.closest('.hdr-qr')) setQr(false);
  });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') setQr(false); });

  // Language toggle: flip EN/AR, set dir, persist, and show the OTHER language on the button.
  const langBtn = document.querySelector('.lang');
  const swapAttrs = (l) => {
    document.querySelectorAll('[data-ph-ar]').forEach((el) => {
      if (!el.dataset.phEn) el.dataset.phEn = el.getAttribute('placeholder') || '';
      el.setAttribute('placeholder', l === 'ar' ? el.dataset.phAr : el.dataset.phEn);
    });
  };
  const applyLang = (l) => {
    document.documentElement.lang = l;
    document.documentElement.dir = l === 'ar' ? 'rtl' : 'ltr';
    try { localStorage.setItem('lang', l); } catch (e) {}
    if (langBtn) langBtn.textContent = l === 'ar' ? 'EN' : 'ع';
    swapAttrs(l);
  };
  const curLang = document.documentElement.dir === 'rtl' ? 'ar' : 'en';
  if (langBtn) {
    langBtn.textContent = curLang === 'ar' ? 'EN' : 'ع';
    langBtn.addEventListener('click', () => applyLang(document.documentElement.dir === 'rtl' ? 'en' : 'ar'));
  }
  swapAttrs(curLang);
</script>
