---
import Base from '../layouts/Base.astro';
import Bi from '../components/Bi.astro';
import { collection } from '../lib/content';

// ── EDITABLE CONTENT (bilingual) ─────────────────────────────────────────────
// Each visible string is { en, ar }. The Arabic is natural fusha, NOT a literal
// translation: the group names and items are Nasser's own Arabic words from his brief;
// "شهاداتنا" is Printopack's own term from their live site. The certificate slot is a
// content-editable template seeded with the real BRCGS certificate.
const content = {
  meta: {
    title: "Social Responsibility - Printopack",
    description: "Printopack's social responsibility across three areas: the environment, the local community, and the international community.",
  },
  header: {
    eyebrow: { en: "Social responsibility", ar: "المسؤولية الاجتماعية" },
    title: { en: "Social responsibility.", ar: "المسؤولية الاجتماعية" },
    lede: {
      en: "Printopack's social responsibility covers three areas: the environment, the local community, and the international community.",
      ar: "تشمل مسؤولية برنتوباك الاجتماعية ثلاثة مجالات: البيئة، والمجتمع المحلي، والمجتمع الدولي.",
    },
  },
  groups: [
    {
      icon: '<path d="M4 20c8 0 16-4 16-16C12 4 4 8 4 20z"/><path d="M4 20c4-6 8-8 12-9"/>',
      name: { en: "Environment", ar: "البيئة" },
      items: [
        { en: "ISO 14000 certificates and its family of standards", ar: "شهادات الأيزو 14 ألف وأخواتها" },
        { en: "Safety system", ar: "نظام السلامة" },
        { en: "Pollution-protection system", ar: "نظام الحماية من التلوث" },
      ],
    },
    {
      icon: '<circle cx="9" cy="8" r="3"/><path d="M3.5 20c0-3 2.6-5 5.5-5s5.5 2 5.5 5"/><circle cx="17.5" cy="9" r="2.2"/><path d="M15.5 20c0-2.4 1.8-4 3.8-4"/>',
      name: { en: "Local community", ar: "المجتمع المحلي" },
      items: [
        { en: "Licence number", ar: "رقم الترخيص" },
        { en: "Saudization certificate", ar: "شهادة السعودة" },
        { en: "Mowaamah certificate", ar: "شهادة المواءمة" },
      ],
    },
    {
      icon: '<circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c3 3.5 3 14.5 0 18M12 3c-3 3.5-3 14.5 0 18"/>',
      name: { en: "International community", ar: "المجتمع الدولي" },
      items: [
        { en: "Global trade", ar: "التجارة العالمية" },
        { en: "Certified shipping", ar: "الشحن المعتمد" },
        { en: "Safe product", ar: "المنتج الآمن" },
      ],
    },
  ],
  certifications: {
    eyebrow: { en: "Certifications", ar: "الشهادات" },
    title: { en: "Our certificates.", ar: "شهاداتنا" },
    note: {
      en: "Click any certificate to view it. Further certificates are published here as they are renewed.",
      ar: "انقر على أي شهادة لعرضها. وتُنشر المزيد من الشهادات هنا عند تجديدها.",
    },
    // Full certificate list, sourced from the content store (admin-managed).
    items: collection('responsibility').map((r) => ({
      name: { en: r.title, ar: r.titleAr },
      note: { en: r.description, ar: r.descriptionAr },
      image: r.image,
      href: r.link || undefined,
    })),
  },
};
const c = content;
---
<Base title={c.meta.title} description={c.meta.description}>
  <!-- PAGE HEADER -->
  <section class="page-head">
    <div class="wrap-wide">
      <div class="page-head-inner">
        <span class="eyebrow"><Bi en={c.header.eyebrow.en} ar={c.header.eyebrow.ar} /></span>
        <h1><Bi en={c.header.title.en} ar={c.header.title.ar} /></h1>
        <p class="lede"><Bi en={c.header.lede.en} ar={c.header.lede.ar} /></p>
      </div>
    </div>
  </section>

  <!-- THREE GROUPS -->
  <section class="groups">
    <div class="wrap-wide">
      <div class="group-grid">
        {c.groups.map((g) => (
          <div class="group">
            <span class="group-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" set:html={g.icon} />
            </span>
            <h3><Bi en={g.name.en} ar={g.name.ar} /></h3>
            <ul>
              {g.items.map((it) => (
                <li>
                  <span class="tick" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l4.5 4.5L19 7"/></svg>
                  </span>
                  <Bi en={it.en} ar={it.ar} />
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CERTIFICATES (the full list of Printopack's certificates; other pages link here) -->
  <section class="certs" id="certificates" style="background:var(--cream);scroll-margin-top:120px">
    <div class="wrap-wide">
      <div class="section-head">
        <span class="eyebrow"><Bi en={c.certifications.eyebrow.en} ar={c.certifications.eyebrow.ar} /></span>
        <h2><Bi en={c.certifications.title.en} ar={c.certifications.title.ar} /></h2>
      </div>
      <div class="cert-grid">
        {c.certifications.items.map((cert) => (
          <a class="cert-card" href={cert.href ?? cert.image} target="_blank" rel="noopener">
            <span class="cert-thumb"><img src={cert.image} alt={cert.name.en} loading="lazy" /></span>
            <span class="cert-body">
              <span class="cert-name"><Bi en={cert.name.en} ar={cert.name.ar} /></span>
              <span class="cert-note"><Bi en={cert.note.en} ar={cert.note.ar} /></span>
            </span>
          </a>
        ))}
      </div>
      <p class="resp-note"><Bi en={c.certifications.note.en} ar={c.certifications.note.ar} /></p>
    </div>
  </section>
</Base>

<style>
  .page-head{padding-block:clamp(56px,8vw,104px) clamp(30px,4vw,52px);background:var(--cream);border-bottom:1px solid var(--line)}
  .page-head-inner{max-width:820px}
  .page-head h1{margin:20px 0 22px;font-size:clamp(40px,6vw,78px)}
  .page-head .lede{max-width:62ch}

  .group-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:28px}
  .group{background:var(--cream);border:1px solid var(--line);border-radius:var(--radius);padding:clamp(28px,3vw,38px)}
  .group-icon{display:inline-flex;align-items:center;justify-content:center;width:54px;height:54px;border-radius:50%;background:var(--gold-soft);color:var(--gold);margin-bottom:20px}
  .group-icon svg{width:26px;height:26px}
  .group h3{font-size:clamp(21px,2vw,26px);margin-bottom:18px;padding-bottom:16px;border-bottom:1px solid var(--line)}
  .group li{display:flex;align-items:flex-start;gap:11px;color:var(--ink);padding:8px 0;font-size:15px}
  .tick{flex:none;display:inline-flex;color:var(--gold);margin-top:3px}
  .tick svg{width:17px;height:17px}
  .resp-note{margin-top:clamp(32px,4vw,48px);color:var(--faint);font-size:14px}
  @media(max-width:820px){.group-grid{grid-template-columns:1fr;gap:20px}}

  /* certificate slots: auto-fill grid holds any number, any shape, without breaking */
  .cert-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(230px,1fr));gap:24px}
  .cert-card{display:flex;flex-direction:column;background:var(--paper);border:1px solid var(--line);border-radius:var(--radius);overflow:hidden}
  .cert-card:hover{border-color:var(--navy);box-shadow:0 18px 36px rgba(14,35,64,.08)}
  .cert-thumb{background:var(--white);aspect-ratio:3/4;display:grid;place-items:center;overflow:hidden;padding:14px;border-bottom:1px solid var(--line)}
  .cert-thumb img{max-width:100%;max-height:100%;width:auto;height:auto;object-fit:contain}
  .cert-body{padding:16px 18px}
  .cert-name{display:block;font-family:var(--display);font-size:16px;color:var(--ink);line-height:1.3}
  .cert-note{display:block;margin-top:6px;font-size:13px;color:var(--muted)}
  @media(max-width:520px){.cert-grid{grid-template-columns:1fr}}
</style>
