---
import Base from '../layouts/Base.astro';
import Counter from '../components/Counter.astro';
import Bi from '../components/Bi.astro';
import { collection } from '../lib/content';
const year = new Date().getFullYear();

// ── EDITABLE CONTENT (bilingual) ─────────────────────────────────────────────
// Team (Nasser's Page 1 subsection). He asked for manager names + photos; the live
// site has no team page, so names/photos are client-gated: leadership is shown by role
// with a photo/monogram slot (no invented names). The admin swaps each slot for a real
// name + photo. Employee count (~400) is real. NOTE: Nasser also wanted total-years and
// average-years-of-experience counters; those numbers are client-provided (pending).
const content = {
  meta: {
    title: "Our Team - Printopack",
    description: "The people behind Printopack: a team of around 400 across production, quality, engraving and commercial, led by experienced managers in Jeddah.",
  },
  header: {
    eyebrow: { en: "Our team", ar: "فريق العمل" },
    title: { en: "The people behind Printopack.", ar: "الأشخاص الذين يقفون خلف برنتوباك." },
    lede: {
      en: "Packaging is made by people. Around 400 of them, across the press floor, the engraving room, the lab and the offices, turn each brief into a finished product, run after run.",
      ar: "التغليف يصنعه الناس؛ نحو 400 شخص في أرضية المصنع وغرفة الحفر والمختبر والمكاتب يحوّلون كل موجزٍ إلى منتجٍ نهائي، تشغيلةً بعد أخرى.",
    },
  },
  counters: [
    { prefix: "~", value: 400, label: { en: "Team members", ar: "عضو في الفريق" } },
    { from: 1997, value: year, label: { en: "Operating since 1997", ar: "نعمل منذ 1997" } },
    { value: 5, label: { en: "Production departments", ar: "أقسام إنتاجية" } },
    { value: 6, label: { en: "Regional offices", ar: "مكاتب إقليمية" } },
  ],
  leadership: {
    eyebrow: { en: "Leadership", ar: "القيادة" },
    title: { en: "Led by people who know packaging.", ar: "يقودها أشخاص يعرفون التغليف." },
    lede: {
      en: "Each part of the business is run by a manager with deep experience in flexible packaging.",
      ar: "يدير كل جزء من الأعمال مديرٌ ذو خبرة عميقة في التغليف المرن.",
    },
    // Each member has a name slot (client-gated, filled via admin) + role, photo/monogram
    // and a concise note. When `name` is filled it becomes the heading and the role moves
    // to a subtitle; until then the role heads the card. The admin adds/edits/removes these.
    // Sourced from the content store (admin-managed). Blank name -> the card shows the role
    // as its heading (no invented name), exactly as before.
    members: collection('team').map((m) => ({
      photo: m.photo, mono: m.mono,
      name: { en: m.name, ar: m.nameAr },
      role: { en: m.role, ar: m.roleAr },
      desc: { en: m.bio, ar: m.bioAr },
    })),
  },
  culture: {
    eyebrow: { en: "Life at Printopack", ar: "الحياة في برنتوباك" },
    quote: {
      en: "We hire for craft and care, then give people the tools and the standard to do their best work.",
      ar: "نوظّف على أساس الإتقان والاهتمام، ثم نمنح الناس الأدوات والمعيار ليقدّموا أفضل ما لديهم.",
    },
    link: { en: "Explore careers", ar: "استكشف الوظائف" },
  },
  cta: {
    eyebrow: { en: "Work with our team", ar: "اعمل مع فريقنا" },
    title: { en: "Have a project in mind?", ar: "لديك مشروع في ذهنك؟" },
    button: { en: "Request a quote", ar: "اطلب عرض سعر" },
  },
};
const c = content;
---
<Base title={c.meta.title} description={c.meta.description}>
  <!-- PAGE HEADER -->
  <section class="page-head">
    <div class="wrap-wide">
      <div class="page-head-inner">
        <span class="eyebrow"><Bi en={c.header.eyebrow.en} ar={c.header.eyebrow.ar} /></span>
        <h1><Bi en={c.header.title.en} ar={c.header.title.ar} /></h1>
        <p class="lede"><Bi en={c.header.lede.en} ar={c.header.lede.ar} /></p>
      </div>
    </div>
  </section>

  <!-- COUNTERS -->
  <section class="on-deep team-stats">
    <div class="wrap-wide counters-row">
      {c.counters.map((n) => <Counter from={n.from} prefix={n.prefix} value={n.value} label={n.label.en} labelAr={n.label.ar} />)}
    </div>
  </section>

  <!-- LEADERSHIP -->
  <section class="leadership">
    <div class="wrap-wide">
      <div class="section-head">
        <span class="eyebrow"><Bi en={c.leadership.eyebrow.en} ar={c.leadership.eyebrow.ar} /></span>
        <h2 style="margin-top:16px"><Bi en={c.leadership.title.en} ar={c.leadership.title.ar} /></h2>
        <p class="lede"><Bi en={c.leadership.lede.en} ar={c.leadership.lede.ar} /></p>
      </div>
      <div class="team-grid">
        {c.leadership.members.map((m) => (
          <div class="member">
            <span class="avatar">
              {m.photo
                ? <img src={m.photo} alt={m.name.en || m.role.en} />
                : <span class="avatar-mono" aria-hidden="true">{m.mono}</span>}
            </span>
            {m.name.en
              ? <><h3 class="member-name"><Bi en={m.name.en} ar={m.name.ar} /></h3><span class="member-role"><Bi en={m.role.en} ar={m.role.ar} /></span></>
              : <h3 class="member-name"><Bi en={m.role.en} ar={m.role.ar} /></h3>}
            <p class="member-desc"><Bi en={m.desc.en} ar={m.desc.ar} /></p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CULTURE BAND -->
  <section class="culture">
    <div class="culture-bg"><img src="/images/factory.jpg" alt="Inside the Printopack facility" loading="lazy" /></div>
    <div class="wrap culture-inner">
      <span class="eyebrow" style="color:var(--gold-bright)"><Bi en={c.culture.eyebrow.en} ar={c.culture.eyebrow.ar} /></span>
      <p class="culture-quote"><Bi en={c.culture.quote.en} ar={c.culture.quote.ar} /></p>
      <a href="/careers" class="link-line" style="color:var(--gold-bright);border-color:var(--gold-bright)"><Bi en={c.culture.link.en} ar={c.culture.link.ar} /></a>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta">
    <div class="wrap" style="text-align:center">
      <span class="eyebrow plain" style="color:var(--gold)"><Bi en={c.cta.eyebrow.en} ar={c.cta.eyebrow.ar} /></span>
      <h2 style="margin:16px 0 26px"><Bi en={c.cta.title.en} ar={c.cta.title.ar} /></h2>
      <a href="/contact" class="btn btn-gold"><Bi en={c.cta.button.en} ar={c.cta.button.ar} /></a>
    </div>
  </section>
</Base>

<style>
  .page-head{padding-block:clamp(56px,8vw,104px) clamp(30px,4vw,52px);background:var(--cream);border-bottom:1px solid var(--line)}
  .page-head-inner{max-width:820px}
  .page-head h1{margin:20px 0 22px;font-size:clamp(40px,6vw,78px)}
  .page-head .lede{max-width:60ch}

  .team-stats{padding-block:clamp(52px,6vw,78px)}
  .counters-row{display:grid;grid-template-columns:repeat(4,1fr);gap:30px}

  .leadership .section-head{max-width:640px}
  .leadership .lede{margin-top:18px}
  .team-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:clamp(26px,3vw,44px)}
  .member{text-align:start}
  .avatar{
    display:grid;place-items:center;width:76px;height:76px;border-radius:50%;overflow:hidden;
    background:var(--cream);border:1px solid var(--gold);margin-bottom:20px;
  }
  .avatar img{width:100%;height:100%;object-fit:cover}
  .avatar-mono{font-family:var(--display);font-weight:400;font-size:23px;letter-spacing:.04em;color:var(--navy)}
  .member-name{font-size:clamp(18px,1.5vw,21px);margin-bottom:8px}
  .member-role{display:block;font-family:var(--display);font-size:12px;font-weight:500;letter-spacing:.1em;text-transform:uppercase;color:var(--gold);margin-bottom:10px}
  .member-desc{font-size:14.5px;color:var(--muted);line-height:1.6;max-width:30ch}

  .culture{position:relative;color:var(--paper);overflow:hidden;padding-block:clamp(88px,12vw,150px)}
  .culture-bg{position:absolute;inset:0}
  .culture-bg img{width:100%;height:100%;object-fit:cover}
  .culture-bg::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,rgba(9,24,41,.72),rgba(9,24,41,.86))}
  .culture-inner{position:relative;z-index:2;text-align:center;max-width:900px}
  .culture-quote{font-family:var(--display);font-weight:300;font-size:clamp(24px,3.4vw,42px);line-height:1.28;margin:22px auto 28px;max-width:24ch}

  @media(max-width:1000px){
    .counters-row{grid-template-columns:repeat(2,1fr);gap:36px 24px}
    .team-grid{grid-template-columns:repeat(2,1fr);gap:40px 28px}
  }
  @media(max-width:520px){
    .counters-row{grid-template-columns:1fr}
    .team-grid{grid-template-columns:1fr}
  }
</style>
