---
import Base from '../layouts/Base.astro';
import Counter from '../components/Counter.astro';
// Years in the market: computed live so it is always current (climbs from 1997).
const year = new Date().getFullYear();

// Team. Employee count is known (~400). Individual manager names and photos are
// provided by the client and added via the admin CMS, so leadership is shown here
// by role with monogram placeholders (no invented names). The client swaps each
// monogram for a photo and adds the person's name when ready.
const leaders = [
  { role: "General Management", mono: "GM", desc: "Sets direction and holds every run to the Printopack standard." },
  { role: "Operations", mono: "OP", desc: "Keeps the plant running to plan, safely and on time." },
  { role: "Production", mono: "PR", desc: "Owns the press floor, from substrate to finished reel." },
  { role: "Engraving & Prepress", mono: "EP", desc: "Turns artwork into engraved cylinders, ready to print." },
  { role: "Quality & Compliance", mono: "QC", desc: "Guards food safety and quality from incoming goods to dispatch." },
  { role: "Commercial & Export", mono: "CX", desc: "Partners with brands across 26 countries and beyond." },
  { role: "Supply Chain", mono: "SC", desc: "Plans materials and delivery so orders land on time." },
  { role: "IT & Systems", mono: "IT", desc: "Runs the systems behind the factory and the customer portal." },
];
---
<Base
  title="Our Team - Printopack"
  description="The people behind Printopack: a team of around 400 across production, quality, engraving and commercial, led by experienced managers in Jeddah."
>
  <!-- PAGE HEADER -->
  <section class="page-head">
    <div class="wrap-wide">
      <div class="page-head-inner">
        <span class="eyebrow" data-reveal>Our team</span>
        <h1 data-reveal>The people behind Printopack.</h1>
        <p class="lede" data-reveal>
          Packaging is made by people. Around 400 of them, across the press floor, the engraving
          room, the lab and the offices, turn each brief into a finished product, run after run.
        </p>
      </div>
    </div>
  </section>

  <!-- COUNTERS -->
  <section class="on-deep team-stats">
    <div class="wrap-wide counters-row">
      <Counter prefix="~" value="400" label="Team members" />
      <Counter from="1997" value={year} label="Operating since 1997" />
      <Counter value="5" label="Production departments" />
      <Counter value="6" label="Regional offices" />
    </div>
  </section>

  <!-- LEADERSHIP -->
  <section class="leadership">
    <div class="wrap-wide">
      <div class="section-head" data-reveal>
        <span class="eyebrow">Leadership</span>
        <h2 style="margin-top:16px">Led by people who know packaging.</h2>
        <p class="lede">Each part of the business is run by a manager with deep experience in flexible packaging. Names and photographs are being added.</p>
      </div>
      <div class="team-grid">
        {leaders.map((l) => (
          <div class="member" data-reveal>
            <span class="avatar" aria-hidden="true">{l.mono}</span>
            <h3 class="member-role">{l.role}</h3>
            <p class="member-desc">{l.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CULTURE BAND -->
  <section class="culture">
    <div class="culture-bg"><img src="/images/factory.jpg" alt="Inside the Printopack facility" loading="lazy" /></div>
    <div class="wrap culture-inner">
      <span class="eyebrow" data-reveal style="color:var(--gold-bright)">Life at Printopack</span>
      <p class="culture-quote" data-reveal>
        We hire for craft and care, then give people the tools and the standard to do their best work.
      </p>
      <a href="/careers" class="link-line" data-reveal style="color:var(--gold-bright);border-color:var(--gold-bright)">Explore careers</a>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta">
    <div class="wrap" style="text-align:center">
      <span class="eyebrow plain" data-reveal style="color:var(--gold)">Work with our team</span>
      <h2 data-reveal style="margin:16px 0 26px">Have a project in mind?</h2>
      <a href="/contact" class="btn btn-gold" data-reveal>Request a quote</a>
    </div>
  </section>
</Base>

<style>
  .page-head{padding-block:clamp(56px,8vw,104px) clamp(30px,4vw,52px);background:var(--cream);border-bottom:1px solid var(--line)}
  .page-head-inner{max-width:820px}
  .page-head h1{margin:20px 0 22px;font-size:clamp(40px,6vw,78px)}
  .page-head .lede{max-width:60ch}

  .team-stats{padding-block:clamp(52px,6vw,78px)}
  .counters-row{display:grid;grid-template-columns:repeat(4,1fr);gap:30px}

  /* leadership grid */
  .leadership .section-head{max-width:640px}
  .leadership .lede{margin-top:18px}
  .team-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:clamp(26px,3vw,44px)}
  .member{text-align:left}
  .avatar{
    display:grid;place-items:center;width:76px;height:76px;border-radius:50%;
    background:var(--cream);border:1px solid var(--gold);
    font-family:var(--display);font-weight:400;font-size:23px;letter-spacing:.04em;
    color:var(--navy);margin-bottom:20px;
  }
  .member-role{font-size:clamp(18px,1.5vw,21px);margin-bottom:10px}
  .member-desc{font-size:14.5px;color:var(--muted);line-height:1.6;max-width:30ch}

  /* culture band */
  .culture{position:relative;color:var(--paper);overflow:hidden;padding-block:clamp(88px,12vw,150px)}
  .culture-bg{position:absolute;inset:0}
  .culture-bg img{width:100%;height:100%;object-fit:cover}
  .culture-bg::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,rgba(9,24,41,.72),rgba(9,24,41,.86))}
  .culture-inner{position:relative;z-index:2;text-align:center;max-width:900px}
  .culture-quote{font-family:var(--display);font-weight:300;font-size:clamp(24px,3.4vw,42px);line-height:1.28;margin:22px auto 28px;max-width:22ch}

  @media(max-width:1000px){
    .counters-row{grid-template-columns:repeat(2,1fr);gap:36px 24px}
    .team-grid{grid-template-columns:repeat(2,1fr);gap:40px 28px}
  }
  @media(max-width:520px){
    .counters-row{grid-template-columns:1fr}
    .team-grid{grid-template-columns:1fr}
  }
</style>
