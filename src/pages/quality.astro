---
import Base from '../layouts/Base.astro';
import Counter from '../components/Counter.astro';

// Quality & Responsibility. Combines the Quality System and Social Responsibility
// sections the client asked for. Certificate names are representative placeholders:
// the client uploads the exact certificates and numbers through the admin CMS.
const quality = [
  { t: "Quality certificates", d: "Internationally recognised food-safety and quality-management certification for food-contact packaging." },
  { t: "Quality assurance", d: "Quality is built into every run, not inspected in at the end: controls at incoming goods, on press and at dispatch." },
  { t: "Laboratory & testing", d: "An in-house lab checks barrier performance, migration and print quality before an order ships." },
];
const responsibility = [
  { k: "Environment", items: ["ISO 14000 environmental management", "Workplace safety systems", "Anti-pollution and solvent recovery"] },
  { k: "Local community", items: ["Valid operating licence", "Saudization certificate", "Compliance (Mowaamah) certificate"] },
  { k: "International", items: ["Global trade compliance", "Certified shipping", "Safe, food-grade product"] },
];
---
<Base
  title="Quality & Responsibility - Printopack"
  description="Printopack's quality system and social responsibility: certified food-safe manufacturing, an in-house testing lab, environmental management and community compliance."
>
  <!-- PAGE HEADER -->
  <section class="page-head">
    <div class="wrap-wide">
      <div class="page-head-inner">
        <span class="eyebrow">Quality &amp; responsibility</span>
        <h1>Held to a standard, in every sense.</h1>
        <p class="lede">
          Quality and responsibility are not separate programmes at Printopack. Certified food-safe
          production, an in-house lab, environmental management and full local compliance run through
          everything we make.
        </p>
      </div>
    </div>
  </section>

  <!-- QUALITY SYSTEM -->
  <section class="qsys">
    <div class="wrap-wide">
      <div class="section-head">
        <span class="eyebrow">Quality system</span>
        <h2>Quality you can certify.</h2>
      </div>
      <div class="qsys-grid">
        {quality.map((q) => (
          <div class="qcard">
            <span class="qcard-mark" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 3l7 3v5c0 4.4-3 8.4-7 10-4-1.6-7-5.6-7-10V6z"/><path d="M9.2 12l2 2 3.6-4"/></svg>
            </span>
            <h3>{q.t}</h3>
            <p>{q.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- COUNTERS -->
  <section class="on-deep q-stats">
    <div class="wrap-wide counters-row">
      <Counter prefix="" value="100" suffix="%" label="Food-grade materials" />
      <Counter prefix="+" value="25" label="Years certified" />
      <Counter prefix="+" value="26" label="Export markets" />
    </div>
  </section>

  <!-- SOCIAL RESPONSIBILITY -->
  <section class="resp">
    <div class="wrap-wide">
      <div class="section-head">
        <span class="eyebrow">Social responsibility</span>
        <h2>Responsible to the environment, the community and the world.</h2>
      </div>
      <div class="resp-grid">
        {responsibility.map((r) => (
          <div class="resp-col">
            <h3>{r.k}</h3>
            <ul>
              {r.items.map((it) => (
                <li>
                  <span class="tick" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l4.5 4.5L19 7"/></svg>
                  </span>
                  {it}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
      <p class="resp-note">Certificate documents and numbers are published and kept current by Printopack through the site's admin.</p>
    </div>
  </section>
</Base>

<style>
  .page-head{padding-block:clamp(56px,8vw,104px) clamp(30px,4vw,52px);background:var(--cream);border-bottom:1px solid var(--line)}
  .page-head-inner{max-width:820px}
  .page-head h1{margin:20px 0 22px;font-size:clamp(40px,6vw,78px)}
  .page-head .lede{max-width:60ch}

  .qsys-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:28px}
  .qcard{background:var(--cream);border:1px solid var(--line);border-radius:var(--radius);padding:clamp(28px,3vw,38px)}
  .qcard-mark{display:inline-flex;color:var(--gold)}
  .qcard-mark svg{width:34px;height:34px}
  .qcard h3{font-size:clamp(20px,2vw,25px);margin:20px 0 12px}
  .qcard p{color:var(--muted)}
  @media(max-width:820px){.qsys-grid{grid-template-columns:1fr}}

  .counters-row{display:grid;grid-template-columns:repeat(3,1fr);gap:32px}
  @media(max-width:640px){.counters-row{grid-template-columns:1fr;gap:40px}}

  .resp-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:clamp(28px,4vw,56px)}
  .resp-col h3{font-size:clamp(20px,2vw,26px);padding-bottom:16px;margin-bottom:20px;border-bottom:1px solid var(--line)}
  .resp-col li{display:flex;align-items:flex-start;gap:12px;color:var(--muted);padding:9px 0}
  .tick{flex:none;display:inline-flex;color:var(--gold);margin-top:3px}
  .tick svg{width:17px;height:17px}
  .resp-note{margin-top:clamp(36px,5vw,56px);color:var(--faint);font-size:14px}
  @media(max-width:760px){.resp-grid{grid-template-columns:1fr;gap:32px}}
</style>
