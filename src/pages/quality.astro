---
import Base from '../layouts/Base.astro';
import Bi from '../components/Bi.astro';

// Quality System hub (Nasser's Page 2): a concise intro that routes into the three
// subsections. Bilingual; Arabic uses Nasser's own section names.
const content = {
  meta: {
    title: "Quality System - Printopack",
    description: "Printopack's quality system: quality certificates, quality assurance, and an in-house laboratory and testing.",
  },
  header: {
    eyebrow: { en: "Quality system", ar: "نظام الجودة" },
    title: { en: "Quality system.", ar: "نظام الجودة." },
    lede: {
      en: "Quality at Printopack spans three areas: our certificates, our quality assurance, and our in-house laboratory and testing.",
      ar: "يشمل نظام الجودة في برنتوباك ثلاثة مجالات: شهاداتنا، وضمان الجودة، والمختبر والفحص لدينا.",
    },
  },
  go: { en: "Explore", ar: "استكشف" },
  subpages: [
    { title: { en: "Quality Certificates", ar: "شهادات الجودة" }, desc: { en: "Internationally recognised, independently audited certification.", ar: "اعتمادٌ معترف به دولياً، تُدقّقه جهاتٌ مستقلة." }, href: "/quality/certificates", img: "/images/factory-solvent.jpg" },
    { title: { en: "Quality Assurance", ar: "ضمان الجودة" }, desc: { en: "Controls built into every run, not inspected in at the end.", ar: "ضوابط مدمجة في كل تشغيلة، لا تُفحص في النهاية فقط." }, href: "/quality/assurance", img: "/images/factory-rotogravure.jpg" },
    { title: { en: "Lab & Testing", ar: "المختبر والفحص" }, desc: { en: "An in-house laboratory checks each order before it ships.", ar: "مختبرٌ داخلي يفحص كل طلبٍ قبل شحنه." }, href: "/quality/lab", img: "/images/factory-punching.jpg" },
  ],
};
const c = content;
---
<Base title={c.meta.title} description={c.meta.description}>
  <!-- PAGE HEADER -->
  <section class="page-head">
    <div class="wrap-wide">
      <div class="page-head-inner">
        <span class="eyebrow"><Bi en={c.header.eyebrow.en} ar={c.header.eyebrow.ar} /></span>
        <h1><Bi en={c.header.title.en} ar={c.header.title.ar} /></h1>
        <p class="lede"><Bi en={c.header.lede.en} ar={c.header.lede.ar} /></p>
      </div>
    </div>
  </section>

  <!-- SUBPAGE CARDS -->
  <section class="sub">
    <div class="wrap-wide">
      <div class="sub-grid">
        {c.subpages.map((s) => (
          <a class="sub-card" href={s.href}>
            <span class="card-img"><img src={s.img} alt={s.title.en} loading="lazy" /></span>
            <span class="sub-body">
              <span class="sub-title"><Bi en={s.title.en} ar={s.title.ar} /></span>
              <span class="sub-desc"><Bi en={s.desc.en} ar={s.desc.ar} /></span>
              <span class="sub-go"><Bi en={c.go.en} ar={c.go.ar} /> &rarr;</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .page-head{padding-block:clamp(56px,8vw,104px) clamp(30px,4vw,52px);background:var(--cream);border-bottom:1px solid var(--line)}
  .page-head-inner{max-width:820px}
  .page-head h1{margin:20px 0 22px;font-size:clamp(40px,6vw,78px)}
  .page-head .lede{max-width:62ch}

  .sub-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:26px}
  .sub-card{display:flex;flex-direction:column;background:var(--paper);border:1px solid var(--line);border-radius:var(--radius);overflow:hidden}
  .sub-card:hover{border-color:var(--navy);box-shadow:0 20px 40px rgba(14,35,64,.08)}
  .sub-card .card-img{aspect-ratio:16/10}
  .sub-card:hover .card-img img{opacity:.92}
  .sub-body{display:flex;flex-direction:column;padding:24px 26px 26px}
  .sub-title{font-family:var(--display);font-size:clamp(20px,2vw,25px);font-weight:var(--w-light);color:var(--ink)}
  .sub-desc{color:var(--muted);font-size:15px;margin:10px 0 18px}
  .sub-go{font-family:var(--display);font-size:12px;font-weight:500;letter-spacing:.14em;text-transform:uppercase;color:var(--gold);margin-top:auto}
  @media(max-width:820px){.sub-grid{grid-template-columns:1fr}}
</style>
