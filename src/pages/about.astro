---
import Base from '../layouts/Base.astro';
import Counter from '../components/Counter.astro';

// About Us. Mission and vision are the client's real published statements. Company
// history, ownership and the full values narrative are client-gated: the copy below
// is a faithful scaffold the client refines in the admin CMS after signing.
const values = [
  { t: "Quality without compromise", d: "Every reel is held to the Printopack standard, from incoming substrate to final dispatch." },
  { t: "Responsible by design", d: "Food-safe materials, solvent recovery and efficient production run through everything we make." },
  { t: "Partnership, not supply", d: "We advise on structure and print from the first brief, so the packaging fits the product and the line." },
  { t: "Built to deliver", d: "Planned materials and export logistics mean orders land on time, run after run." },
];
---
<Base
  title="About Us - Printopack"
  description="Printopack, Saudi Modern Packaging Factory, has produced responsible flexible packaging in Jeddah since 1997 for food, beverage and consumer brands across 26+ countries."
>
  <!-- PAGE HEADER -->
  <section class="page-head">
    <div class="wrap-wide">
      <div class="page-head-inner">
        <span class="eyebrow">About us</span>
        <h1>Packaging with a legacy since 1997.</h1>
        <p class="lede">
          Printopack, the Saudi Modern Packaging Factory, develops and produces responsible flexible
          packaging from Jeddah for food, beverage, pharmaceutical and personal-care brands across the
          region and beyond.
        </p>
      </div>
    </div>
  </section>

  <!-- COUNTERS -->
  <section class="on-deep about-stats">
    <div class="wrap-wide counters-row">
      <Counter prefix="+" value="25" label="Years in the market" />
      <Counter prefix="+" value="26" label="Countries served" />
      <Counter prefix="~" value="400" label="Team members" />
      <Counter prefix="" value="6" label="Regional offices" />
    </div>
  </section>

  <!-- STORY -->
  <section class="story">
    <div class="wrap-wide story-grid">
      <div class="story-media">
        <div class="card-img"><img src="/images/factory.jpg" alt="Printopack production in Jeddah" /></div>
      </div>
      <div class="story-body">
        <span class="eyebrow">Our story</span>
        <h2>From a Jeddah factory to brands across 26 countries.</h2>
        <p class="lede">
          Founded in 1997, Printopack has grown from a single flexible-packaging line into a full
          converter: rotogravure printing, in-house cylinder engraving, bag making, finishing and
          solvent recovery, all under one roof.
        </p>
        <p class="lede">
          The company is family-owned and Saudi-operated, and today serves leading food and beverage
          names through a network of six regional offices. This section will carry the full history and
          the owners' story once the client provides them.
        </p>
      </div>
    </div>
  </section>

  <!-- MISSION / VISION -->
  <section class="on-navy mv">
    <div class="wrap-wide mv-grid">
      <div class="mv-item">
        <span class="eyebrow">Our vision</span>
        <h3>Empowering brands through creative packaging excellence.</h3>
      </div>
      <div class="mv-item">
        <span class="eyebrow">Our mission</span>
        <h3>To be the driving force behind brands' packaging evolution, with a legacy of expertise in flexible packaging solutions since 1997.</h3>
      </div>
    </div>
  </section>

  <!-- VALUES -->
  <section class="values">
    <div class="wrap-wide">
      <div class="section-head">
        <span class="eyebrow">What we stand for</span>
        <h2>Our values</h2>
      </div>
      <div class="values-grid">
        {values.map((v) => (
          <div class="value">
            <span class="value-rule"></span>
            <h3>{v.t}</h3>
            <p>{v.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="on-deep about-cta">
    <div class="wrap" style="text-align:center">
      <span class="eyebrow plain" style="color:var(--gold-bright)">Work with us</span>
      <h2 style="margin:14px 0 26px">Let's build packaging that performs.</h2>
      <a href="/contact" class="btn btn-gold">Request a quote</a>
    </div>
  </section>
</Base>

<style>
  .page-head{padding-block:clamp(56px,8vw,104px) clamp(30px,4vw,52px);background:var(--cream);border-bottom:1px solid var(--line)}
  .page-head-inner{max-width:820px}
  .page-head h1{margin:20px 0 22px;font-size:clamp(40px,6vw,78px)}
  .page-head .lede{max-width:60ch}

  .counters-row{display:grid;grid-template-columns:repeat(4,1fr);gap:32px}
  @media(max-width:760px){.counters-row{grid-template-columns:1fr 1fr;gap:40px 24px}}

  .story-grid{display:grid;grid-template-columns:1fr 1.05fr;gap:clamp(36px,6vw,84px);align-items:center}
  .story-media .card-img{aspect-ratio:4/3;border-radius:var(--radius)}
  .story-body .eyebrow{margin-bottom:16px}
  .story-body h2{margin-bottom:22px}
  .story-body .lede + .lede{margin-top:18px}
  @media(max-width:860px){.story-grid{grid-template-columns:1fr;gap:36px}}

  .mv-grid{display:grid;grid-template-columns:1fr 1fr;gap:clamp(36px,6vw,72px)}
  .mv-item .eyebrow{margin-bottom:18px}
  .mv-item h3{font-weight:var(--w-light);line-height:1.18}
  @media(max-width:760px){.mv-grid{grid-template-columns:1fr;gap:40px}}

  .values-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:40px 56px}
  .value-rule{display:block;width:34px;height:2px;background:var(--gold);margin-bottom:20px}
  .value h3{font-size:clamp(20px,2vw,26px);margin-bottom:12px}
  .value p{color:var(--muted)}
  @media(max-width:760px){.values-grid{grid-template-columns:1fr;gap:32px}}
</style>
