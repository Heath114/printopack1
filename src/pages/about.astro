---
import Base from '../layouts/Base.astro';
import Bi from '../components/Bi.astro';

// ── EDITABLE CONTENT (bilingual) ─────────────────────────────────────────────
// About Us is a concise hub routing into the four subpages. Arabic uses Nasser's own
// section names (الشركة، المسؤولية الاجتماعية، أقسام المصنع، فريق العمل).
const content = {
  meta: {
    title: "About Us - Printopack",
    description: "Get to know Printopack: the company, our social responsibility, our factory departments and our team.",
  },
  header: {
    eyebrow: { en: "About us", ar: "من نحن" },
    title: { en: "About Printopack.", ar: "عن برنتوباك." },
    lede: {
      en: "Get to know the company behind the packaging, our responsibility, our plant and our people. Choose a section to explore.",
      ar: "تعرّف على الشركة التي تقف وراء التغليف، ومسؤوليتنا، ومصنعنا، وفريقنا. اختر قسماً لاستكشافه.",
    },
  },
  go: { en: "Explore", ar: "استكشف" },
  subpages: [
    { title: { en: "The Company", ar: "الشركة" }, desc: { en: "History, ownership, mission, vision and values.", ar: "التاريخ والملكية والرسالة والرؤية والقيم." }, href: "/company", img: "/images/factory.jpg" },
    { title: { en: "Social Responsibility", ar: "المسؤولية الاجتماعية" }, desc: { en: "Environment, local community and international commitments.", ar: "البيئة والمجتمع المحلي والالتزامات الدولية." }, href: "/responsibility", img: "/images/dept-5.jpg" },
    { title: { en: "Factory Departments", ar: "أقسام المصنع" }, desc: { en: "Inside the plant: printing, engraving, converting and more.", ar: "داخل المصنع: الطباعة والحفر والتحويل والمزيد." }, href: "/factory", img: "/images/dept-1.jpg" },
    { title: { en: "Our Team", ar: "فريق العمل" }, desc: { en: "The people who run the press floor and the offices.", ar: "الأشخاص الذين يديرون أرضية المصنع والمكاتب." }, href: "/team", img: "/images/dept-4.jpg" },
  ],
};
const c = content;
---
<Base title={c.meta.title} description={c.meta.description}>
  <!-- PAGE HEADER -->
  <section class="page-head">
    <div class="wrap-wide">
      <div class="page-head-inner">
        <span class="eyebrow"><Bi en={c.header.eyebrow.en} ar={c.header.eyebrow.ar} /></span>
        <h1><Bi en={c.header.title.en} ar={c.header.title.ar} /></h1>
        <p class="lede"><Bi en={c.header.lede.en} ar={c.header.lede.ar} /></p>
      </div>
    </div>
  </section>

  <!-- SUBPAGE CARDS -->
  <section class="sub">
    <div class="wrap-wide">
      <div class="sub-grid">
        {c.subpages.map((s) => (
          <a class="sub-card" href={s.href}>
            <span class="card-img"><img src={s.img} alt={s.title.en} loading="lazy" /></span>
            <span class="sub-body">
              <span class="sub-title"><Bi en={s.title.en} ar={s.title.ar} /></span>
              <span class="sub-desc"><Bi en={s.desc.en} ar={s.desc.ar} /></span>
              <span class="sub-go"><Bi en={c.go.en} ar={c.go.ar} /> &rarr;</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .page-head{padding-block:clamp(56px,8vw,104px) clamp(30px,4vw,52px);background:var(--cream);border-bottom:1px solid var(--line)}
  .page-head-inner{max-width:820px}
  .page-head h1{margin:20px 0 22px;font-size:clamp(40px,6vw,78px)}
  .page-head .lede{max-width:60ch}

  .sub-grid{display:grid;grid-template-columns:1fr 1fr;gap:28px}
  .sub-card{display:flex;flex-direction:column;background:var(--paper);border:1px solid var(--line);border-radius:var(--radius);overflow:hidden}
  .sub-card:hover{border-color:var(--navy);box-shadow:0 20px 40px rgba(14,35,64,.08)}
  .sub-card .card-img{aspect-ratio:16/9}
  .sub-card:hover .card-img img{opacity:.92}
  .sub-body{display:flex;flex-direction:column;padding:24px 26px 26px}
  .sub-title{font-family:var(--display);font-size:clamp(21px,2vw,26px);font-weight:var(--w-light);color:var(--ink)}
  .sub-desc{color:var(--muted);font-size:15px;margin:10px 0 18px}
  .sub-go{font-family:var(--display);font-size:12px;font-weight:500;letter-spacing:.14em;text-transform:uppercase;color:var(--gold);margin-top:auto}
  @media(max-width:640px){.sub-grid{grid-template-columns:1fr}}
</style>
