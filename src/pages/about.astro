---
import Base from '../layouts/Base.astro';

// ── EDITABLE CONTENT ────────────────────────────────────────────────────────
// About Us is a concise hub (Nasser's Page 1): a short intro that routes into the
// four subpages. All copy/images are fields here (the admin's editable surface).
const content = {
  meta: {
    title: "About Us - Printopack",
    description: "Get to know Printopack: the company, our social responsibility, our factory departments and our team.",
  },
  header: {
    eyebrow: "About us",
    title: "About Printopack.",
    lede: "Get to know the company behind the packaging, our responsibility, our plant and our people. Choose a section to explore.",
  },
  subpages: [
    { title: "The Company", desc: "History, ownership, mission, vision and values.", href: "/company", img: "/images/factory.jpg" },
    { title: "Social Responsibility", desc: "Environment, local community and international commitments.", href: "/responsibility", img: "/images/dept-5.jpg" },
    { title: "Factory Departments", desc: "Inside the plant: printing, engraving, converting and more.", href: "/factory", img: "/images/dept-1.jpg" },
    { title: "Our Team", desc: "The people who run the press floor and the offices.", href: "/team", img: "/images/dept-4.jpg" },
  ],
};
const c = content;
---
<Base title={c.meta.title} description={c.meta.description}>
  <!-- PAGE HEADER -->
  <section class="page-head">
    <div class="wrap-wide">
      <div class="page-head-inner">
        <span class="eyebrow">{c.header.eyebrow}</span>
        <h1>{c.header.title}</h1>
        <p class="lede">{c.header.lede}</p>
      </div>
    </div>
  </section>

  <!-- SUBPAGE CARDS -->
  <section class="sub">
    <div class="wrap-wide">
      <div class="sub-grid">
        {c.subpages.map((s) => (
          <a class="sub-card" href={s.href}>
            <span class="card-img"><img src={s.img} alt={s.title} loading="lazy" /></span>
            <span class="sub-body">
              <span class="sub-title">{s.title}</span>
              <span class="sub-desc">{s.desc}</span>
              <span class="sub-go">Explore &rarr;</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .page-head{padding-block:clamp(56px,8vw,104px) clamp(30px,4vw,52px);background:var(--cream);border-bottom:1px solid var(--line)}
  .page-head-inner{max-width:820px}
  .page-head h1{margin:20px 0 22px;font-size:clamp(40px,6vw,78px)}
  .page-head .lede{max-width:60ch}

  .sub-grid{display:grid;grid-template-columns:1fr 1fr;gap:28px}
  .sub-card{display:flex;flex-direction:column;background:var(--paper);border:1px solid var(--line);border-radius:var(--radius);overflow:hidden}
  .sub-card:hover{border-color:var(--navy);box-shadow:0 20px 40px rgba(14,35,64,.08)}
  .sub-card .card-img{aspect-ratio:16/9}
  .sub-card:hover .card-img img{opacity:.92}
  .sub-body{display:flex;flex-direction:column;padding:24px 26px 26px}
  .sub-title{font-family:var(--display);font-size:clamp(21px,2vw,26px);font-weight:var(--w-light);color:var(--ink)}
  .sub-desc{color:var(--muted);font-size:15px;margin:10px 0 18px}
  .sub-go{font-family:var(--display);font-size:12px;font-weight:500;letter-spacing:.14em;text-transform:uppercase;color:var(--gold);margin-top:auto}
  @media(max-width:640px){.sub-grid{grid-template-columns:1fr}}
</style>
