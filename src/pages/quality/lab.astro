---
import Base from '../../layouts/Base.astro';
import Bi from '../../components/Bi.astro';

// Lab & Testing (Page 2, subsection 3). The live site has no lab content, so the test
// types below are generic and factual, grounded in Printopack's real work (food and
// cosmetic flexible packaging), editable by the client.
const content = {
  meta: { title: "Lab & Testing - Printopack", description: "Printopack's in-house laboratory checks barrier performance, migration and print quality before an order ships." },
  header: {
    eyebrow: { en: "Quality system", ar: "نظام الجودة" },
    title: { en: "Lab & testing.", ar: "المختبر والفحص." },
    lede: {
      en: "An in-house laboratory checks each order against specification before it ships, from barrier performance to print quality.",
      ar: "مختبرٌ داخلي يفحص كل طلبٍ مقابل المواصفات قبل شحنه، من أداء الحاجز إلى جودة الطباعة.",
    },
  },
  tests: {
    eyebrow: { en: "What our lab checks", ar: "ما يفحصه مختبرنا" },
    title: { en: "Tested before it ships.", ar: "يُفحص قبل الشحن." },
    items: [
      { icon: '<path d="M9 3h6M10 3v6l-5 9a2 2 0 0 0 1.8 3h10.4a2 2 0 0 0 1.8-3l-5-9V3"/>', title: { en: "Barrier performance", ar: "أداء الحاجز" }, desc: { en: "Oxygen and moisture barrier testing.", ar: "فحص الحاجز ضد الأكسجين والرطوبة." } },
      { icon: '<path d="M12 3l7 3v5c0 4.4-3 8.4-7 10-4-1.6-7-5.6-7-10V6z"/><path d="M9.2 12l2 2 3.6-4"/>', title: { en: "Food-contact & migration", ar: "الملامسة للأغذية والانتقال" }, desc: { en: "Food-contact safety and migration checks.", ar: "فحوصات سلامة الملامسة للأغذية والانتقال." } },
      { icon: '<circle cx="13" cy="11" r="8"/><path d="M13 7v4l3 2"/>', title: { en: "Print quality", ar: "جودة الطباعة" }, desc: { en: "Colour accuracy and registration.", ar: "دقة اللون والتسجيل." } },
      { icon: '<path d="M4 12h16M8 8l-4 4 4 4M16 8l4 4-4 4"/>', title: { en: "Bond & seal strength", ar: "قوة الالتصاق والغلق" }, desc: { en: "Lamination bond and seal strength.", ar: "قوة التصاق التصفيح والغلق." } },
    ],
  },
};
const c = content;
---
<Base title={c.meta.title} description={c.meta.description}>
  <section class="page-head">
    <div class="wrap-wide">
      <div class="page-head-inner">
        <span class="eyebrow"><Bi en={c.header.eyebrow.en} ar={c.header.eyebrow.ar} /></span>
        <h1><Bi en={c.header.title.en} ar={c.header.title.ar} /></h1>
        <p class="lede"><Bi en={c.header.lede.en} ar={c.header.lede.ar} /></p>
      </div>
    </div>
  </section>

  <section class="steps">
    <div class="wrap-wide">
      <div class="section-head">
        <span class="eyebrow"><Bi en={c.tests.eyebrow.en} ar={c.tests.eyebrow.ar} /></span>
        <h2><Bi en={c.tests.title.en} ar={c.tests.title.ar} /></h2>
      </div>
      <div class="step-grid">
        {c.tests.items.map((s) => (
          <div class="step">
            <span class="step-icon" aria-hidden="true"><svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.5" set:html={s.icon} /></span>
            <h3><Bi en={s.title.en} ar={s.title.ar} /></h3>
            <p><Bi en={s.desc.en} ar={s.desc.ar} /></p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="qnav on-deep">
    <div class="wrap-wide qnav-inner">
      <a class="qnav-link" href="/quality"><Bi en="All of Quality System" ar="كل نظام الجودة" /></a>
      <div class="qnav-sub">
        <a href="/quality/certificates"><Bi en="Quality Certificates" ar="شهادات الجودة" /> &rarr;</a>
        <a href="/quality/assurance"><Bi en="Quality Assurance" ar="ضمان الجودة" /> &rarr;</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .page-head{padding-block:clamp(56px,8vw,104px) clamp(30px,4vw,52px);background:var(--cream);border-bottom:1px solid var(--line)}
  .page-head-inner{max-width:820px}
  .page-head h1{margin:20px 0 22px;font-size:clamp(40px,6vw,78px)}
  .page-head .lede{max-width:62ch}

  .step-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:26px}
  .step{background:var(--cream);border:1px solid var(--line);border-radius:var(--radius);padding:clamp(26px,2.6vw,34px)}
  .step-icon{display:inline-flex;align-items:center;justify-content:center;width:52px;height:52px;border-radius:50%;background:var(--gold-soft);color:var(--gold);margin-bottom:18px}
  .step-icon svg{width:25px;height:25px}
  .step h3{font-size:clamp(18px,1.7vw,21px);margin-bottom:10px;line-height:1.2}
  .step p{color:var(--muted);font-size:14.5px}
  @media(max-width:900px){.step-grid{grid-template-columns:1fr 1fr;gap:20px}}
  @media(max-width:520px){.step-grid{grid-template-columns:1fr}}

  .qnav{padding-block:clamp(40px,5vw,60px)}
  .qnav-inner{display:flex;justify-content:space-between;align-items:center;gap:24px;flex-wrap:wrap}
  .qnav-link{font-family:var(--display);font-size:clamp(18px,2vw,24px);font-weight:var(--w-light);color:var(--paper)}
  .qnav-link:hover{color:var(--gold-bright)}
  .qnav-sub{display:flex;gap:26px;flex-wrap:wrap}
  .qnav-sub a{font-family:var(--display);font-size:13px;letter-spacing:.06em;text-transform:uppercase;color:var(--gold-bright)}
</style>
