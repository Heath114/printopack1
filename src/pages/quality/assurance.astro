---
import Base from '../../layouts/Base.astro';
import Bi from '../../components/Bi.astro';

// Quality Assurance (Page 2, subsection 2). The live site has no QA content, so the
// steps below are generic, factual quality controls grounded in Printopack's real
// operations (printing, lamination, coating, slitting), editable by the client.
const content = {
  meta: { title: "Quality Assurance - Printopack", description: "Quality is built into every Printopack run, not inspected in at the end: controls at incoming goods, on press, and at dispatch." },
  header: {
    eyebrow: { en: "Quality system", ar: "نظام الجودة" },
    title: { en: "Quality assurance.", ar: "ضمان الجودة." },
    lede: {
      en: "Quality is built into every run, not inspected in at the end. Controls run from incoming goods, through the press, to dispatch.",
      ar: "الجودة مدمجة في كل تشغيلة، لا تُفحص في النهاية فقط. تمتد الضوابط من استلام المواد، مروراً بالطباعة، حتى التسليم.",
    },
  },
  steps: {
    eyebrow: { en: "How we assure quality", ar: "كيف نضمن الجودة" },
    title: { en: "Controls at every stage.", ar: "ضوابط في كل مرحلة." },
    items: [
      { icon: '<path d="M20 6L9 17l-5-5"/>', title: { en: "Incoming inspection", ar: "فحص الوارد" }, desc: { en: "Raw materials and substrates are checked on arrival.", ar: "تُفحص المواد الخام والركائز عند وصولها." } },
      { icon: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>', title: { en: "In-process control", ar: "الضبط أثناء التشغيل" }, desc: { en: "Colour, registration and structure are controlled on press.", ar: "يُضبط اللون والتسجيل والبنية على الطباعة." } },
      { icon: '<path d="M12 3l7 3v5c0 4.4-3 8.4-7 10-4-1.6-7-5.6-7-10V6z"/><path d="M9.2 12l2 2 3.6-4"/>', title: { en: "Final inspection", ar: "الفحص النهائي" }, desc: { en: "Every order is checked before dispatch.", ar: "يُفحص كل طلبٍ قبل التسليم." } },
      { icon: '<path d="M4 5h16M4 12h16M4 19h10"/>', title: { en: "Traceability", ar: "التتبّع" }, desc: { en: "Each run is documented for full traceability.", ar: "تُوثّق كل تشغيلة لتتبّعٍ كامل." } },
    ],
  },
};
const c = content;
---
<Base title={c.meta.title} description={c.meta.description}>
  <section class="page-head">
    <div class="wrap-wide">
      <div class="page-head-inner">
        <span class="eyebrow"><Bi en={c.header.eyebrow.en} ar={c.header.eyebrow.ar} /></span>
        <h1><Bi en={c.header.title.en} ar={c.header.title.ar} /></h1>
        <p class="lede"><Bi en={c.header.lede.en} ar={c.header.lede.ar} /></p>
      </div>
    </div>
  </section>

  <section class="steps">
    <div class="wrap-wide">
      <div class="section-head">
        <span class="eyebrow"><Bi en={c.steps.eyebrow.en} ar={c.steps.eyebrow.ar} /></span>
        <h2><Bi en={c.steps.title.en} ar={c.steps.title.ar} /></h2>
      </div>
      <div class="step-grid">
        {c.steps.items.map((s) => (
          <div class="step">
            <span class="step-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" set:html={s.icon} /></span>
            <h3><Bi en={s.title.en} ar={s.title.ar} /></h3>
            <p><Bi en={s.desc.en} ar={s.desc.ar} /></p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="qnav on-deep">
    <div class="wrap-wide qnav-inner">
      <a class="qnav-link" href="/quality"><Bi en="All of Quality System" ar="كل نظام الجودة" /></a>
      <div class="qnav-sub">
        <a href="/quality/certificates"><Bi en="Quality Certificates" ar="شهادات الجودة" /> &rarr;</a>
        <a href="/quality/lab"><Bi en="Lab & Testing" ar="المختبر والفحص" /> &rarr;</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .page-head{padding-block:clamp(56px,8vw,104px) clamp(30px,4vw,52px);background:var(--cream);border-bottom:1px solid var(--line)}
  .page-head-inner{max-width:820px}
  .page-head h1{margin:20px 0 22px;font-size:clamp(40px,6vw,78px)}
  .page-head .lede{max-width:62ch}

  .step-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:26px}
  .step{background:var(--cream);border:1px solid var(--line);border-radius:var(--radius);padding:clamp(26px,2.6vw,34px)}
  .step-icon{display:inline-flex;align-items:center;justify-content:center;width:52px;height:52px;border-radius:50%;background:var(--gold-soft);color:var(--gold);margin-bottom:18px}
  .step-icon svg{width:25px;height:25px}
  .step h3{font-size:clamp(18px,1.7vw,21px);margin-bottom:10px;line-height:1.2}
  .step p{color:var(--muted);font-size:14.5px}
  @media(max-width:900px){.step-grid{grid-template-columns:1fr 1fr;gap:20px}}
  @media(max-width:520px){.step-grid{grid-template-columns:1fr}}

  .qnav{padding-block:clamp(40px,5vw,60px)}
  .qnav-inner{display:flex;justify-content:space-between;align-items:center;gap:24px;flex-wrap:wrap}
  .qnav-link{font-family:var(--display);font-size:clamp(18px,2vw,24px);font-weight:var(--w-light);color:var(--paper)}
  .qnav-link:hover{color:var(--gold-bright)}
  .qnav-sub{display:flex;gap:26px;flex-wrap:wrap}
  .qnav-sub a{font-family:var(--display);font-size:13px;letter-spacing:.06em;text-transform:uppercase;color:var(--gold-bright)}
</style>
