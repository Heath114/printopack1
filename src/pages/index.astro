---
import Base from '../layouts/Base.astro';
import Counter from '../components/Counter.astro';

const capabilities = [
  { img: "/images/dept-1.jpg", label: "Rotogravure Printing", href: "/factory" },
  { img: "/images/dept-4.jpg", label: "Cylinder Engraving", href: "/factory" },
  { img: "/images/dept-2.jpg", label: "Bag Making", href: "/factory" },
  { img: "/images/dept-3.jpg", label: "Punching & Finishing", href: "/factory" },
];
const news = [
  { date: "10 Feb 2023", cat: "General", title: "The Future of Packaging in Saudi Arabia", img: "/images/lineup.jpg" },
  { date: "06 May 2023", cat: "General", title: "The Benefits of Flexible Packaging: Durability, Versatility & Eco-Friendliness", img: "/images/factory.jpg" },
  { date: "20 Jun 2022", cat: "General", title: "PVC vs PET-G Shrink Films", img: "/images/dept-5.jpg" },
];
const products = [
  { name: "Chips & Snacks", img: "/images/cat-1.png" },
  { name: "Chocolates", img: "/images/cat-2.png" },
  { name: "Bakery Products", img: "/images/cat-3.png" },
  { name: "Candy", img: "/images/cat-4.png" },
  { name: "Breads", img: "/images/cat-5.png" },
  { name: "Bottle Labels", img: "/images/cat-6.png" },
  { name: "Lids", img: "/images/cat-7.png" },
  { name: "Ice Cream", img: "/images/cat-8.png" },
];
const clients = Array.from({ length: 20 }, (_, i) => `/images/clients/client-${i + 1}.png`);

// "Why Printopack": four icon value-props, janasmart's card device rendered with gold.
const why = [
  { t: "Everything under one roof", d: "Engraving, printing, converting and finishing in one Jeddah plant: faster proofs, tighter control.",
    icon: '<path d="M12 3l9 5-9 5-9-5z"/><path d="M3 12l9 5 9-5"/>' },
  { t: "Food-safe certified", d: "Certified food-contact materials and an in-house lab checking every run before it ships.",
    icon: '<path d="M12 3l7 3v5c0 4.4-3 8.4-7 10-4-1.6-7-5.6-7-10V6z"/><path d="M9.2 12l2 2 3.6-4"/>' },
  { t: "26 countries served", d: "Export logistics and regional offices that get your order to the line on time.",
    icon: '<circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c3 3.5 3 14.5 0 18M12 3c-3 3.5-3 14.5 0 18"/>' },
  { t: "25 years of expertise", d: "A flexible-packaging legacy since 1997, trusted by leading regional brands.",
    icon: '<circle cx="12" cy="9" r="6"/><path d="M8.5 14l-1.5 7 5-3 5 3-1.5-7"/>' },
];

// Vision/Mission/Values for the tabbed band.
const mvValues = ["Quality without compromise", "Responsible by design", "Partnership, not supply", "Built to deliver on time"];
---
<Base>
  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg"><img src="/images/hero.jpg" alt="Printopack production" fetchpriority="high" /></div>
    <div class="wrap-wide hero-inner">
      <span class="eyebrow" style="color:var(--gold-bright)">Since 1997 · Jeddah, Saudi Arabia</span>
      <h1 class="display-xl">Where technology<br>meets <span class="serif-note" style="color:var(--gold-bright)">vision.</span></h1>
      <p class="hero-lede">A global leader in developing and producing responsible packaging for food, beverage, pharmaceutical, medical, home and personal-care brands.</p>
      <div class="hero-cta">
        <a href="/products" class="btn btn-gold">Explore our products</a>
        <a href="/contact" class="btn btn-outline-light">Request a quote</a>
      </div>
    </div>
  </section>

  <!-- COUNTERS -->
  <section class="counters on-deep">
    <div class="wrap-wide counters-grid">
      <Counter value="6" label="Regional offices" />
      <Counter prefix="+" value="26" label="Countries served" />
      <Counter prefix="+" value="25" label="Years of printing" />
      <Counter prefix="~" value="400" label="Team members" />
    </div>
  </section>

  <!-- WHY PRINTOPACK (icon value cards) -->
  <section class="why">
    <div class="wrap-wide">
      <div class="section-head center">
        <span class="eyebrow plain" style="color:var(--gold)">Why Printopack</span>
        <h2 style="margin-top:14px">Built to perform, end to end.</h2>
      </div>
      <div class="why-grid">
        {why.map((w) => (
          <div class="why-card">
            <span class="why-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" set:html={w.icon} />
            </span>
            <h3>{w.t}</h3>
            <p>{w.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- INTRO -->
  <section>
    <div class="wrap intro-grid">
      <div data-reveal>
        <span class="eyebrow">Who we are</span>
        <h2 style="margin-top:16px">Pioneering flexible packaging, refined until it performs.</h2>
      </div>
      <div data-reveal>
        <p class="lede">From our Jeddah facility, every structure, laminate and print run is developed until it meets the Printopack standard, then delivered on time, to leading brands across the region and beyond.</p>
        <a href="/about" class="link-line" style="margin-top:26px">Our story</a>
      </div>
    </div>
  </section>

  <!-- PRODUCTS PREVIEW -->
  <section style="padding-top:0">
    <div class="wrap-wide">
      <div class="section-head split-head">
        <div>
          <span class="eyebrow" data-reveal>What we make</span>
          <h2 data-reveal style="margin-top:16px">Packaging for every category</h2>
        </div>
        <a href="/products" class="link-line" data-reveal>All products</a>
      </div>
      <div class="prod-grid">
        {products.map((p) => (
          <a href="/products" class="card prod-card" data-reveal>
            <span class="card-img prod-img"><img src={p.img} alt={p.name} loading="lazy" decoding="async" /></span>
            <span class="prod-label">{p.name}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CAPABILITIES / FACTORY -->
  <section style="padding-top:0">
    <div class="wrap-wide">
      <div class="section-head">
        <span class="eyebrow" data-reveal>What we do</span>
        <h2 data-reveal>Capabilities, end to end.</h2>
      </div>
      <div class="cap-grid">
        {capabilities.map((c) => (
          <a href={c.href} class="card cap-card" data-reveal>
            <span class="card-img cap-img"><img src={c.img} alt={c.label} loading="lazy" decoding="async" /></span>
            <span class="cap-label">{c.label}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- VISION / MISSION / VALUES (tabbed band, image + tabs + checklist) -->
  <section class="on-navy vmv">
    <div class="wrap-wide vmv-grid">
      <div class="vmv-media"><img src="/images/lineup.jpg" alt="Printopack finished packaging" loading="lazy" decoding="async" /></div>
      <div class="vmv-body">
        <span class="eyebrow">What drives us</span>
        <h2 style="margin:14px 0 26px">Vision, mission and values.</h2>
        <div class="vmv-tabs" role="tablist" aria-label="Vision, mission and values">
          <button class="vmv-tab is-active" role="tab" aria-selected="true" id="h-vision" aria-controls="p-vision" data-tab="vision">Vision</button>
          <button class="vmv-tab" role="tab" aria-selected="false" id="h-mission" aria-controls="p-mission" data-tab="mission">Mission</button>
          <button class="vmv-tab" role="tab" aria-selected="false" id="h-values" aria-controls="p-values" data-tab="values">Values</button>
        </div>
        <div class="vmv-panels">
          <div class="vmv-panel is-active" role="tabpanel" id="p-vision" aria-labelledby="h-vision" data-panel="vision">
            <p class="vmv-statement">Empowering brands through creative packaging excellence.</p>
          </div>
          <div class="vmv-panel" role="tabpanel" id="p-mission" aria-labelledby="h-mission" data-panel="mission" hidden>
            <p class="vmv-statement">To be the driving force behind brands' packaging evolution, with a legacy of expertise in flexible packaging since 1997.</p>
          </div>
          <div class="vmv-panel" role="tabpanel" id="p-values" aria-labelledby="h-values" data-panel="values" hidden>
            <ul class="vmv-list">
              {mvValues.map((v) => (
                <li>
                  <span class="vmv-tick" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l4.5 4.5L19 7"/></svg></span>
                  {v}
                </li>
              ))}
            </ul>
          </div>
        </div>
        <a href="/about" class="link-line vmv-link">Read our philosophy</a>
      </div>
    </div>
  </section>

  <!-- QUALITY & RESPONSIBILITY TEASER -->
  <section style="background:var(--cream)">
    <div class="wrap split">
      <div class="split-media" data-reveal><img src="/images/dept-5.jpg" alt="Quality and responsibility at Printopack" loading="lazy" decoding="async" /></div>
      <div data-reveal>
        <span class="eyebrow">Quality &amp; responsibility</span>
        <h2 style="margin:16px 0 20px">Certified at every step.</h2>
        <p class="lede">From ISO-certified food-safety systems to responsible, low-impact production, quality is built into every run, not inspected in at the end. It is how we have earned the trust of brands across 26 countries.</p>
        <a href="/quality" class="link-line" style="margin-top:26px">Our standards</a>
      </div>
    </div>
  </section>

  <!-- SUCCESS PARTNERS -->
  <section>
    <div class="wrap-wide">
      <div class="section-head center">
        <span class="eyebrow plain" data-reveal style="color:var(--gold)">Success partners</span>
        <h2 data-reveal style="margin-top:14px">Trusted by leading brands</h2>
      </div>
      <div class="logo-grid">
        {clients.map((c) => (
          <span class="logo" data-reveal><img src={c} alt="Client brand" loading="lazy" /></span>
        ))}
      </div>
      <div class="partner-counters">
        <Counter prefix="+" value="26" label="Countries served" />
        <Counter prefix="+" value="20" label="Brand partners" />
      </div>
    </div>
  </section>

  <!-- NEWS -->
  <section>
    <div class="wrap-wide">
      <div class="section-head" style="display:flex;justify-content:space-between;align-items:flex-end;max-width:none">
        <div>
          <span class="eyebrow" data-reveal>News &amp; events</span>
          <h2 data-reveal style="margin-top:16px">The latest from Printopack</h2>
        </div>
        <a href="/news" class="link-line" data-reveal>All news</a>
      </div>
      <div class="news-grid">
        {news.map((n) => (
          <a href="/news" class="card news-card" data-reveal>
            <span class="card-img news-img"><img src={n.img} alt="" loading="lazy" decoding="async" /></span>
            <span class="news-meta">{n.cat} · {n.date}</span>
            <h3 class="news-title">{n.title}</h3>
            <span class="link-line news-read">Read more</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta on-deep">
    <div class="wrap" style="text-align:center">
      <span class="eyebrow plain" data-reveal style="color:var(--gold-bright)">Let's talk packaging</span>
      <h2 data-reveal style="margin:16px 0 26px">Set the standard in your industry.</h2>
      <a href="/contact" class="btn btn-gold" data-reveal>Request a quote</a>
    </div>
  </section>
</Base>

<style>
  /* hero */
  .hero{position:relative;min-height:92vh;display:flex;align-items:flex-end;color:var(--paper);overflow:hidden}
  .hero-bg{position:absolute;inset:0}
  .hero-bg img{width:100%;height:100%;object-fit:cover}
  .hero-bg::after{content:"";position:absolute;inset:0;background:linear-gradient(105deg,rgba(9,24,41,.78) 0%,rgba(9,24,41,.42) 42%,rgba(9,24,41,.12) 72%),linear-gradient(0deg,rgba(9,24,41,.88) 0%,rgba(9,24,41,.15) 46%,transparent 70%)}
  .hero-inner{position:relative;z-index:2;padding-bottom:clamp(48px,7vw,88px)}
  .hero h1{margin:20px 0 24px;max-width:16ch}
  .hero-lede{font-size:clamp(16px,1.5vw,20px);color:rgba(250,246,238,.82);max-width:52ch;font-weight:300;line-height:1.6}
  .hero-cta{display:flex;gap:14px;margin-top:34px;flex-wrap:wrap}

  /* counters */
  .counters{padding-block:clamp(48px,6vw,72px)}
  .counters-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:30px}

  /* intro */
  .intro-grid{display:grid;grid-template-columns:1fr 1fr;gap:clamp(30px,6vw,80px);align-items:start}

  /* capabilities */
  .cap-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:26px}
  .cap-img{aspect-ratio:4/5}
  .cap-label{display:block;margin-top:16px;font-family:var(--display);font-size:15px;font-weight:400;letter-spacing:.04em;color:var(--ink)}
  .cap-card:hover .cap-label{color:var(--gold)}

  /* why-printopack icon cards */
  .why-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:24px}
  .why-card{background:var(--paper);border:1px solid var(--line);border-radius:var(--radius);padding:clamp(26px,2.6vw,34px) clamp(22px,2.2vw,28px)}
  .why-card:hover{border-color:var(--gold);box-shadow:0 20px 40px rgba(14,35,64,.07)}
  .why-icon{display:inline-flex;align-items:center;justify-content:center;width:56px;height:56px;border-radius:50%;background:var(--gold-soft);color:var(--gold);margin-bottom:22px}
  .why-icon svg{width:27px;height:27px}
  .why-card h3{font-size:clamp(18px,1.7vw,22px);margin-bottom:12px;line-height:1.15}
  .why-card p{color:var(--muted);font-size:14.5px;max-width:none}
  @media(max-width:1000px){.why-grid{grid-template-columns:1fr 1fr;gap:20px}}
  @media(max-width:560px){.why-grid{grid-template-columns:1fr}}

  /* vision/mission/values tabbed band */
  .vmv-grid{display:grid;grid-template-columns:1fr 1.1fr;gap:clamp(32px,5vw,72px);align-items:center}
  .vmv-media{aspect-ratio:4/3;overflow:hidden;border-radius:var(--radius);background:var(--navy-soft)}
  .vmv-media img{width:100%;height:100%;object-fit:cover}
  .vmv-tabs{display:flex;gap:4px;border-bottom:1px solid var(--line-dark);margin-bottom:28px}
  .vmv-tab{font-family:var(--display);font-size:13px;font-weight:500;letter-spacing:.12em;text-transform:uppercase;color:rgba(250,246,238,.55);padding:12px 20px;border-bottom:2px solid transparent;margin-bottom:-1px}
  .vmv-tab:hover{color:var(--paper)}
  .vmv-tab.is-active{color:var(--gold-bright);border-bottom-color:var(--gold-bright)}
  .vmv-panel[hidden]{display:none}
  .vmv-panels{min-height:132px}
  .vmv-statement{font-family:var(--display);font-weight:300;font-size:clamp(22px,2.7vw,33px);line-height:1.26;color:var(--paper);max-width:24ch}
  .vmv-list{display:grid;gap:12px}
  .vmv-list li{display:flex;align-items:center;gap:12px;color:rgba(250,246,238,.86);font-size:clamp(16px,1.4vw,18px)}
  .vmv-tick{flex:none;display:inline-flex;color:var(--gold-bright)}
  .vmv-tick svg{width:18px;height:18px}
  .vmv-link{margin-top:30px;color:var(--gold-bright);border-color:var(--gold-bright)}
  @media(max-width:860px){.vmv-grid{grid-template-columns:1fr;gap:32px}.vmv-media{order:2}}

  /* news */
  .news-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:34px;align-items:stretch}
  .news-card{display:flex;flex-direction:column}
  .news-img{aspect-ratio:3/2}
  .news-meta{display:block;margin-top:18px;font-family:var(--display);font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(--gold)}
  .news-title{margin:10px 0 16px;font-size:clamp(20px,1.7vw,25px)}
  .news-read{font-size:12px;margin-top:auto;align-self:flex-start}

  /* section head with side link */
  .split-head{display:flex;justify-content:space-between;align-items:flex-end;max-width:none}

  /* products preview.
     multiply melts each photo's baked-in white background into the cream
     tile, so the product sits on the tile instead of inside a smaller white box. */
  .prod-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:26px}
  .prod-img{aspect-ratio:1;background:var(--cream);display:grid;place-items:center}
  .prod-img img{width:100%;height:100%;object-fit:contain;padding:10px;mix-blend-mode:multiply}
  .prod-label{display:block;margin-top:14px;font-family:var(--display);font-size:15px;letter-spacing:.04em;color:var(--ink)}
  .prod-card:hover .prod-label{color:var(--gold)}

  /* split feature (quality teaser) */
  .split{display:grid;grid-template-columns:1fr 1fr;gap:clamp(30px,6vw,74px);align-items:center}
  .split-media{aspect-ratio:5/4;overflow:hidden;background:var(--sand)}
  .split-media img{width:100%;height:100%;object-fit:cover}

  /* partners logo grid.
     The image is absolutely positioned: a percentage max-height inside an
     aspect-ratio grid cell is circular and collapses the img to 0x0, while
     an abs-pos child resolves against the cell and cannot inflate it.
     mix-blend-mode melts the logos' baked-in white backgrounds into the paper. */
  .logo{position:relative;background:var(--paper);aspect-ratio:16/9}
  .logo-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:1px;background:var(--line);border:1px solid var(--line)}
  .logo img{position:absolute;inset:0;margin:auto;max-width:calc(100% - 52px);max-height:calc(100% - 52px);mix-blend-mode:multiply}
  .logo:hover img{filter:grayscale(1);opacity:.55}
  .partner-counters{display:flex;justify-content:center;gap:clamp(40px,8vw,120px);margin-top:clamp(44px,6vw,66px)}

  @media(max-width:1000px){
    .counters-grid,.cap-grid,.prod-grid{grid-template-columns:repeat(2,1fr);gap:36px 24px}
    .intro-grid,.news-grid,.split{grid-template-columns:1fr;gap:30px}
    .news-grid{gap:40px}
    .split-head{flex-direction:column;align-items:flex-start;gap:16px}
    .logo-grid{grid-template-columns:repeat(3,1fr)}
  }
  @media(max-width:560px){
    .counters-grid,.cap-grid{grid-template-columns:1fr}
    .prod-grid{grid-template-columns:repeat(2,1fr);gap:18px}
    .prod-img img{padding:8px}
    .prod-label{font-size:13.5px}
    .logo-grid{grid-template-columns:repeat(2,1fr)}
    .hero-cta{flex-direction:column;align-items:flex-start}
    .partner-counters{gap:40px}
  }
</style>

<script>
  // Vision/Mission/Values tabs on the home band. Instant, no motion, keyboard-friendly.
  const tabs = Array.from(document.querySelectorAll('.vmv-tab'));
  const panels = Array.from(document.querySelectorAll('.vmv-panel'));
  function select(tab) {
    tabs.forEach((t) => { t.classList.remove('is-active'); t.setAttribute('aria-selected', 'false'); });
    panels.forEach((p) => { p.classList.remove('is-active'); p.setAttribute('hidden', ''); });
    tab.classList.add('is-active'); tab.setAttribute('aria-selected', 'true');
    const panel = document.getElementById('p-' + tab.dataset.tab);
    panel?.classList.add('is-active'); panel?.removeAttribute('hidden');
  }
  tabs.forEach((t, i) => {
    t.addEventListener('click', () => select(t));
    t.addEventListener('keydown', (e) => {
      if (e.key !== 'ArrowRight' && e.key !== 'ArrowLeft') return;
      e.preventDefault();
      const next = e.key === 'ArrowRight' ? (i + 1) % tabs.length : (i - 1 + tabs.length) % tabs.length;
      tabs[next].focus(); select(tabs[next]);
    });
  });
</script>
