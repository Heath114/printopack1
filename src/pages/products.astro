---
import Base from '../layouts/Base.astro';
import Counter from '../components/Counter.astro';
import Bi from '../components/Bi.astro';
import { categories, filters } from '../data/products';
const year = new Date().getFullYear();

// Products (Nasser's Page 3). Catalogue-and-enquire model: browse product groups, open
// one for its products, request a quote (no cart, no prices). The 20 groups are the
// client's real category list; individual products inside each group are client-added
// via the admin. Bilingual; page copy below is editable content.
const content = {
  meta: {
    title: "Products - Printopack",
    description: "Flexible packaging for food, beverage, confectionery and personal-care brands: laminate pouches, films, shrink sleeves and lidding, made to your brief and offered by consultation.",
  },
  header: {
    eyebrow: { en: "Products", ar: "المنتجات" },
    title: { en: "Packaging, made to your brief.", ar: "تغليفٌ مصنوع وفق موجزكم." },
    lede: {
      en: "From snack films to shrink sleeves, every structure is developed for your product, printed in our Jeddah facility and offered by consultation. Browse the groups, open one for detail, then request a quote and we will build to your specification.",
      ar: "من أفلام الوجبات الخفيفة إلى أكمام الانكماش، يُطوَّر كل تركيبٍ لمنتجكم، ويُطبع في مصنعنا بجدة، ويُقدَّم بالاستشارة. تصفّحوا المجموعات، وافتحوا إحداها للتفاصيل، ثم اطلبوا عرض سعر لنصنعه وفق مواصفاتكم.",
    },
  },
  catalogue: {
    label: { en: "Download our catalogue", ar: "حمّل الكتالوج" },
    meta: { en: "PDF", ar: "PDF" },
    href: "/downloads/printopack-catalogue.pdf",
  },
  rail: {
    kicker: { en: "Browse", ar: "تصفّح" },
    note: { en: "Catalogue and enquiry only. No online checkout, every order is made to order and priced on request.", ar: "كتالوج واستفسار فقط. لا شراء إلكتروني؛ كل طلبٍ يُصنع حسب الطلب ويُسعَّر عند الطلب." },
    cta: { en: "Request a quote", ar: "اطلب عرض سعر" },
  },
  card: { meta: { en: "Price on request", ar: "السعر عند الطلب" }, link: { en: "View & enquire", ar: "عرض واستفسار" } },
  empty: { en: "No products in this group yet. Please get in touch and we will scope it with you.", ar: "لا توجد منتجات في هذه المجموعة بعد. يرجى التواصل معنا وسنحدّدها معكم." },
  // Bag & pouch formats (from Printopack's own catalogue).
  formats: {
    eyebrow: { en: "Formats", ar: "الأشكال" },
    title: { en: "Bag and pouch formats we produce.", ar: "أشكال الأكياس والعبوات التي نُنتجها." },
    items: [
      { en: "Pillow Bags", ar: "أكياس وسادية" },
      { en: "Gusseted Bags", ar: "أكياس بجوانب مطويّة" },
      { en: "Center Seal Bags", ar: "أكياس بلحام مركزي" },
      { en: "Zipper Bags", ar: "أكياس بسحّاب" },
      { en: "Stand-up Pouches", ar: "عبوات واقفة" },
      { en: "Handle Bags", ar: "أكياس بمقبض" },
    ],
  },
  howto: {
    eyebrow: { en: "How we work", ar: "كيف نعمل" },
    title: { en: "Made to order, offered by consultation.", ar: "يُصنع حسب الطلب، ويُقدَّم بالاستشارة." },
    steps: [
      { n: "01", t: { en: "Share your brief", ar: "شاركونا موجزكم" }, d: { en: "Format, structure, barrier needs and artwork. We advise on the right laminate from the start.", ar: "الشكل والتركيب واحتياجات الحاجز والتصميم. ننصحكم بالتصفيح المناسب من البداية." } },
      { n: "02", t: { en: "We develop and proof", ar: "نطوّر ونجهّز البروفة" }, d: { en: "Cylinders engraved, structure built and printed, refined until it meets the Printopack standard.", ar: "تُحفر الأسطوانات ويُبنى التركيب ويُطبع، ويُنقّح حتى يبلغ معيار برنتوباك." } },
      { n: "03", t: { en: "Approve and produce", ar: "اعتمدوا وننتج" }, d: { en: "Sign off the proof and we produce at volume, delivered on time to your line.", ar: "اعتمدوا البروفة وننتج بالكميات، ويُسلَّم في وقته إلى خطكم." } },
    ],
  },
  counters: [
    { from: 1997, value: year, label: { en: "Printing since 1997", ar: "نطبع منذ 1997" } },
    { prefix: "+", value: 35, label: { en: "Countries served", ar: "دولة نخدمها" } },
    { prefix: "~", value: 400, label: { en: "Team members", ar: "عضو في الفريق" } },
    { value: 5, label: { en: "Production departments", ar: "أقسام إنتاجية" } },
  ],
  cta: {
    eyebrow: { en: "Let's talk packaging", ar: "لنتحدّث عن التغليف" },
    title: { en: "Tell us what you are packing.", ar: "أخبرونا بما تعبّئون." },
    button: { en: "Request a quote", ar: "اطلب عرض سعر" },
  },
};
const c = content;
---
<Base title={c.meta.title} description={c.meta.description}>
  <!-- PAGE HEADER -->
  <section class="page-head">
    <div class="wrap-wide">
      <div class="page-head-inner">
        <span class="eyebrow"><Bi en={c.header.eyebrow.en} ar={c.header.eyebrow.ar} /></span>
        <h1><Bi en={c.header.title.en} ar={c.header.title.ar} /></h1>
        <p class="lede"><Bi en={c.header.lede.en} ar={c.header.lede.ar} /></p>
        <a class="cat-download" href={c.catalogue.href} target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M12 3v12m0 0l-4.5-4.5M12 15l4.5-4.5"/><path d="M4 17v2.5A1.5 1.5 0 0 0 5.5 21h13a1.5 1.5 0 0 0 1.5-1.5V17"/></svg>
          <span><Bi en={c.catalogue.label.en} ar={c.catalogue.label.ar} /></span>
          <span class="cat-download-meta"><Bi en={c.catalogue.meta.en} ar={c.catalogue.meta.ar} /></span>
        </a>
      </div>
    </div>
  </section>

  <!-- CATALOGUE: filter rail + group grid -->
  <section class="catalogue">
    <div class="wrap-wide cat-layout">
      <aside class="cat-rail">
        <span class="rail-kicker"><Bi en={c.rail.kicker.en} ar={c.rail.kicker.ar} /></span>
        <!-- mobile-only dropdown trigger; on desktop the list is an always-open sidebar -->
        <button class="rail-toggle" aria-expanded="false" aria-controls="filter-list">
          <span class="rail-toggle-label"><Bi en={filters[0].label.en} ar={filters[0].label.ar} /></span>
          <svg class="rail-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <ul class="rail-list" id="filter-list">
          {filters.map((f, i) => (
            <li><button class={"rail-btn" + (i === 0 ? " active" : "")} data-filter={f.key}><Bi en={f.label.en} ar={f.label.ar} /></button></li>
          ))}
        </ul>
        <div class="rail-note">
          <p><Bi en={c.rail.note.en} ar={c.rail.note.ar} /></p>
          <a href="/contact" class="btn btn-solid rail-cta"><Bi en={c.rail.cta.en} ar={c.rail.cta.ar} /></a>
        </div>
      </aside>

      <div class="cat-main">
        <div class="cat-grid">
          {categories.map((cat) => (
            <article class="prod2" data-group={cat.group}>
              <a href={`/products/${cat.slug}`} class="prod2-img" aria-label={cat.name.en}>
                <img src={cat.img} alt={cat.name.en} loading="lazy" decoding="async" />
              </a>
              <div class="prod2-body">
                <h3 class="prod2-name"><a href={`/products/${cat.slug}`}><Bi en={cat.name.en} ar={cat.name.ar} /></a></h3>
                <p class="prod2-desc"><Bi en={cat.desc.en} ar={cat.desc.ar} /></p>
                <div class="prod2-foot">
                  <span class="prod2-meta"><Bi en={c.card.meta.en} ar={c.card.meta.ar} /></span>
                  <a href={`/products/${cat.slug}`} class="link-line prod2-link"><Bi en={c.card.link.en} ar={c.card.link.ar} /></a>
                </div>
              </div>
            </article>
          ))}
        </div>
        <p class="cat-empty" hidden><Bi en={c.empty.en} ar={c.empty.ar} /></p>
      </div>
    </div>
  </section>

  <!-- FORMATS (bag & pouch types from the catalogue) -->
  <section class="formats" style="background:var(--cream)">
    <div class="wrap-wide">
      <div class="section-head">
        <span class="eyebrow plain" style="color:var(--gold)"><Bi en={c.formats.eyebrow.en} ar={c.formats.eyebrow.ar} /></span>
        <h2 style="margin-top:14px"><Bi en={c.formats.title.en} ar={c.formats.title.ar} /></h2>
      </div>
      <ul class="format-grid">
        {c.formats.items.map((f) => (
          <li class="format-chip"><Bi en={f.en} ar={f.ar} /></li>
        ))}
      </ul>
    </div>
  </section>

  <!-- HOW WE WORK -->
  <section class="on-navy howto">
    <div class="wrap">
      <div class="section-head">
        <span class="eyebrow"><Bi en={c.howto.eyebrow.en} ar={c.howto.eyebrow.ar} /></span>
        <h2 style="margin-top:16px"><Bi en={c.howto.title.en} ar={c.howto.title.ar} /></h2>
      </div>
      <div class="steps">
        {c.howto.steps.map((s) => (
          <div class="step">
            <span class="step-n">{s.n}</span>
            <h3 class="step-t"><Bi en={s.t.en} ar={s.t.ar} /></h3>
            <p class="step-d"><Bi en={s.d.en} ar={s.d.ar} /></p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="on-deep prod-stats">
    <div class="wrap-wide counters-row">
      {c.counters.map((n) => <Counter from={n.from} prefix={n.prefix} value={n.value} label={n.label.en} labelAr={n.label.ar} />)}
    </div>
  </section>

  <!-- CTA -->
  <section class="cta">
    <div class="wrap" style="text-align:center">
      <span class="eyebrow plain" style="color:var(--gold)"><Bi en={c.cta.eyebrow.en} ar={c.cta.eyebrow.ar} /></span>
      <h2 style="margin:16px 0 26px"><Bi en={c.cta.title.en} ar={c.cta.title.ar} /></h2>
      <a href="/contact" class="btn btn-gold"><Bi en={c.cta.button.en} ar={c.cta.button.ar} /></a>
    </div>
  </section>
</Base>

<style>
  .page-head{padding-block:clamp(56px,8vw,104px) clamp(30px,4vw,52px);background:var(--cream);border-bottom:1px solid var(--line)}
  .page-head-inner{max-width:820px}
  .page-head h1{margin:20px 0 22px;font-size:clamp(40px,6vw,78px)}
  .page-head .lede{max-width:60ch}
  .cat-download{display:inline-flex;align-items:center;gap:10px;margin-top:26px;padding:11px 18px;border:1px solid var(--navy);border-radius:var(--radius);font-family:var(--display);font-size:14px;color:var(--navy);background:var(--paper)}
  .cat-download:hover{background:var(--navy);color:var(--paper)}
  .cat-download svg{width:18px;height:18px}
  .cat-download-meta{font-size:11px;letter-spacing:.12em;color:var(--gold);border-inline-start:1px solid var(--line);padding-inline-start:10px}
  .cat-download:hover .cat-download-meta{color:var(--gold-bright)}

  .cat-layout{display:grid;grid-template-columns:260px 1fr;gap:clamp(30px,5vw,64px);align-items:start}
  .cat-rail{position:sticky;top:150px;align-self:start}
  .rail-kicker{font-family:var(--display);font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);display:block;margin-bottom:18px}
  .rail-toggle{display:none}
  .rail-list{display:flex;flex-direction:column;gap:2px;border-top:1px solid var(--line)}
  .rail-btn{display:block;width:100%;text-align:start;padding:13px 0;font-family:var(--display);font-size:15px;font-weight:400;color:var(--muted);border-bottom:1px solid var(--line-soft)}
  .rail-btn:hover{color:var(--ink)}
  .rail-btn.active{color:var(--navy);font-weight:500}
  .rail-note{margin-top:28px}
  .rail-note p{font-size:13.5px;color:var(--muted);line-height:1.6;margin-bottom:18px;max-width:34ch}
  .rail-cta{width:100%;justify-content:center}

  .cat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:clamp(20px,2.4vw,34px)}
  .prod2{display:flex;flex-direction:column;border:1px solid var(--line);background:var(--paper)}
  .prod2[hidden]{display:none}
  .prod2:hover{border-color:var(--sand);box-shadow:0 24px 44px rgba(14,35,64,.07)}
  .prod2-img{display:block;aspect-ratio:4/3;background:var(--cream);overflow:hidden}
  .prod2-img img{width:100%;height:100%;object-fit:contain;padding:22px;mix-blend-mode:multiply}
  .prod2-body{display:flex;flex-direction:column;flex:1;padding:22px 22px 24px}
  .prod2-name{font-size:clamp(19px,1.5vw,22px);margin-bottom:9px}
  .prod2-name a:hover{color:var(--gold)}
  .prod2-desc{font-size:14.5px;color:var(--muted);line-height:1.6;margin-bottom:20px}
  .prod2-foot{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-top:auto;padding-top:16px;border-top:1px solid var(--line-soft)}
  .prod2-meta{font-family:var(--display);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--faint)}
  .prod2-link{font-size:11.5px!important}
  .cat-empty{margin-top:30px;color:var(--muted)}

  .formats{padding-block:clamp(48px,6vw,80px)}
  .format-grid{display:flex;flex-wrap:wrap;gap:12px;margin-top:clamp(24px,3vw,34px)}
  .format-chip{font-family:var(--display);font-size:clamp(15px,1.4vw,17px);color:var(--navy);background:var(--paper);border:1px solid var(--line);border-radius:999px;padding:12px 22px}

  .steps{display:grid;grid-template-columns:repeat(3,1fr);gap:clamp(28px,4vw,56px);margin-top:clamp(30px,4vw,48px)}
  .step{border-top:1px solid var(--line-dark);padding-top:24px}
  .step-n{font-family:var(--display);font-size:14px;font-weight:500;letter-spacing:.1em;color:var(--gold-bright)}
  .step-t{font-size:clamp(21px,2vw,26px);margin:14px 0 12px;color:var(--paper)}
  .step-d{font-size:15px;color:rgba(250,246,238,.72);line-height:1.65;max-width:36ch}

  .prod-stats{padding-block:clamp(52px,6vw,78px)}
  .counters-row{display:grid;grid-template-columns:repeat(4,1fr);gap:30px}

  @media(max-width:920px){
    .cat-layout{grid-template-columns:1fr;gap:28px}
    /* min-width:0 lets the 1fr track shrink to the viewport; without it the
       no-wrap filter rail forces the whole column (and card grid) ~1022px wide */
    .cat-rail,.cat-main{min-width:0}
    .cat-rail{position:static}
    /* the filter becomes a pull-down: a full-width trigger that opens an organised
       list, taps to select and closes. Instant open/close (no motion). */
    .rail-kicker{display:none}
    .rail-toggle{display:flex;align-items:center;justify-content:space-between;gap:12px;width:100%;padding:14px 18px;border:1px solid var(--line);border-radius:6px;background:var(--paper);font-family:var(--display);font-size:15px;color:var(--ink)}
    .rail-chevron{width:19px;height:19px;color:var(--muted);flex:none}
    .rail-toggle[aria-expanded="true"] .rail-chevron{transform:rotate(180deg)}
    .rail-list{display:none;flex-direction:column;gap:0;border:1px solid var(--line);border-top:none;border-radius:0 0 6px 6px;overflow:hidden}
    .cat-rail.open .rail-list{display:flex}
    .rail-btn{width:100%;text-align:start;padding:13px 18px;font-size:15px;color:var(--muted);border-bottom:1px solid var(--line-soft)}
    .rail-list li:last-child .rail-btn{border-bottom:none}
    .rail-btn.active{color:var(--navy);font-weight:500;background:var(--cream)}
    .rail-note{display:none}
    .cat-grid{grid-template-columns:repeat(2,1fr)}
    .steps{grid-template-columns:1fr;gap:0}
    .step{border-top:1px solid var(--line-dark);padding:24px 0}
    .counters-row{grid-template-columns:repeat(2,1fr);gap:36px 24px}
  }
  @media(max-width:520px){
    .cat-grid{grid-template-columns:1fr}
    .counters-row{grid-template-columns:1fr}
  }
</style>

<script>
  // Group filter: toggle group cards by filter. No reload.
  const buttons = document.querySelectorAll<HTMLButtonElement>('.rail-btn');
  const cards = document.querySelectorAll<HTMLElement>('.prod2');
  const empty = document.querySelector<HTMLElement>('.cat-empty');
  const rail = document.querySelector<HTMLElement>('.cat-rail');
  const toggle = document.querySelector<HTMLButtonElement>('.rail-toggle');
  const toggleLabel = document.querySelector<HTMLElement>('.rail-toggle-label');
  const apply = (filter: string) => {
    let shown = 0;
    cards.forEach((card) => {
      const match = filter === 'all' || card.dataset.group === filter;
      card.hidden = !match;
      if (match) shown++;
    });
    if (empty) empty.hidden = shown !== 0;
  };
  const setOpen = (open: boolean) => {
    rail?.classList.toggle('open', open);
    toggle?.setAttribute('aria-expanded', String(open));
  };
  toggle?.addEventListener('click', () => setOpen(!rail?.classList.contains('open')));
  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      buttons.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      apply(btn.dataset.filter || 'all');
      if (toggleLabel) toggleLabel.innerHTML = btn.innerHTML; // mirror the choice (keeps EN/AR spans)
      setOpen(false);
    });
  });
  // close the pull-down when tapping outside it
  document.addEventListener('click', (e) => {
    if (rail && !(e.target as HTMLElement).closest('.cat-rail')) setOpen(false);
  });
</script>
