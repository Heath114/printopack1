---
import Base from '../layouts/Base.astro';
import Counter from '../components/Counter.astro';

// Grove catalogue model: browse categories, enquire for a quote (no cart, no prices).
// Products and full descriptions are provided by the client and edited via the admin
// CMS. Copy here is category-level and intentionally generic so it reads well until
// the client fills in the detail.
const categories = [
  { img: "/images/cat-1.png", name: "Chips & Snacks", group: "snacks", desc: "Metallised laminate bags and films that hold freshness and crunch on the shelf." },
  { img: "/images/cat-2.png", name: "Chocolates", group: "confectionery", desc: "High-barrier wrappers and flow-wrap films with a premium print finish." },
  { img: "/images/cat-3.png", name: "Bakery Products", group: "bakery", desc: "Grease-resistant laminates and bags for breads, cakes and pastries." },
  { img: "/images/cat-4.png", name: "Candy", group: "confectionery", desc: "Twist wraps, flow-wrap and stand-up pouches for confectionery lines." },
  { img: "/images/cat-5.png", name: "Breads", group: "bakery", desc: "Printed bread bags and resealable packs built for shelf life." },
  { img: "/images/cat-6.png", name: "Bottle Labels", group: "labels", desc: "Shrink sleeves and wrap-around labels for bottles and containers." },
  { img: "/images/cat-7.png", name: "Lids", group: "lids", desc: "Heat-seal lidding films for cups, trays and dairy formats." },
  { img: "/images/cat-8.png", name: "Ice Cream", group: "frozen", desc: "Cold-resistant wrappers and lidding for frozen and dairy products." },
];

const groups = [
  { key: "all", label: "All products" },
  { key: "snacks", label: "Snacks" },
  { key: "confectionery", label: "Confectionery" },
  { key: "bakery", label: "Bakery" },
  { key: "labels", label: "Labels & sleeves" },
  { key: "lids", label: "Lids & closures" },
  { key: "frozen", label: "Frozen & dairy" },
];

const steps = [
  { n: "01", t: "Share your brief", d: "Format, structure, barrier needs and artwork. We advise on the right laminate from the start." },
  { n: "02", t: "We develop and proof", d: "Cylinders engraved, structure built and printed, refined until it meets the Printopack standard." },
  { n: "03", t: "Approve and produce", d: "Sign off the proof and we produce at volume, delivered on time to your line." },
];
---
<Base
  title="Products - Printopack"
  description="Flexible packaging for food, beverage, confectionery and personal-care brands: laminate pouches, films, shrink sleeves and lidding, made to your brief and offered by consultation."
>
  <!-- PAGE HEADER -->
  <section class="page-head">
    <div class="wrap-wide">
      <div class="page-head-inner">
        <span class="eyebrow" data-reveal>Products</span>
        <h1 data-reveal>Packaging, made to your brief.</h1>
        <p class="lede" data-reveal>
          From snack films to shrink sleeves, every structure is developed for your product, printed
          in our Jeddah facility and offered by consultation. Browse the categories, then request a
          quote and we will build to your specification.
        </p>
      </div>
    </div>
  </section>

  <!-- CATALOGUE: filter rail + grid -->
  <section class="catalogue">
    <div class="wrap-wide cat-layout">
      <aside class="cat-rail">
        <span class="rail-kicker">Browse</span>
        <ul class="rail-list">
          {groups.map((g, i) => (
            <li><button class={"rail-btn" + (i === 0 ? " active" : "")} data-filter={g.key}>{g.label}</button></li>
          ))}
        </ul>
        <div class="rail-note">
          <p>Catalogue and enquiry only. No online checkout, every order is made to order and priced on request.</p>
          <a href="/contact" class="btn btn-solid rail-cta">Request a quote</a>
        </div>
      </aside>

      <div class="cat-main">
        <div class="cat-grid">
          {categories.map((c) => (
            <article class="prod2" data-group={c.group} data-reveal>
              <a href="/contact" class="prod2-img" aria-label={`Enquire about ${c.name}`}>
                <img src={c.img} alt={c.name} loading="lazy" decoding="async" />
              </a>
              <div class="prod2-body">
                <h3 class="prod2-name">{c.name}</h3>
                <p class="prod2-desc">{c.desc}</p>
                <div class="prod2-foot">
                  <span class="prod2-meta">Price on request</span>
                  <a href="/contact" class="link-line prod2-link">Request a quote</a>
                </div>
              </div>
            </article>
          ))}
        </div>
        <p class="cat-empty" hidden>No products in this category yet. Please <a href="/contact">get in touch</a> and we will scope it with you.</p>
      </div>
    </div>
  </section>

  <!-- HOW WE WORK -->
  <section class="on-navy howto">
    <div class="wrap">
      <div class="section-head" data-reveal>
        <span class="eyebrow">How we work</span>
        <h2 style="margin-top:16px">Made to order, offered by consultation.</h2>
      </div>
      <div class="steps">
        {steps.map((s) => (
          <div class="step" data-reveal>
            <span class="step-n">{s.n}</span>
            <h3 class="step-t">{s.t}</h3>
            <p class="step-d">{s.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="on-deep prod-stats">
    <div class="wrap-wide counters-row">
      <Counter prefix="+" value="25" label="Years of printing" />
      <Counter prefix="+" value="26" label="Countries served" />
      <Counter prefix="~" value="400" label="Team members" />
      <Counter value="5" label="Production departments" />
    </div>
  </section>

  <!-- CTA -->
  <section class="cta">
    <div class="wrap" style="text-align:center">
      <span class="eyebrow plain" data-reveal style="color:var(--gold)">Let's talk packaging</span>
      <h2 data-reveal style="margin:16px 0 26px">Tell us what you are packing.</h2>
      <a href="/contact" class="btn btn-gold" data-reveal>Request a quote</a>
    </div>
  </section>
</Base>

<style>
  /* page header */
  .page-head{padding-block:clamp(56px,8vw,104px) clamp(30px,4vw,52px);background:var(--cream);border-bottom:1px solid var(--line)}
  .page-head-inner{max-width:820px}
  .page-head h1{margin:20px 0 22px;font-size:clamp(40px,6vw,78px)}
  .page-head .lede{max-width:60ch}

  /* catalogue layout */
  .cat-layout{display:grid;grid-template-columns:260px 1fr;gap:clamp(30px,5vw,64px);align-items:start}
  .cat-rail{position:sticky;top:150px;align-self:start}
  .rail-kicker{font-family:var(--display);font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);display:block;margin-bottom:18px}
  .rail-list{display:flex;flex-direction:column;gap:2px;border-top:1px solid var(--line)}
  .rail-btn{display:block;width:100%;text-align:left;padding:13px 0;font-family:var(--display);font-size:15px;font-weight:400;color:var(--muted);border-bottom:1px solid var(--line-soft);transition:.25s var(--ease)}
  .rail-btn:hover{color:var(--ink);padding-left:6px}
  .rail-btn.active{color:var(--navy);font-weight:500}
  .rail-note{margin-top:28px}
  .rail-note p{font-size:13.5px;color:var(--muted);line-height:1.6;margin-bottom:18px;max-width:34ch}
  .rail-cta{width:100%;justify-content:center}

  /* product cards */
  .cat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:clamp(20px,2.4vw,34px)}
  .prod2{display:flex;flex-direction:column;border:1px solid var(--line);background:var(--paper);transition:border-color .35s var(--ease),box-shadow .35s var(--ease)}
  /* [hidden] must beat the .prod2 class selector, or filtered-out cards stay visible */
  .prod2[hidden]{display:none}
  .prod2:hover{border-color:var(--sand);box-shadow:0 24px 44px rgba(14,35,64,.07)}
  .prod2-img{display:block;aspect-ratio:4/3;background:var(--cream);overflow:hidden}
  .prod2-img img{width:100%;height:100%;object-fit:contain;padding:22px;mix-blend-mode:multiply;transition:transform 1s var(--ease)}
  .prod2:hover .prod2-img img{transform:scale(1.05)}
  .prod2-body{display:flex;flex-direction:column;flex:1;padding:22px 22px 24px}
  .prod2-name{font-size:clamp(19px,1.5vw,22px);margin-bottom:9px}
  .prod2-desc{font-size:14.5px;color:var(--muted);line-height:1.6;margin-bottom:20px}
  .prod2-foot{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-top:auto;padding-top:16px;border-top:1px solid var(--line-soft)}
  .prod2-meta{font-family:var(--display);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--faint)}
  .prod2-link{font-size:11.5px!important}
  .cat-empty{margin-top:30px;color:var(--muted)}
  .cat-empty a{color:var(--gold);border-bottom:1px solid currentColor}

  /* how we work */
  .steps{display:grid;grid-template-columns:repeat(3,1fr);gap:clamp(28px,4vw,56px);margin-top:clamp(30px,4vw,48px)}
  .step{border-top:1px solid var(--line-dark);padding-top:24px}
  .step-n{font-family:var(--display);font-size:14px;font-weight:500;letter-spacing:.1em;color:var(--gold-bright)}
  .step-t{font-size:clamp(21px,2vw,26px);margin:14px 0 12px;color:var(--paper)}
  .step-d{font-size:15px;color:rgba(250,246,238,.72);line-height:1.65;max-width:36ch}

  /* stats */
  .prod-stats{padding-block:clamp(52px,6vw,78px)}
  .counters-row{display:grid;grid-template-columns:repeat(4,1fr);gap:30px}

  @media(max-width:920px){
    .cat-layout{grid-template-columns:1fr;gap:34px}
    .cat-rail{position:static}
    .rail-list{flex-direction:row;flex-wrap:wrap;border-top:none;gap:8px}
    .rail-btn{width:auto;border:1px solid var(--line);border-radius:2px;padding:9px 15px;font-size:13.5px}
    .rail-btn:hover{padding-left:15px}
    .rail-btn.active{border-color:var(--navy);color:var(--navy)}
    .rail-note{display:none}
    .cat-grid{grid-template-columns:repeat(2,1fr)}
    .steps{grid-template-columns:1fr;gap:0}
    .step{border-top:1px solid var(--line-dark);padding:24px 0}
    .counters-row{grid-template-columns:repeat(2,1fr);gap:36px 24px}
  }
  @media(max-width:520px){
    .cat-grid{grid-template-columns:1fr}
    .counters-row{grid-template-columns:1fr}
  }
</style>

<script>
  // Catalogue filter: toggle category cards by group. No page reload, no motion
  // beyond the existing reveal. Falls back to showing everything if JS is off.
  const buttons = document.querySelectorAll<HTMLButtonElement>('.rail-btn');
  const cards = document.querySelectorAll<HTMLElement>('.prod2');
  const empty = document.querySelector<HTMLElement>('.cat-empty');

  const apply = (filter: string) => {
    let shown = 0;
    cards.forEach((card) => {
      const match = filter === 'all' || card.dataset.group === filter;
      card.hidden = !match;
      // force a filtered-in card fully visible so it never stays stuck at the
      // reveal animation's opacity:0 if it had not scrolled into view yet
      if (match) { card.classList.add('in'); shown++; }
    });
    if (empty) empty.hidden = shown !== 0;
  };

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      buttons.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      apply(btn.dataset.filter || 'all');
    });
  });
</script>
