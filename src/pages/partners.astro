---
import Base from '../layouts/Base.astro';
import Counter from '../components/Counter.astro';

// Success Partners. The 20 client logos are real. Per-client names and countries
// are supplied by the client and managed in the admin CMS; the logos stand on their
// own here. Markets shown are Printopack's real regional offices plus HQ.
const clients = Array.from({ length: 20 }, (_, i) => `/images/clients/client-${i + 1}.png`);
const markets = ["Saudi Arabia", "Kuwait", "Jordan", "Egypt", "Sudan", "Tunisia", "Algeria"];
---
<Base
  title="Success Partners - Printopack"
  description="Printopack is trusted by leading food, beverage and consumer brands across 26+ countries. Meet some of the partners we print and pack for."
>
  <!-- PAGE HEADER -->
  <section class="page-head">
    <div class="wrap-wide">
      <div class="page-head-inner">
        <span class="eyebrow" data-reveal>Success partners</span>
        <h1 data-reveal>Trusted by leading brands.</h1>
        <p class="lede" data-reveal>
          From regional champions to household names, brands come to Printopack for packaging that
          protects their product and carries their identity. Here are some of the partners we print
          and pack for.
        </p>
      </div>
    </div>
  </section>

  <!-- COUNTERS -->
  <section class="on-deep partner-stats">
    <div class="wrap-wide counters-row">
      <Counter prefix="+" value="20" label="Brand partners" />
      <Counter prefix="+" value="26" label="Countries served" />
      <Counter prefix="+" value="25" label="Years of printing" />
      <Counter prefix="~" value="400" label="Team members" />
    </div>
  </section>

  <!-- LOGO GRID -->
  <section class="partners-wall">
    <div class="wrap-wide">
      <div class="section-head center" data-reveal>
        <span class="eyebrow plain" style="color:var(--gold)">Our partners</span>
        <h2 style="margin-top:14px">Brands that trust our print.</h2>
      </div>
      <div class="logo-grid">
        {clients.map((c) => (
          <span class="logo" data-reveal><img src={c} alt="Client brand" loading="lazy" /></span>
        ))}
      </div>
    </div>
  </section>

  <!-- MARKETS -->
  <section class="markets">
    <div class="wrap markets-inner">
      <div data-reveal>
        <span class="eyebrow">Where we deliver</span>
        <h2 style="margin:16px 0 18px">Across the region and beyond.</h2>
        <p class="lede">With six regional offices and export to more than 26 countries, we keep partners supplied wherever their brands sell.</p>
      </div>
      <div class="markets-tags" data-reveal>
        {markets.map((m) => <span class="tag">{m}</span>)}
        <span class="tag tag-more">+ 19 more markets</span>
      </div>
    </div>
  </section>

  <!-- PARTNERSHIP BAND -->
  <section class="on-navy editorial">
    <div class="wrap editorial-inner">
      <span class="eyebrow" data-reveal>Why brands stay</span>
      <p class="editorial-quote" data-reveal>
        A partner, not just a supplier: consistent print, structures made to spec and delivery you
        can plan around, order after order.
      </p>
      <a href="/contact" class="link-line" data-reveal style="color:var(--gold-bright);border-color:var(--gold-bright)">Become a partner</a>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta">
    <div class="wrap" style="text-align:center">
      <span class="eyebrow plain" data-reveal style="color:var(--gold)">Let's talk packaging</span>
      <h2 data-reveal style="margin:16px 0 26px">Put your brand in good company.</h2>
      <a href="/contact" class="btn btn-gold" data-reveal>Request a quote</a>
    </div>
  </section>
</Base>

<style>
  .page-head{padding-block:clamp(56px,8vw,104px) clamp(30px,4vw,52px);background:var(--cream);border-bottom:1px solid var(--line)}
  .page-head-inner{max-width:820px}
  .page-head h1{margin:20px 0 22px;font-size:clamp(40px,6vw,78px)}
  .page-head .lede{max-width:60ch}

  .partner-stats{padding-block:clamp(52px,6vw,78px)}
  .counters-row{display:grid;grid-template-columns:repeat(4,1fr);gap:30px}

  /* logo wall (fuller than the home strip) */
  .logo-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:1px;background:var(--line);border:1px solid var(--line)}
  .logo{position:relative;background:var(--paper);aspect-ratio:16/10}
  .logo img{position:absolute;inset:0;margin:auto;max-width:calc(100% - 56px);max-height:calc(100% - 56px);mix-blend-mode:multiply;transition:.4s var(--ease)}
  .logo:hover img{filter:grayscale(1);opacity:.55}

  /* markets */
  .markets{background:var(--cream);border-top:1px solid var(--line);border-bottom:1px solid var(--line)}
  .markets-inner{display:grid;grid-template-columns:1fr 1fr;gap:clamp(30px,5vw,72px);align-items:center}
  .markets-tags{display:flex;flex-wrap:wrap;gap:12px}
  .tag{font-family:var(--display);font-size:14px;letter-spacing:.03em;color:var(--ink);border:1px solid var(--line);background:var(--paper);padding:11px 20px;border-radius:2px}
  .tag-more{color:var(--gold);border-color:var(--gold-soft);background:var(--gold-soft)}

  /* editorial (shared with home) */
  .editorial-inner{max-width:920px;text-align:center;margin-inline:auto}
  .editorial-quote{font-family:var(--display);font-weight:300;font-size:clamp(24px,3.2vw,40px);line-height:1.28;color:var(--paper);margin:24px auto 30px;max-width:none}

  @media(max-width:1000px){
    .counters-row{grid-template-columns:repeat(2,1fr);gap:36px 24px}
    .logo-grid{grid-template-columns:repeat(3,1fr)}
    .markets-inner{grid-template-columns:1fr;gap:26px}
  }
  @media(max-width:520px){
    .counters-row{grid-template-columns:1fr}
    .logo-grid{grid-template-columns:repeat(2,1fr)}
  }
</style>
