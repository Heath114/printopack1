---
import Base from '../layouts/Base.astro';
import Bi from '../components/Bi.astro';
import Counter from '../components/Counter.astro';
import { reachMap } from '../data/reach-map';
import { collection } from '../lib/content';

// Offices directory, sourced from the content store (admin-managed), split by group.
const _offices = collection('offices');
const saudiOffices = _offices.filter((o) => o.group === 'Saudi Arabia').map((o) => ({
  city: { en: o.city, ar: o.cityAr }, area: { en: o.country, ar: o.countryAr },
  staff: { en: o.staffName, ar: o.staffNameAr }, role: { en: o.staffRole, ar: o.staffRoleAr },
  email: o.email, phone: o.phone,
}));
const regionalOffices = _offices.filter((o) => o.group === 'Regional & Export').map((o) => ({
  country: { en: o.city, ar: o.cityAr },
  staff: { en: o.staffName, ar: o.staffNameAr }, role: { en: o.staffRole, ar: o.staffRoleAr },
  email: o.email, phone: o.phone,
}));

// Contact (Nasser's Page 7, التواصل والمراسلات) - the last page.
// Design brief (Nasser + Amal's real directory in reference/offices.md):
//  - An Outlook-style enquiry window: pick a reason and your market, and the message is
//    routed to the right inbox automatically (the "autonomous mapper"; resolved recipient +
//    subject are attached to the submission).
//  - The reused reach map is stacked ABOVE the form (vertical, roomier), with a "choose your
//    market" pull-down beside it (for visitors who do not know the geography). Selecting a
//    market (map or pull-down) highlights the country + fills a stable office card + fills
//    the read-only office email/phone in the form. Careers is handled centrally by HR: it
//    swaps the locked contact to HR, disables the market picker + map, and reveals a required
//    CV upload + optional cover letter (styled dropzones; multipart Netlify Forms).
//  - Visitors can either submit the Netlify form or open a pre-filled draft in Outlook / Gmail
//    / their default mail app (recipient + subject + body auto-filled from the form).
//  - Counters sit right after the header. Reads ?office=<cc> (Partners map popup) and
//    ?reason=/&role= (legacy Careers) to preselect + scroll.
// Bilingual EN/AR + RTL, responsive, no motion, template-first (content is the admin surface).
const year = new Date().getFullYear();

// Offices keyed by the reach-map country codes: drives the map + the market selector + the
// office card. Real routing emails/phones (Amal's directory); shared desks point at one
// office (Jordan+Iraq, Tunisia+Libya). Staff names are client-gated (filled via the admin).
const officesByCc = {
  sa: { name: { en: "Saudi Arabia", ar: "المملكة العربية السعودية" }, role: { en: "Head Office", ar: "المقر الرئيسي" }, place: { en: "Industrial Area 5, Jeddah", ar: "المنطقة الصناعية 5، جدة" }, email: "info@printopack.com.sa", phone: "+966 12 608 1074" },
  kw: { name: { en: "Kuwait", ar: "الكويت" }, role: { en: "Regional Office", ar: "مكتب إقليمي" }, place: { en: "", ar: "" }, email: "kuwait@printopack.com.sa", phone: "+965 97707578" },
  jo: { name: { en: "Jordan", ar: "الأردن" }, role: { en: "Regional Office", ar: "مكتب إقليمي" }, place: { en: "Jordan & Iraq office", ar: "مكتب الأردن والعراق" }, email: "jordan@printopack.com.sa", phone: "+962 7 8570 6299" },
  iq: { name: { en: "Iraq", ar: "العراق" }, role: { en: "Regional Office", ar: "مكتب إقليمي" }, place: { en: "Jordan & Iraq office", ar: "مكتب الأردن والعراق" }, email: "jordan@printopack.com.sa", phone: "+962 7 8570 6299" },
  eg: { name: { en: "Egypt", ar: "مصر" }, role: { en: "Regional Office", ar: "مكتب إقليمي" }, place: { en: "", ar: "" }, email: "egypt@printopack.com.sa", phone: "+20 111 171 2221" },
  sd: { name: { en: "Sudan", ar: "السودان" }, role: { en: "Regional Office", ar: "مكتب إقليمي" }, place: { en: "", ar: "" }, email: "sudan@printopack.com.sa", phone: "+966 55 421 9918" },
  tn: { name: { en: "Tunisia", ar: "تونس" }, role: { en: "Regional Office", ar: "مكتب إقليمي" }, place: { en: "Tunisia & Libya office", ar: "مكتب تونس وليبيا" }, email: "tunisia@printopack.com.sa", phone: "+216 28534504" },
  ly: { name: { en: "Libya", ar: "ليبيا" }, role: { en: "Regional Office", ar: "مكتب إقليمي" }, place: { en: "Tunisia & Libya office", ar: "مكتب تونس وليبيا" }, email: "tunisia@printopack.com.sa", phone: "+216 28534504" },
  dz: { name: { en: "Algeria", ar: "الجزائر" }, role: { en: "Regional Office", ar: "مكتب إقليمي" }, place: { en: "", ar: "" }, email: "info-algeria@printopack.com.sa", phone: "+213 553038979" },
  ma: { name: { en: "Morocco", ar: "المغرب" }, role: { en: "Regional Office", ar: "مكتب إقليمي" }, place: { en: "", ar: "" }, email: "moroccooffice@printopack.com.sa", phone: "+966 55 421 9918" },
  ye: { name: { en: "Yemen", ar: "اليمن" }, role: { en: "Regional Office", ar: "مكتب إقليمي" }, place: { en: "", ar: "" }, email: "yemen@printopack.com.sa", phone: "+967 775299991" },
  sy: { name: { en: "Syria", ar: "سوريا" }, role: { en: "Regional Office", ar: "مكتب إقليمي" }, place: { en: "", ar: "" }, email: "bsh_moneer@hotmail.com", phone: "+963 933431615" },
};
// Human Resources office (careers are handled centrally, not per-country).
const hrOffice = { name: { en: "Human Resources", ar: "الموارد البشرية" }, role: { en: "Recruitment", ar: "التوظيف" }, place: { en: "Head Office, Jeddah", ar: "المقر الرئيسي، جدة" }, email: "hr@printopack.com.sa", phone: "+966 12 608 1074" };
// Selector order for the "target market" pull-down (Saudi first / default, then the region).
const marketOrder = ["sa", "kw", "jo", "iq", "eg", "sd", "tn", "ly", "dz", "ma", "ye", "sy"];

const content = {
  meta: {
    title: "Contact - Printopack",
    description: "Talk to Printopack in Jeddah or through our regional offices across the region. Pick a reason and your market and we route your enquiry to the right desk.",
  },
  header: {
    eyebrow: { en: "Contact", ar: "التواصل والمراسلات" },
    title: { en: "Let's talk packaging.", ar: "لنتحدّث عن التغليف." },
    lede: {
      en: "Send your brief, your artwork or just a question. Choose what it is about and the market you are in, and we route it to the right team, at head office in Jeddah or the regional office nearest you.",
      ar: "أرسل ملخّصك أو تصاميمك أو مجرّد سؤال. اختر موضوع رسالتك والسوق الذي تعمل فيه، ونوجّهها إلى الفريق المناسب، في المقر الرئيسي بجدة أو أقرب مكتب إقليمي إليك.",
    },
  },
  counters: [
    { value: "10", label: { en: "Regional offices", ar: "مكتب إقليمي" } },
    { prefix: "+", value: "35", label: { en: "Countries served", ar: "دولة نصل إليها" } },
    { from: "1997", value: String(year), label: { en: "In the market since 1997", ar: "في السوق منذ 1997" } },
  ],
  // General contact channels (head office + direct management emails + customer portal).
  channels: {
    hq: {
      kicker: { en: "Head office", ar: "المقر الرئيسي" },
      title: { en: "Jeddah, Saudi Arabia", ar: "جدة، المملكة العربية السعودية" },
      addr: {
        en: "Industrial Area 5, Unit 10, 8508<br />Jeddah 22428<br />P.O. Box 19596, Jeddah 21445",
        ar: "المنطقة الصناعية 5، وحدة 10، 8508<br />جدة 22428<br />ص.ب 19596، جدة 21445",
      },
    },
    direct: {
      kicker: { en: "Direct lines", ar: "خطوط مباشرة" },
      title: { en: "Reach a department", ar: "تواصل مع قسم" },
      items: [
        { label: { en: "General management", ar: "الإدارة العامة" }, email: "info@printopack.com.sa" },
        { label: { en: "Human resources", ar: "الموارد البشرية" }, email: "hr@printopack.com.sa" },
        { label: { en: "Marketing", ar: "التسويق" }, email: "mkt@printopack.com.sa", phone: "+966 531179791" },
      ],
    },
    portal: {
      kicker: { en: "Customers", ar: "العملاء" },
      title: { en: "Customer portal", ar: "بوابة العملاء" },
      text: {
        en: "Existing customers follow orders, statements and documents through the Printopack customer program.",
        ar: "يتابع عملاؤنا الحاليون الطلبات وكشوف الحساب والمستندات عبر برنامج عملاء برنتوباك.",
      },
      cta: { en: "Customer login", ar: "دخول العملاء" },
    },
  },
  // The enquiry window (id="enquire").
  enquire: {
    eyebrow: { en: "Write to us", ar: "راسلنا" },
    title: { en: "One window, routed to the right desk.", ar: "نافذةٌ واحدة، تُوجَّه إلى المكتب المناسب." },
    lede: {
      en: "Tell us what your message is about and where you are. We attach the right recipient automatically, so it reaches the correct team the first time.",
      ar: "أخبرنا بموضوع رسالتك وأين تتواجد. نُرفق المُستلِم الصحيح تلقائياً، لتصل إلى الفريق المناسب من أول مرة.",
    },
    pickLabel: { en: "Choose your market", ar: "اختر سوقك" },
    pickHint: { en: "Not sure on the map? Pick your country from the list.", ar: "لا تعرف موقعها على الخريطة؟ اختر دولتك من القائمة." },
    cardHint: { en: "Selected office", ar: "المكتب المختار" },
    officeNote: { en: "This office will receive your enquiry.", ar: "سيستلم هذا المكتب رسالتك." },
    careerNote: { en: "Career applications are handled by our Human Resources team.", ar: "تتولّى إدارة الموارد البشرية طلبات التوظيف." },
    autoTag: { en: "Automatic", ar: "تلقائي" },
    reasons: [
      { key: "general", label: { en: "General enquiry", ar: "استفسار عام" }, email: "info@printopack.com.sa" },
      { key: "sales", label: { en: "Sales & quotations", ar: "المبيعات وطلبات الأسعار" }, email: "mkt@printopack.com.sa" },
      { key: "marketing", label: { en: "Marketing & media", ar: "التسويق والإعلام" }, email: "mkt@printopack.com.sa" },
      { key: "careers", label: { en: "Careers", ar: "التوظيف" }, email: "hr@printopack.com.sa" },
    ],
    fields: {
      reason: { en: "What is it about?", ar: "ما موضوع رسالتك؟" },
      officeEmail: { en: "Office email", ar: "بريد المكتب" },
      officePhone: { en: "Office phone", ar: "هاتف المكتب" },
      name: { en: "Full name", ar: "الاسم الكامل" },
      email: { en: "Your email", ar: "بريدك الإلكتروني" },
      phone: { en: "Your phone (optional)", ar: "هاتفك (اختياري)" },
      company: { en: "Company / brand (optional)", ar: "الشركة / العلامة (اختياري)" },
      message: { en: "Your message", ar: "رسالتك" },
      cv: { en: "CV / résumé", ar: "السيرة الذاتية" },
      cover: { en: "Cover letter (optional)", ar: "خطاب التقديم (اختياري)" },
    },
    upload: { cta: { en: "Choose a file", ar: "اختر ملفاً" }, hint: { en: "PDF or Word", ar: "PDF أو Word" } },
    submit: { en: "Send enquiry", ar: "أرسل الرسالة" },
    composeLabel: { en: "Or open a draft in your email app", ar: "أو افتح مسودّة في تطبيق بريدك" },
    compose: { outlook: { en: "Outlook", ar: "أوتلوك" }, gmail: { en: "Gmail", ar: "جيميل" }, mail: { en: "Email app", ar: "تطبيق البريد" } },
    success: {
      en: "Thank you. Your enquiry has been sent and the right team will get back to you shortly.",
      ar: "شكراً لك. تم إرسال رسالتك وسيعاود الفريق المختص التواصل معك قريباً.",
    },
  },
  // Regional offices directory + counter. Amal's regional list = 10 offices (the number
  // she gave). Staff names are admin-filled placeholders (see note + PRODUCTION_TODO.md).
  offices: {
    eyebrow: { en: "Our offices", ar: "مكاتبنا" },
    title: { en: "Close to your market.", ar: "قريبون من سوقك." },
    saudiLabel: { en: "Saudi Arabia", ar: "المملكة العربية السعودية" },
    regionalLabel: { en: "Regional & export", ar: "الإقليمية والتصدير" },
    staffRole: { en: "Office manager", ar: "مدير المكتب" },
    saudi: saudiOffices,
    regional: regionalOffices,
    note: {
      en: "The office manager names shown here are samples; Printopack sets the real names through the site's admin.",
      ar: "أسماء مديري المكاتب المعروضة هنا عيّنات توضيحية؛ وتُدخل برنتوباك الأسماء الحقيقية عبر لوحة تحكم الموقع.",
    },
  },
};
const c = content;
const markets = marketOrder.map((cc) => ({ cc, ...officesByCc[cc] }));
---
<Base title={c.meta.title} description={c.meta.description}>
  <!-- PAGE HEADER -->
  <section class="page-head">
    <div class="wrap-wide">
      <div class="page-head-inner">
        <span class="eyebrow"><Bi en={c.header.eyebrow.en} ar={c.header.eyebrow.ar} /></span>
        <h1><Bi en={c.header.title.en} ar={c.header.title.ar} /></h1>
        <p class="lede"><Bi en={c.header.lede.en} ar={c.header.lede.ar} /></p>
      </div>
    </div>
  </section>

  <!-- STATS (right after the header) -->
  <section class="on-deep contact-stats">
    <div class="wrap-wide counters-row">
      {c.counters.map((n) => <Counter from={n.from} prefix={n.prefix} value={n.value} label={n.label.en} labelAr={n.label.ar} />)}
    </div>
  </section>

  <!-- GENERAL CONTACT CHANNELS -->
  <section class="channels">
    <div class="wrap-wide chan-grid">
      <div class="chan" data-reveal>
        <span class="chan-kicker"><Bi en={c.channels.hq.kicker.en} ar={c.channels.hq.kicker.ar} /></span>
        <h3><Bi en={c.channels.hq.title.en} ar={c.channels.hq.title.ar} /></h3>
        <p class="chan-addr">
          <span class="i18n-en" set:html={c.channels.hq.addr.en}></span><span class="i18n-ar" lang="ar" set:html={c.channels.hq.addr.ar}></span>
        </p>
        <a href="tel:+966126081074" class="chan-line" dir="ltr">+966 12 608 1074</a>
        <a href="mailto:info@printopack.com.sa" class="chan-line" dir="ltr">info@printopack.com.sa</a>
      </div>
      <div class="chan" data-reveal>
        <span class="chan-kicker"><Bi en={c.channels.direct.kicker.en} ar={c.channels.direct.kicker.ar} /></span>
        <h3><Bi en={c.channels.direct.title.en} ar={c.channels.direct.title.ar} /></h3>
        <ul class="chan-list">
          {c.channels.direct.items.map((it) => (
            <li>
              <span class="chan-list-label"><Bi en={it.label.en} ar={it.label.ar} /></span>
              <a href={`mailto:${it.email}`} dir="ltr">{it.email}</a>
              {it.phone && <a href={`tel:${it.phone.replace(/\s/g, '')}`} dir="ltr">{it.phone}</a>}
            </li>
          ))}
        </ul>
      </div>
      <div class="chan" data-reveal>
        <span class="chan-kicker"><Bi en={c.channels.portal.kicker.en} ar={c.channels.portal.kicker.ar} /></span>
        <h3><Bi en={c.channels.portal.title.en} ar={c.channels.portal.title.ar} /></h3>
        <p><Bi en={c.channels.portal.text.en} ar={c.channels.portal.text.ar} /></p>
        <a href="https://printopack.azurewebsites.net/" target="_blank" rel="noopener" class="btn btn-outline chan-cta"><Bi en={c.channels.portal.cta.en} ar={c.channels.portal.cta.ar} /></a>
      </div>
    </div>
  </section>

  <!-- ENQUIRY WINDOW: map + market pull-down + stable office card + routed form -->
  <section class="enquire" id="enquire" style="background:var(--cream)">
    <div class="wrap enquire-stack">
      <div class="enquire-head" data-reveal>
        <span class="eyebrow"><Bi en={c.enquire.eyebrow.en} ar={c.enquire.eyebrow.ar} /></span>
        <h2 style="margin:16px 0 16px"><Bi en={c.enquire.title.en} ar={c.enquire.title.ar} /></h2>
        <p class="lede"><Bi en={c.enquire.lede.en} ar={c.enquire.lede.ar} /></p>
      </div>

      <!-- reused reach map -->
      <div class="mapwrap" id="mapwrap">
        <svg class="reach-map" viewBox={reachMap.viewBox} role="group" aria-label="Map of the markets Printopack serves" preserveAspectRatio="xMidYMid meet">
          <path class="rc-ctx" d={reachMap.context} aria-hidden="true" />
          {Object.entries(reachMap.served).map(([cc, d]) => (
            <path class="rc" d={d} data-cc={cc} tabindex="0" role="button" aria-label={officesByCc[cc].name.en} />
          ))}
        </svg>
      </div>

      <!-- market pull-down, alongside the map (for visitors who don't know the geography) -->
      <div class="map-pick" id="map-pick">
        <label class="map-pick-inner">
          <span class="map-pick-label"><Bi en={c.enquire.pickLabel.en} ar={c.enquire.pickLabel.ar} /></span>
          <span class="select-wrap">
            <select class="market-select" aria-label={c.enquire.pickLabel.en}>
              {markets.map((m, i) => (
                <option value={m.cc} data-en={m.name.en} data-ar={m.name.ar} selected={i === 0}>{m.name.en}</option>
              ))}
            </select>
            <svg class="select-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
          </span>
        </label>
        <span class="map-pick-hint"><Bi en={c.enquire.pickHint.en} ar={c.enquire.pickHint.ar} /></span>
      </div>

      <!-- stable office card (was the floating popup): sits below the map, never moves -->
      <div class="office-card" id="office-card">
        <span class="oc-tag"><Bi en={c.enquire.cardHint.en} ar={c.enquire.cardHint.ar} /></span>
        <span class="oc-role"></span>
        <span class="oc-name"></span>
        <span class="oc-place"></span>
        <span class="oc-note"></span>
      </div>

      <!-- routed enquiry form -->
      <div class="enquire-formwrap">
        <p class="enquire-success" role="status" hidden><Bi en={c.enquire.success.en} ar={c.enquire.success.ar} /></p>
        <form class="enquire-form" name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" enctype="multipart/form-data" action="/contact?submitted=1#enquire">
          <input type="hidden" name="form-name" value="contact" />
          <!-- autonomous mapper: the resolved recipient + subject are attached on every change -->
          <input type="hidden" name="department" class="f-dept" value="General enquiry" />
          <input type="hidden" name="target_market" class="f-market" value="sa" />
          <input type="hidden" name="subject" class="f-subject" value="" />
          <p class="hp" hidden><label>Do not fill this in: <input name="bot-field" /></label></p>

          <label class="field">
            <span class="field-label"><Bi en={c.enquire.fields.reason.en} ar={c.enquire.fields.reason.ar} /></span>
            <span class="select-wrap">
              <select class="reason-select" aria-label={c.enquire.fields.reason.en}>
                {c.enquire.reasons.map((d, i) => (
                  <option value={d.key} data-email={d.email} data-en={d.label.en} data-ar={d.label.ar} selected={i === 0}>{d.label.en}</option>
                ))}
              </select>
              <svg class="select-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
            </span>
          </label>

          <!-- read-only, auto-filled office contact (unchangeable) -->
          <div class="field-row locked-row">
            <label class="field">
              <span class="field-label lock-label">
                <Bi en={c.enquire.fields.officeEmail.en} ar={c.enquire.fields.officeEmail.ar} />
                <span class="auto-tag"><Bi en={c.enquire.autoTag.en} ar={c.enquire.autoTag.ar} /></span>
              </span>
              <input class="locked f-route" name="route_email" type="text" value="info@printopack.com.sa" readonly tabindex="-1" dir="ltr" aria-readonly="true" />
            </label>
            <label class="field">
              <span class="field-label lock-label">
                <Bi en={c.enquire.fields.officePhone.en} ar={c.enquire.fields.officePhone.ar} />
                <span class="auto-tag"><Bi en={c.enquire.autoTag.en} ar={c.enquire.autoTag.ar} /></span>
              </span>
              <input class="locked f-ophone" name="office_phone" type="text" value="+966 12 608 1074" readonly tabindex="-1" dir="ltr" aria-readonly="true" />
            </label>
          </div>

          <label class="field">
            <span class="field-label"><Bi en={c.enquire.fields.name.en} ar={c.enquire.fields.name.ar} /></span>
            <input type="text" name="name" required placeholder={c.enquire.fields.name.en} data-ph-ar={c.enquire.fields.name.ar} />
          </label>
          <div class="field-row">
            <label class="field">
              <span class="field-label"><Bi en={c.enquire.fields.email.en} ar={c.enquire.fields.email.ar} /></span>
              <input type="email" name="email" required placeholder="name@example.com" dir="ltr" />
            </label>
            <label class="field">
              <span class="field-label"><Bi en={c.enquire.fields.phone.en} ar={c.enquire.fields.phone.ar} /></span>
              <input type="tel" name="phone" placeholder="+966 5X XXX XXXX" dir="ltr" />
            </label>
          </div>
          <label class="field">
            <span class="field-label"><Bi en={c.enquire.fields.company.en} ar={c.enquire.fields.company.ar} /></span>
            <input type="text" name="company" placeholder={c.enquire.fields.company.en} data-ph-ar={c.enquire.fields.company.ar} />
          </label>
          <label class="field">
            <span class="field-label"><Bi en={c.enquire.fields.message.en} ar={c.enquire.fields.message.ar} /></span>
            <textarea name="message" rows="4" required></textarea>
          </label>

          <!-- CAREER-ONLY: revealed when the reason is Careers (CV required + optional cover) -->
          <div class="career-fields" hidden>
            <p class="career-note"><Bi en={c.enquire.careerNote.en} ar={c.enquire.careerNote.ar} /></p>
            <label class="field">
              <span class="field-label"><Bi en={c.enquire.fields.cv.en} ar={c.enquire.fields.cv.ar} /></span>
              <span class="file-drop" data-file>
                <input type="file" name="cv" class="file-native cv-input" accept=".pdf,.doc,.docx" />
                <span class="file-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 16V4m0 0L7.5 8.5M12 4l4.5 4.5"/><path d="M4 15v3.5A1.5 1.5 0 0 0 5.5 20h13a1.5 1.5 0 0 0 1.5-1.5V15"/></svg>
                </span>
                <span class="file-copy">
                  <span class="file-cta"><Bi en={c.enquire.upload.cta.en} ar={c.enquire.upload.cta.ar} /></span>
                  <span class="file-hint"><Bi en={c.enquire.upload.hint.en} ar={c.enquire.upload.hint.ar} /></span>
                </span>
              </span>
            </label>
            <label class="field">
              <span class="field-label"><Bi en={c.enquire.fields.cover.en} ar={c.enquire.fields.cover.ar} /></span>
              <span class="file-drop" data-file>
                <input type="file" name="cover_letter" class="file-native" accept=".pdf,.doc,.docx" />
                <span class="file-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 16V4m0 0L7.5 8.5M12 4l4.5 4.5"/><path d="M4 15v3.5A1.5 1.5 0 0 0 5.5 20h13a1.5 1.5 0 0 0 1.5-1.5V15"/></svg>
                </span>
                <span class="file-copy">
                  <span class="file-cta"><Bi en={c.enquire.upload.cta.en} ar={c.enquire.upload.cta.ar} /></span>
                  <span class="file-hint"><Bi en={c.enquire.upload.hint.en} ar={c.enquire.upload.hint.ar} /></span>
                </span>
              </span>
            </label>
          </div>

          <button type="submit" class="btn btn-gold enquire-submit"><Bi en={c.enquire.submit.en} ar={c.enquire.submit.ar} /></button>

          <!-- open a pre-filled draft in the visitor's own mail app -->
          <div class="compose">
            <span class="compose-label"><Bi en={c.enquire.composeLabel.en} ar={c.enquire.composeLabel.ar} /></span>
            <div class="compose-btns">
              <button type="button" class="compose-btn" data-compose="outlook">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 7l9 6 9-6"/></svg>
                <Bi en={c.enquire.compose.outlook.en} ar={c.enquire.compose.outlook.ar} />
              </button>
              <button type="button" class="compose-btn" data-compose="gmail">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 7l9 6 9-6"/></svg>
                <Bi en={c.enquire.compose.gmail.en} ar={c.enquire.compose.gmail.ar} />
              </button>
              <button type="button" class="compose-btn" data-compose="mail">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 7l9 6 9-6"/></svg>
                <Bi en={c.enquire.compose.mail.en} ar={c.enquire.compose.mail.ar} />
              </button>
            </div>
          </div>
        </form>
      </div>
    </div>
  </section>

  <!-- OFFICES DIRECTORY -->
  <section class="on-navy offices-band">
    <div class="wrap-wide">
      <div class="section-head" data-reveal>
        <span class="eyebrow"><Bi en={c.offices.eyebrow.en} ar={c.offices.eyebrow.ar} /></span>
        <h2 style="margin-top:16px"><Bi en={c.offices.title.en} ar={c.offices.title.ar} /></h2>
      </div>

      <span class="office-group-label"><Bi en={c.offices.saudiLabel.en} ar={c.offices.saudiLabel.ar} /></span>
      <div class="office-grid">
        {c.offices.saudi.map((o) => (
          <div class="office" data-reveal>
            <h3><Bi en={o.city.en} ar={o.city.ar} /></h3>
            <span class="office-area"><Bi en={o.area.en} ar={o.area.ar} /></span>
            <span class="office-staff">
              <span class="staff-role"><Bi en={o.role ? o.role.en : c.offices.staffRole.en} ar={o.role ? o.role.ar : c.offices.staffRole.ar} /></span>
              <span class="staff-name"><Bi en={o.staff.en} ar={o.staff.ar} /></span>
            </span>
            <a href={`tel:${o.phone.replace(/\s/g, '')}`} dir="ltr">{o.phone}</a>
            <a href={`mailto:${o.email}`} dir="ltr">{o.email}</a>
          </div>
        ))}
      </div>

      <span class="office-group-label" style="margin-top:clamp(30px,4vw,48px)"><Bi en={c.offices.regionalLabel.en} ar={c.offices.regionalLabel.ar} /></span>
      <div class="office-grid">
        {c.offices.regional.map((o) => (
          <div class="office" data-reveal>
            <h3><Bi en={o.country.en} ar={o.country.ar} /></h3>
            <span class="office-staff">
              <span class="staff-role"><Bi en={o.role ? o.role.en : c.offices.staffRole.en} ar={o.role ? o.role.ar : c.offices.staffRole.ar} /></span>
              <span class="staff-name"><Bi en={o.staff.en} ar={o.staff.ar} /></span>
            </span>
            <a href={`tel:${o.phone.replace(/\s/g, '')}`} dir="ltr">{o.phone}</a>
            <a href={`mailto:${o.email}`} dir="ltr">{o.email}</a>
          </div>
        ))}
      </div>

      <!-- build-only helper: remove before production (see PRODUCTION_TODO.md) -->
      <p class="cnote"><Bi en={c.offices.note.en} ar={c.offices.note.ar} /></p>
    </div>
  </section>
</Base>

