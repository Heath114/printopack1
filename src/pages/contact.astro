<script define:vars={{ OFFICES: officesByCc, HR: hrOffice, NOTE: { en: c.enquire.officeNote.en, ar: c.enquire.officeNote.ar }, CAREER: { en: c.enquire.careerNote.en, ar: c.enquire.careerNote.ar } }}>
  // Enquiry window logic:
  //  - reason + market drive the "autonomous mapper": a resolved recipient (office email +
  //    phone) and a subject are written into the read-only fields + hidden fields on every
  //    change. Careers is handled centrally by HR: it swaps the locked contact to HR,
  //    disables the market picker + dims the map, and reveals the CV / cover-letter uploads.
  //  - the market pull-down (beside the map) and the map are two-way synced.
  //  - the compose buttons open a pre-filled draft (recipient + subject + body) in the
  //    visitor's Outlook / Gmail / default mail app.
  //  - ?office=<cc> (Partners popup) and ?reason=/&role= (legacy Careers) preselect + scroll.
  const scope = document.getElementById('enquire');
  const form = scope && scope.querySelector('.enquire-form');
  if (scope && form) {
    const reasonSel = form.querySelector('.reason-select');
    const marketSel = scope.querySelector('.market-select');
    const mapPick = document.getElementById('map-pick');
    const fRoute = form.querySelector('.f-route');
    const fOPhone = form.querySelector('.f-ophone');
    const fDept = form.querySelector('.f-dept');
    const fMarket = form.querySelector('.f-market');
    const fSubject = form.querySelector('.f-subject');
    const mapWrap = document.getElementById('mapwrap');
    const card = document.getElementById('office-card');
    const ocRole = card.querySelector('.oc-role');
    const ocName = card.querySelector('.oc-name');
    const ocPlace = card.querySelector('.oc-place');
    const ocNote = card.querySelector('.oc-note');
    const careerFields = form.querySelector('.career-fields');
    const cvInput = form.querySelector('.cv-input');
    const paths = Array.from(scope.querySelectorAll('.rc'));
    const lang = () => (document.documentElement.dir === 'rtl' ? 'ar' : 'en');
    const isCareers = () => reasonSel.value === 'careers';
    const currentOffice = () => (isCareers() ? HR : OFFICES[marketSel.value] || OFFICES.sa);

    const highlight = () => {
      const cc = marketSel.value;
      paths.forEach((p) => p.classList.toggle('active', !isCareers() && p.dataset.cc === cc));
    };
    const renderCard = () => {
      const o = currentOffice(); const L = lang();
      ocRole.textContent = o.role[L];
      ocName.textContent = o.name[L];
      ocPlace.textContent = (o.place && o.place[L]) ? o.place[L] : '';
      ocNote.textContent = isCareers() ? CAREER[L] : NOTE[L];
    };
    const sync = () => {
      const o = currentOffice();
      const r = reasonSel.selectedOptions[0];
      const m = marketSel.selectedOptions[0];
      fRoute.value = o.email;
      fOPhone.value = o.phone;
      fDept.value = r.dataset.en;
      fMarket.value = isCareers() ? '' : marketSel.value;
      fSubject.value = 'Website enquiry: ' + r.dataset.en + (!isCareers() && m ? ' (' + m.dataset.en + ')' : '');
    };
    const applyMode = () => {
      const careers = isCareers();
      careerFields.hidden = !careers;
      if (careers) cvInput.setAttribute('required', ''); else cvInput.removeAttribute('required');
      marketSel.disabled = careers;
      mapPick.classList.toggle('is-disabled', careers);
      mapWrap.classList.toggle('is-locked', careers);
    };
    const refresh = () => { applyMode(); highlight(); renderCard(); sync(); };

    reasonSel.addEventListener('change', refresh);
    marketSel.addEventListener('change', refresh);
    const pickMarket = (cc) => {
      if (isCareers()) return;
      const opt = Array.from(marketSel.options).find((o) => o.value === cc);
      if (opt) { marketSel.value = cc; refresh(); }
    };
    const bind = (el) => {
      el.addEventListener('click', (e) => { e.stopPropagation(); pickMarket(el.dataset.cc); });
      el.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); pickMarket(el.dataset.cc); } });
    };
    paths.forEach(bind);

    // modern upload dropzones: reflect the chosen filename
    scope.querySelectorAll('[data-file]').forEach((drop) => {
      const input = drop.querySelector('.file-native');
      const cta = drop.querySelector('.file-cta');
      const base = cta.textContent;
      input.addEventListener('change', () => {
        if (input.files && input.files.length) { cta.textContent = input.files[0].name; drop.classList.add('has-file'); }
        else { cta.textContent = base; drop.classList.remove('has-file'); }
      });
    });

    // open a pre-filled draft in the visitor's chosen mail app
    const val = (n) => (form.querySelector('[name="' + n + '"]')?.value || '').trim();
    const buildBody = () => {
      const m = marketSel.selectedOptions[0];
      const lines = ['Reason: ' + fDept.value];
      if (!isCareers() && m) lines.push('Market: ' + m.dataset.en);
      lines.push('Name: ' + val('name'), 'Email: ' + val('email'));
      if (val('phone')) lines.push('Phone: ' + val('phone'));
      if (val('company')) lines.push('Company: ' + val('company'));
      lines.push('', val('message'));
      return lines.join('\r\n');
    };
    scope.querySelectorAll('[data-compose]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const to = fRoute.value, su = fSubject.value, body = buildBody();
        const eS = encodeURIComponent(su), eB = encodeURIComponent(body), eT = encodeURIComponent(to);
        const kind = btn.dataset.compose;
        if (kind === 'gmail') {
          window.open('https://mail.google.com/mail/?view=cm&fs=1&to=' + eT + '&su=' + eS + '&body=' + eB, '_blank', 'noopener');
        } else if (kind === 'outlook') {
          window.open('https://outlook.office.com/mail/deeplink/compose?to=' + eT + '&subject=' + eS + '&body=' + eB, '_blank', 'noopener');
        } else {
          window.location.href = 'mailto:' + to + '?subject=' + eS + '&body=' + eB;
        }
      });
    });

    // bilingual <option> labels (both selects live under #enquire)
    const swapOptions = () => {
      const L = lang();
      scope.querySelectorAll('option[data-en]').forEach((o) => { o.textContent = L === 'ar' ? o.dataset.ar : o.dataset.en; });
    };
    new MutationObserver(() => { swapOptions(); renderCard(); sync(); })
      .observe(document.documentElement, { attributes: true, attributeFilter: ['dir', 'lang'] });
    swapOptions();

    // preselect from query params
    const qs = new URLSearchParams(location.search);
    const office = qs.get('office');
    const reason = qs.get('reason');
    const role = qs.get('role');
    const reasonMap = { general: 'general', quote: 'sales', sales: 'sales', marketing: 'marketing', careers: 'careers' };
    if (reason && reasonMap[reason]) reasonSel.value = reasonMap[reason];
    if (office && OFFICES[office] && reasonSel.value !== 'careers') marketSel.value = office;
    if (role) {
      const msg = form.querySelector('textarea[name="message"]');
      if (msg && !msg.value) msg.value = 'Regarding the "' + role + '" role.';
    }
    refresh();
    if (office || reason) {
      const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
      requestAnimationFrame(() => scope.scrollIntoView({ behavior: reduce ? 'auto' : 'smooth', block: 'start' }));
    }

    // Netlify redirects here with ?submitted=1 on success: show the thank-you, hide the form
    if (qs.get('submitted') === '1') {
      const ok = scope.querySelector('.enquire-success');
      if (ok) ok.hidden = false;
      form.hidden = true;
    }
  }
</script>
