---
import Base from '../layouts/Base.astro';

// Gallery. Photos use the client's real factory images as a starting set. Videos and
// advertisements are client-gated: the admin adds media and the grid fills out. The
// tile sizes vary to give the grid an editorial, magazine feel while staying still.
const media = [
  { img: "/images/dept-1.jpg", cap: "Rotogravure press", span: "wide" },
  { img: "/images/dept-4.jpg", cap: "Cylinder engraving" },
  { img: "/images/dept-2.jpg", cap: "Bag making" },
  { img: "/images/factory.jpg", cap: "The Jeddah plant", span: "tall" },
  { img: "/images/dept-3.jpg", cap: "Finishing line" },
  { img: "/images/lineup.jpg", cap: "Finished product", span: "wide" },
  { img: "/images/dept-5.jpg", cap: "Solvent recovery" },
];
---
<Base
  title="Gallery - Printopack"
  description="A look inside Printopack: photos from the Jeddah plant, our production lines and finished packaging. Videos and campaign work are added regularly."
>
  <!-- PAGE HEADER -->
  <section class="page-head">
    <div class="wrap-wide">
      <div class="page-head-inner">
        <span class="eyebrow">Gallery</span>
        <h1>Inside Printopack.</h1>
        <p class="lede">
          Photographs from the plant floor, our production lines and finished packaging. Videos and
          campaign material are added by our team and appear here as they are published.
        </p>
      </div>
    </div>
  </section>

  <!-- FILTER TABS (static labels for now) -->
  <section class="gal">
    <div class="wrap-wide">
      <div class="gal-tabs">
        <span class="gal-tab active">Photos</span>
        <span class="gal-tab">Videos</span>
        <span class="gal-tab">Advertisements</span>
      </div>
      <div class="gal-grid">
        {media.map((m) => (
          <figure class={"gal-item" + (m.span ? " " + m.span : "")}>
            <span class="card-img"><img src={m.img} alt={m.cap} loading="lazy" /></span>
            <figcaption>{m.cap}</figcaption>
          </figure>
        ))}
      </div>
      <p class="gal-note">Videos and advertisements are managed by Printopack and appear here once uploaded.</p>
    </div>
  </section>
</Base>

<style>
  .page-head{padding-block:clamp(56px,8vw,104px) clamp(30px,4vw,52px);background:var(--cream);border-bottom:1px solid var(--line)}
  .page-head-inner{max-width:820px}
  .page-head h1{margin:20px 0 22px;font-size:clamp(40px,6vw,78px)}
  .page-head .lede{max-width:60ch}

  .gal-tabs{display:flex;gap:10px;margin-bottom:36px;flex-wrap:wrap}
  .gal-tab{font-family:var(--display);font-size:12px;font-weight:500;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);border:1px solid var(--line);padding:11px 22px;border-radius:var(--radius)}
  .gal-tab.active{background:var(--navy);color:var(--paper);border-color:var(--navy)}

  .gal-grid{display:grid;grid-template-columns:repeat(3,1fr);grid-auto-rows:240px;gap:16px}
  .gal-item{position:relative;overflow:hidden;border-radius:var(--radius)}
  .gal-item .card-img{width:100%;height:100%}
  .gal-item.wide{grid-column:span 2}
  .gal-item.tall{grid-row:span 2}
  .gal-item figcaption{position:absolute;left:0;right:0;bottom:0;padding:14px 16px;font-family:var(--display);font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(--paper);background:linear-gradient(transparent,rgba(9,24,41,.72))}
  .gal-note{margin-top:32px;color:var(--faint);font-size:14px}
  @media(max-width:820px){.gal-grid{grid-template-columns:1fr 1fr;grid-auto-rows:200px}.gal-item.wide{grid-column:span 2}}
  @media(max-width:520px){.gal-grid{grid-template-columns:1fr;grid-auto-rows:220px}.gal-item.wide,.gal-item.tall{grid-column:auto;grid-row:auto}}
</style>
