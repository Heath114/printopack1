---
import Base from '../layouts/Base.astro';

// News & Events. The three articles below are the client's real posts (title, date,
// category from the live site). Excerpts are short editorial summaries and the full
// articles, plus the exhibition calendar, are managed in the admin CMS.
const posts = [
  {
    date: "10 Feb 2023", cat: "General", img: "/images/lineup.jpg",
    title: "The Future of Packaging in Saudi Arabia",
    excerpt: "How local manufacturing, sustainability targets and rising brand expectations are reshaping flexible packaging across the Kingdom.",
    featured: true,
  },
  {
    date: "06 May 2023", cat: "General", img: "/images/factory.jpg",
    title: "The Benefits of Flexible Packaging: Durability, Versatility and Eco-Friendliness",
    excerpt: "Why brands are moving to laminates and pouches: lighter formats, longer shelf life and a smaller material footprint.",
  },
  {
    date: "20 Jun 2022", cat: "General", img: "/images/dept-5.jpg",
    title: "PVC vs PET-G Shrink Films",
    excerpt: "A practical comparison of two common shrink-sleeve substrates, and how to choose between them for clarity, cost and recyclability.",
  },
];

const featured = posts.find((p) => p.featured) ?? posts[0];
const rest = posts.filter((p) => p !== featured);
---
<Base
  title="News & Events - Printopack"
  description="News, insight and exhibitions from Printopack: flexible-packaging trends, capabilities and where to meet our team across the region."
>
  <!-- PAGE HEADER -->
  <section class="page-head">
    <div class="wrap-wide">
      <div class="page-head-inner">
        <span class="eyebrow" data-reveal>News &amp; events</span>
        <h1 data-reveal>The latest from Printopack.</h1>
        <p class="lede" data-reveal>
          Insight on flexible packaging, updates from the factory floor and the exhibitions where
          you can meet our team.
        </p>
      </div>
    </div>
  </section>

  <!-- FEATURED ARTICLE -->
  <section class="featured-wrap">
    <div class="wrap-wide">
      <a href="/news" class="featured" data-reveal>
        <span class="featured-media"><img src={featured.img} alt={featured.title} fetchpriority="high" /></span>
        <span class="featured-body">
          <span class="post-meta">{featured.cat} · {featured.date}</span>
          <h2 class="featured-title">{featured.title}</h2>
          <p class="featured-excerpt">{featured.excerpt}</p>
          <span class="link-line">Read article</span>
        </span>
      </a>
    </div>
  </section>

  <!-- MORE ARTICLES -->
  <section style="padding-top:0">
    <div class="wrap-wide">
      <div class="section-head split-head">
        <div>
          <span class="eyebrow" data-reveal>More stories</span>
          <h2 data-reveal style="margin-top:16px">Recent articles</h2>
        </div>
      </div>
      <div class="news-grid">
        {rest.map((n) => (
          <a href="/news" class="card news-card" data-reveal>
            <span class="card-img news-img"><img src={n.img} alt="" loading="lazy" decoding="async" /></span>
            <span class="post-meta">{n.cat} · {n.date}</span>
            <h3 class="news-title">{n.title}</h3>
            <p class="news-excerpt">{n.excerpt}</p>
            <span class="link-line news-read">Read more</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- EVENTS & EXHIBITIONS -->
  <section class="on-navy events">
    <div class="wrap">
      <div class="events-grid">
        <div class="events-intro" data-reveal>
          <span class="eyebrow">Events &amp; exhibitions</span>
          <h2 style="margin:16px 0 18px">Meet us on the show floor.</h2>
          <p class="lede">
            Printopack takes part in the region's leading packaging, food and print exhibitions. Our
            upcoming schedule is published here through the season. To arrange a meeting or a factory
            visit in the meantime, get in touch.
          </p>
          <a href="/contact" class="btn btn-gold" style="margin-top:28px">Arrange a meeting</a>
        </div>
        <div class="events-note" data-reveal>
          <div class="events-card">
            <span class="events-kicker">Next up</span>
            <p class="events-empty">No events scheduled at the moment. Check back soon, or follow us on LinkedIn for announcements.</p>
            <a href="https://www.linkedin.com/company/80331793/" target="_blank" rel="noopener" class="link-line" style="color:var(--gold-bright);border-color:var(--gold-bright)">Follow on LinkedIn</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  /* page header (shared pattern with products) */
  .page-head{padding-block:clamp(56px,8vw,104px) clamp(30px,4vw,52px);background:var(--cream);border-bottom:1px solid var(--line)}
  .page-head-inner{max-width:820px}
  .page-head h1{margin:20px 0 22px;font-size:clamp(40px,6vw,78px)}
  .page-head .lede{max-width:58ch}

  .post-meta{display:block;font-family:var(--display);font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(--gold)}

  /* featured article */
  .featured-wrap{padding-bottom:clamp(48px,6vw,80px)}
  .featured{display:grid;grid-template-columns:1.15fr 1fr;gap:clamp(28px,4vw,64px);align-items:center}
  .featured-media{display:block;aspect-ratio:16/10;overflow:hidden;background:var(--cream)}
  .featured-media img{width:100%;height:100%;object-fit:cover}
  .featured-body{max-width:52ch}
  .featured-title{font-size:clamp(28px,3.4vw,46px);margin:14px 0 18px}
  .featured:hover .featured-title{color:var(--gold)}
  .featured-excerpt{font-size:clamp(16px,1.3vw,18px);color:var(--muted);line-height:1.65;margin-bottom:24px}

  /* article grid */
  .news-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:clamp(30px,4vw,54px);align-items:stretch}
  .news-card{display:flex;flex-direction:column}
  .news-img{aspect-ratio:16/10}
  .news-card .post-meta{margin-top:20px}
  .news-title{margin:10px 0 12px;font-size:clamp(21px,1.9vw,27px)}
  .news-card:hover .news-title{color:var(--gold)}
  .news-excerpt{color:var(--muted);font-size:15px;line-height:1.6;margin-bottom:18px}
  .news-read{font-size:12px;margin-top:auto;align-self:flex-start}

  /* events */
  .events-grid{display:grid;grid-template-columns:1.2fr 1fr;gap:clamp(34px,6vw,80px);align-items:center}
  .events-card{border:1px solid var(--line-dark);padding:clamp(28px,3vw,40px);background:rgba(250,246,238,.03)}
  .events-kicker{font-family:var(--display);font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:var(--gold-bright);display:block;margin-bottom:16px}
  .events-empty{color:rgba(250,246,238,.72);line-height:1.65;margin-bottom:22px}

  @media(max-width:900px){
    .featured{grid-template-columns:1fr;gap:22px}
    .featured-media{aspect-ratio:16/9}
    .news-grid{grid-template-columns:1fr;gap:40px}
    .events-grid{grid-template-columns:1fr;gap:32px}
  }
</style>
