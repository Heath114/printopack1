---
import Base from '../../layouts/Base.astro';
import Bi from '../../components/Bi.astro';
import { categories, filters } from '../../data/products';

// Product-group detail page (catalogue model, no cart): image + narrative + enquiry.
// One static page per group; copy comes from the shared data module and the bilingual
// block below, edited via the admin CMS in production. Individual products inside a
// group are client-added; this page presents the group and routes to a quote.

export function getStaticPaths() {
  return categories.map((c) => ({ params: { slug: c.slug }, props: { cat: c } }));
}

const { cat } = Astro.props;
const groupFilter = filters.find((f) => f.key === cat.group);
const related = categories.filter((c) => c.group === cat.group && c.slug !== cat.slug).slice(0, 3);
const more = related.length ? related : categories.filter((c) => c.slug !== cat.slug).slice(0, 3);
const quoteMail = `mailto:mkt@printopack.com.sa?subject=${encodeURIComponent(`Quote request: ${cat.name.en}`)}`;

const t = {
  note: {
    en: "Every structure in this range is made to order: we build the laminate, print and finish to your brief, so the pack on your shelf is yours alone.",
    ar: "كل تركيبٍ في هذه المجموعة يُصنع حسب الطلب: نبني التصفيح ونطبع وننهي وفق موجزكم، ليكون ما على رفّكم لكم وحدكم.",
  },
  meta: [
    { en: "Price on request", ar: "السعر عند الطلب" },
    { en: "Made to order", ar: "يُصنع حسب الطلب" },
    { en: "Offered by consultation", ar: "يُقدَّم بالاستشارة" },
  ],
  quote: { en: "Request a quote", ar: "اطلب عرض سعر" },
  talk: { en: "Talk to our team", ar: "تحدّث إلى فريقنا" },
  crumb: { en: "Products", ar: "المنتجات" },
  standard: {
    eyebrow: { en: "The Printopack standard", ar: "معيار برنتوباك" },
    title: { en: "What every order includes.", ar: "ما يشمله كل طلب." },
    items: [
      { t: { en: "Developed for your line", ar: "مطوّر لخطكم" }, d: { en: "Structure, barrier and seal are engineered around your product and your filling equipment, not a catalogue item.", ar: "يُهندَس التركيب والحاجز والغلق حول منتجكم ومعدات التعبئة لديكم، لا كصنفٍ جاهز من كتالوج." } },
      { t: { en: "Printed in-house", ar: "مطبوع داخلياً" }, d: { en: "Rotogravure print with cylinders engraved under our own roof, from artwork to press without hand-offs.", ar: "طباعة روتوغرافير بأسطوانات تُحفر تحت سقفنا، من التصميم إلى الطباعة دون وسطاء." } },
      { t: { en: "Food-safe by default", ar: "آمن غذائياً بطبيعته" }, d: { en: "Food-grade materials and a quality system that follows every order from laminate to delivery.", ar: "مواد ملائمة للأغذية ونظام جودة يرافق كل طلبٍ من التصفيح حتى التسليم." } },
    ],
  },
  more: {
    eyebrow: { en: "Keep browsing", ar: "تابع التصفّح" },
    titleRelated: { en: "More in this range.", ar: "المزيد في هذه المجموعة." },
    titleAll: { en: "More from the catalogue.", ar: "المزيد من الكتالوج." },
    link: { en: "View & enquire", ar: "عرض واستفسار" },
    allLabel: { en: "product groups", ar: "مجموعة منتجات" },
    allCta: { en: "View all products", ar: "عرض كل المنتجات" },
  },
};
---
<Base
  title={`${cat.name.en} - Products - Printopack`}
  description={`${cat.desc.en} Made to order in Jeddah and offered by consultation.`}
>
  <!-- BREADCRUMB -->
  <nav class="crumbs" aria-label="Breadcrumb">
    <div class="wrap-wide">
      <a href="/products"><Bi en={t.crumb.en} ar={t.crumb.ar} /></a>
      <span aria-hidden="true">/</span>
      <span class="crumb-here"><Bi en={cat.name.en} ar={cat.name.ar} /></span>
    </div>
  </nav>

  <!-- GROUP -->
  <section class="pdp">
    <div class="wrap-wide pdp-grid">
      <div class="pdp-media">
        <img src={cat.img} alt={cat.name.en} decoding="async" />
      </div>
      <div class="pdp-info">
        {groupFilter && <span class="eyebrow"><Bi en={groupFilter.label.en} ar={groupFilter.label.ar} /></span>}
        <h1><Bi en={cat.name.en} ar={cat.name.ar} /></h1>
        <p class="lede"><Bi en={cat.desc.en} ar={cat.desc.ar} /></p>
        <p class="pdp-note"><Bi en={t.note.en} ar={t.note.ar} /></p>

        <div class="pdp-meta">
          {t.meta.map((m) => <span><Bi en={m.en} ar={m.ar} /></span>)}
        </div>

        <div class="pdp-actions">
          <a href={quoteMail} class="btn btn-gold"><Bi en={t.quote.en} ar={t.quote.ar} /></a>
          <a href="/contact" class="link-line"><Bi en={t.talk.en} ar={t.talk.ar} /></a>
        </div>
      </div>
    </div>
  </section>

  <!-- THE PRINTOPACK STANDARD -->
  <section class="on-navy pdp-standard">
    <div class="wrap">
      <div class="section-head">
        <span class="eyebrow"><Bi en={t.standard.eyebrow.en} ar={t.standard.eyebrow.ar} /></span>
        <h2 style="margin-top:16px"><Bi en={t.standard.title.en} ar={t.standard.title.ar} /></h2>
      </div>
      <div class="std-grid">
        {t.standard.items.map((s) => (
          <div class="std-item">
            <h3><Bi en={s.t.en} ar={s.t.ar} /></h3>
            <p><Bi en={s.d.en} ar={s.d.ar} /></p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- MORE IN THIS RANGE -->
  <section class="pdp-more">
    <div class="wrap-wide">
      <div class="more-head">
        <span class="eyebrow"><Bi en={t.more.eyebrow.en} ar={t.more.eyebrow.ar} /></span>
        {related.length
          ? <h2 style="margin-top:14px"><Bi en={t.more.titleRelated.en} ar={t.more.titleRelated.ar} /></h2>
          : <h2 style="margin-top:14px"><Bi en={t.more.titleAll.en} ar={t.more.titleAll.ar} /></h2>}
      </div>
      <div class="more-grid">
        {more.map((c) => (
          <a href={`/products/${c.slug}`} class="more-card">
            <span class="more-img"><img src={c.img} alt={c.name.en} loading="lazy" decoding="async" /></span>
            <span class="more-name"><Bi en={c.name.en} ar={c.name.ar} /></span>
            <span class="more-link"><Bi en={t.more.link.en} ar={t.more.link.ar} /></span>
          </a>
        ))}
        <a href="/products" class="more-card more-all">
          <span class="more-all-inner">
            <span class="more-all-count">{categories.length}</span>
            <span class="more-all-label"><Bi en={t.more.allLabel.en} ar={t.more.allLabel.ar} /></span>
            <span class="link-line"><Bi en={t.more.allCta.en} ar={t.more.allCta.ar} /></span>
          </span>
        </a>
      </div>
    </div>
  </section>
</Base>

<style>
  .crumbs{border-bottom:1px solid var(--line-soft);background:var(--cream)}
  .crumbs > div{display:flex;align-items:center;gap:12px;padding-block:14px;font-family:var(--display);font-size:12px;letter-spacing:.14em;text-transform:uppercase}
  .crumbs a{color:var(--muted)}
  .crumbs a:hover{color:var(--gold)}
  .crumbs span[aria-hidden]{color:var(--faint)}
  .crumb-here{color:var(--navy)}

  .pdp{padding-block:clamp(40px,5vw,72px) var(--section-y)}
  .pdp-grid{display:grid;grid-template-columns:1.1fr 1fr;gap:clamp(34px,6vw,90px);align-items:start}
  .pdp-media{background:var(--cream);border:1px solid var(--line);position:sticky;top:170px}
  .pdp-media img{width:100%;aspect-ratio:4/3;object-fit:contain;padding:clamp(24px,3vw,48px);mix-blend-mode:multiply}
  .pdp-info h1{font-size:clamp(36px,4.6vw,62px);margin:18px 0 20px}
  .pdp-note{font-size:15px;color:var(--muted);line-height:1.7;margin-top:18px;max-width:52ch}

  .pdp-meta{display:flex;flex-wrap:wrap;gap:8px 22px;margin-top:26px;padding-top:22px;border-top:1px solid var(--line)}
  .pdp-meta span{font-family:var(--display);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--faint)}

  .pdp-actions{display:flex;align-items:center;gap:28px;margin-top:30px;flex-wrap:wrap}

  .pdp-standard{padding-block:clamp(56px,7vw,96px)}
  .std-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:clamp(26px,4vw,52px);margin-top:clamp(26px,3vw,40px)}
  .std-item{border-top:1px solid var(--line-dark);padding-top:22px}
  .std-item h3{font-size:clamp(19px,1.8vw,24px);color:var(--paper);margin-bottom:10px}
  .std-item p{font-size:14.5px;color:rgba(250,246,238,.72);line-height:1.65}

  .pdp-more{border-top:1px solid var(--line-soft)}
  .more-head{margin-bottom:clamp(28px,4vw,44px)}
  .more-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:clamp(18px,2vw,30px)}
  .more-card{display:flex;flex-direction:column;border:1px solid var(--line);background:var(--paper)}
  .more-card:hover{border-color:var(--sand);box-shadow:0 20px 38px rgba(14,35,64,.07)}
  .more-img{display:block;aspect-ratio:4/3;background:var(--cream);overflow:hidden}
  .more-img img{width:100%;height:100%;object-fit:contain;padding:18px;mix-blend-mode:multiply}
  .more-name{font-family:var(--display);font-size:17px;padding:16px 18px 4px;color:var(--ink)}
  .more-link{font-family:var(--display);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--faint);padding:0 18px 18px}
  .more-card:hover .more-link{color:var(--gold)}
  .more-all{align-items:center;justify-content:center;background:var(--cream);text-align:center}
  .more-all-inner{display:flex;flex-direction:column;align-items:center;gap:6px;padding:24px}
  .more-all-count{font-family:var(--display);font-size:clamp(38px,4vw,54px);font-weight:300;color:var(--navy);line-height:1}
  .more-all-label{font-family:var(--display);font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);margin-bottom:10px}

  @media(max-width:920px){
    .pdp-grid{grid-template-columns:1fr;gap:30px}
    .pdp-media{position:static}
    .std-grid{grid-template-columns:1fr;gap:0}
    .std-item{padding-block:22px}
    .more-grid{grid-template-columns:repeat(2,1fr)}
  }
  @media(max-width:520px){
    .more-grid{grid-template-columns:1fr}
  }
</style>
