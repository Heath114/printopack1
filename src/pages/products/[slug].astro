---
import Base from '../../layouts/Base.astro';
import { categories, groupLabel } from '../../data/products';

// Category detail page (Grove PDP model, no cart): image + narrative + typical
// formats + enquiry. One static page per category; copy comes from the shared
// data module and is edited via the admin CMS in production.

export function getStaticPaths() {
  return categories.map((c) => ({ params: { slug: c.slug }, props: { cat: c } }));
}

const { cat } = Astro.props;
const related = categories.filter((c) => c.group === cat.group && c.slug !== cat.slug).slice(0, 3);
const more = related.length
  ? related
  : categories.filter((c) => c.slug !== cat.slug).slice(0, 3);
const quoteMail = `mailto:mkt@printopack.com.sa?subject=${encodeURIComponent(`Quote request: ${cat.name}`)}`;

const standard = [
  { t: "Developed for your line", d: "Structure, barrier and seal are engineered around your product and your filling equipment, not a catalogue item." },
  { t: "Printed in-house", d: "Rotogravure print with cylinders engraved under our own roof, from artwork to press without hand-offs." },
  { t: "Food-safe by default", d: "Food-grade materials and a quality system that follows every order from laminate to delivery." },
];
---
<Base
  title={`${cat.name} - Products - Printopack`}
  description={`${cat.desc} Made to order in Jeddah and offered by consultation.`}
>
  <!-- BREADCRUMB -->
  <nav class="crumbs" aria-label="Breadcrumb">
    <div class="wrap-wide">
      <a href="/products">Products</a>
      <span aria-hidden="true">/</span>
      <span class="crumb-here">{cat.name}</span>
    </div>
  </nav>

  <!-- PRODUCT -->
  <section class="pdp">
    <div class="wrap-wide pdp-grid">
      <div class="pdp-media" data-reveal>
        <img src={cat.img} alt={cat.name} decoding="async" />
      </div>
      <div class="pdp-info">
        <span class="eyebrow" data-reveal>{groupLabel(cat.group)}</span>
        <h1 data-reveal>{cat.name}</h1>
        <p class="lede" data-reveal>{cat.desc}</p>
        <p class="pdp-note" data-reveal>
          Every structure in this range is made to order: we build the laminate, print and
          finish to your brief, so the pack on your shelf is yours alone.
        </p>

        <div class="pdp-formats" data-reveal>
          <span class="pdp-kicker">Typical formats</span>
          <ul>
            {cat.formats.map((f) => <li>{f}</li>)}
          </ul>
        </div>

        <div class="pdp-meta" data-reveal>
          <span>Price on request</span>
          <span>Made to order</span>
          <span>Offered by consultation</span>
        </div>

        <div class="pdp-actions" data-reveal>
          <a href={quoteMail} class="btn btn-gold">Request a quote</a>
          <a href="/contact" class="link-line">Talk to our team</a>
        </div>
      </div>
    </div>
  </section>

  <!-- THE PRINTOPACK STANDARD -->
  <section class="on-navy pdp-standard">
    <div class="wrap">
      <div class="section-head" data-reveal>
        <span class="eyebrow">The Printopack standard</span>
        <h2 style="margin-top:16px">What every order includes.</h2>
      </div>
      <div class="std-grid">
        {standard.map((s) => (
          <div class="std-item" data-reveal>
            <h3>{s.t}</h3>
            <p>{s.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- MORE IN THIS RANGE -->
  <section class="pdp-more">
    <div class="wrap-wide">
      <div class="more-head" data-reveal>
        <span class="eyebrow">Keep browsing</span>
        <h2 style="margin-top:14px">{related.length ? "More in this range." : "More from the catalogue."}</h2>
      </div>
      <div class="more-grid">
        {more.map((c) => (
          <a href={`/products/${c.slug}`} class="more-card" data-reveal>
            <span class="more-img"><img src={c.img} alt={c.name} loading="lazy" decoding="async" /></span>
            <span class="more-name">{c.name}</span>
            <span class="more-link">View &amp; enquire</span>
          </a>
        ))}
        <a href="/products" class="more-card more-all" data-reveal>
          <span class="more-all-inner">
            <span class="more-all-count">20</span>
            <span class="more-all-label">product categories</span>
            <span class="link-line">View all products</span>
          </span>
        </a>
      </div>
    </div>
  </section>
</Base>

<style>
  /* breadcrumb */
  .crumbs{border-bottom:1px solid var(--line-soft);background:var(--cream)}
  .crumbs > div{display:flex;align-items:center;gap:12px;padding-block:14px;font-family:var(--display);font-size:12px;letter-spacing:.14em;text-transform:uppercase}
  .crumbs a{color:var(--muted)}
  .crumbs a:hover{color:var(--gold)}
  .crumbs span[aria-hidden]{color:var(--faint)}
  .crumb-here{color:var(--navy)}

  /* pdp layout */
  .pdp{padding-block:clamp(40px,5vw,72px) var(--section-y)}
  .pdp-grid{display:grid;grid-template-columns:1.1fr 1fr;gap:clamp(34px,6vw,90px);align-items:start}
  .pdp-media{background:var(--cream);border:1px solid var(--line);position:sticky;top:170px}
  .pdp-media img{width:100%;aspect-ratio:4/3;object-fit:contain;padding:clamp(24px,3vw,48px);mix-blend-mode:multiply}
  .pdp-info h1{font-size:clamp(36px,4.6vw,62px);margin:18px 0 20px}
  .pdp-note{font-size:15px;color:var(--muted);line-height:1.7;margin-top:18px;max-width:52ch}

  .pdp-kicker{font-family:var(--display);font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);display:block;margin-bottom:12px}
  .pdp-formats{margin-top:34px;border-top:1px solid var(--line);padding-top:24px}
  .pdp-formats ul{display:flex;flex-wrap:wrap;gap:10px}
  .pdp-formats li{font-family:var(--display);font-size:13px;letter-spacing:.06em;color:var(--navy);border:1px solid var(--line);padding:9px 16px;border-radius:var(--radius);background:var(--paper)}

  .pdp-meta{display:flex;flex-wrap:wrap;gap:8px 22px;margin-top:26px;padding-top:22px;border-top:1px solid var(--line)}
  .pdp-meta span{font-family:var(--display);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--faint)}

  .pdp-actions{display:flex;align-items:center;gap:28px;margin-top:30px;flex-wrap:wrap}

  /* standard band */
  .pdp-standard{padding-block:clamp(56px,7vw,96px)}
  .std-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:clamp(26px,4vw,52px);margin-top:clamp(26px,3vw,40px)}
  .std-item{border-top:1px solid var(--line-dark);padding-top:22px}
  .std-item h3{font-size:clamp(19px,1.8vw,24px);color:var(--paper);margin-bottom:10px}
  .std-item p{font-size:14.5px;color:rgba(250,246,238,.72);line-height:1.65}

  /* more grid */
  .pdp-more{border-top:1px solid var(--line-soft)}
  .more-head{margin-bottom:clamp(28px,4vw,44px)}
  .more-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:clamp(18px,2vw,30px)}
  .more-card{display:flex;flex-direction:column;border:1px solid var(--line);background:var(--paper)}
  .more-card:hover{border-color:var(--sand);box-shadow:0 20px 38px rgba(14,35,64,.07)}
  .more-img{display:block;aspect-ratio:4/3;background:var(--cream);overflow:hidden}
  .more-img img{width:100%;height:100%;object-fit:contain;padding:18px;mix-blend-mode:multiply}
  .more-name{font-family:var(--display);font-size:17px;padding:16px 18px 4px;color:var(--ink)}
  .more-link{font-family:var(--display);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--faint);padding:0 18px 18px}
  .more-card:hover .more-link{color:var(--gold)}
  .more-all{align-items:center;justify-content:center;background:var(--cream);text-align:center}
  .more-all-inner{display:flex;flex-direction:column;align-items:center;gap:6px;padding:24px}
  .more-all-count{font-family:var(--display);font-size:clamp(38px,4vw,54px);font-weight:300;color:var(--navy);line-height:1}
  .more-all-label{font-family:var(--display);font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);margin-bottom:10px}

  @media(max-width:920px){
    .pdp-grid{grid-template-columns:1fr;gap:30px}
    .pdp-media{position:static}
    .std-grid{grid-template-columns:1fr;gap:0}
    .std-item{padding-block:22px}
    .more-grid{grid-template-columns:repeat(2,1fr)}
  }
  @media(max-width:520px){
    .more-grid{grid-template-columns:1fr}
  }
</style>
