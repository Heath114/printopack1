---
import Base from '../layouts/Base.astro';
import Counter from '../components/Counter.astro';
import Bi from '../components/Bi.astro';
const year = new Date().getFullYear();

// ── EDITABLE CONTENT (bilingual) ─────────────────────────────────────────────
// Factory Departments (Nasser's Page 1 subsection). Department NAMES and PHOTOS are
// real, pulled from the live site's gallery (Rotogravure, Cylinder Engraving, Bagging
// Machine, Punching Machine, Solvent Recovery) plus Warehouses. Descriptions are brief
// factual notes on each real process, editable by the client. Arabic is natural fusha.
const content = {
  meta: {
    title: "Factory Departments - Printopack",
    description: "Inside the Printopack plant in Jeddah: rotogravure printing, in-house cylinder engraving, bag making, punching, solvent recovery and warehousing, all under one roof.",
  },
  header: {
    eyebrow: { en: "Factory departments", ar: "أقسام المصنع" },
    title: { en: "Everything, under one roof.", ar: "كل شيء تحت سقفٍ واحد." },
    lede: {
      en: "From engraved cylinder to finished reel, every stage of production happens inside our Jeddah facility. That means faster proofs, tighter quality control and packaging built exactly to your specification.",
      ar: "من الأسطوانة المحفورة إلى اللفّة النهائية، تجري كل مراحل الإنتاج داخل مصنعنا في جدة، بما يعني بروفات أسرع، ورقابة جودة أدقّ، وتغليفاً مبنياً على مواصفاتكم بالضبط.",
    },
  },
  counters: [
    { value: 5, label: { en: "Production departments", ar: "أقسام إنتاجية" } },
    { from: 1997, value: year, label: { en: "Manufacturing since 1997", ar: "التصنيع منذ 1997" } },
    { prefix: "~", value: 400, label: { en: "People on the floor", ar: "عامل في المصنع" } },
  ],
  departments: {
    eyebrow: { en: "The production line", ar: "خط الإنتاج" },
    title: { en: "Our departments", ar: "أقسامنا" },
    lede: {
      en: "Each stage is a department in its own right, staffed and equipped to hold the Printopack standard.",
      ar: "كل مرحلة قسمٌ قائم بذاته، مجهّز بطاقمه ومعدّاته للحفاظ على معيار برنتوباك.",
    },
    items: [
      { img: "/images/factory-rotogravure.jpg", name: { en: "Rotogravure", ar: "الطباعة الروتوغرافية" }, desc: { en: "High-volume, multi-colour rotogravure printing from engraved cylinders.", ar: "طباعة روتوغرافية متعددة الألوان وعالية الإنتاجية من أسطوانات محفورة." } },
      { img: "/images/factory-engraving.jpg", name: { en: "Cylinder Engraving", ar: "حفر الأسطوانات" }, desc: { en: "In-house engraving of the cylinders used on the press.", ar: "حفر الأسطوانات المستخدمة في الطباعة داخل المصنع." } },
      { img: "/images/factory-bagging.jpg", name: { en: "Bagging Machine", ar: "صناعة الأكياس" }, desc: { en: "Converting printed film into bags and pouches.", ar: "تحويل الأفلام المطبوعة إلى أكياس وعبوات." } },
      { img: "/images/factory-punching.jpg", name: { en: "Punching Machine", ar: "التخريم والتشطيب" }, desc: { en: "Punching and finishing to final specification.", ar: "التخريم والتشطيب حتى المواصفات النهائية." } },
      { img: "/images/factory-solvent.jpg", name: { en: "Solvent Recovery", ar: "استرجاع المذيبات" }, desc: { en: "In-line recovery and reuse of solvents.", ar: "استرجاع المذيبات وإعادة استخدامها ضمن الخط." } },
      { img: "", name: { en: "Warehouses", ar: "المستودعات" }, desc: { en: "Storage for raw material and finished goods.", ar: "تخزين المواد الخام والمنتجات النهائية." } },
    ],
  },
  cta: {
    eyebrow: { en: "See it for yourself", ar: "شاهدها بنفسك" },
    title: { en: "Bring us your brief.", ar: "أرسل لنا مشروعك." },
    button: { en: "Request a quote", ar: "اطلب عرض سعر" },
  },
};
const c = content;
---
<Base title={c.meta.title} description={c.meta.description}>
  <!-- PAGE HEADER -->
  <section class="page-head">
    <div class="wrap-wide">
      <div class="page-head-inner">
        <span class="eyebrow"><Bi en={c.header.eyebrow.en} ar={c.header.eyebrow.ar} /></span>
        <h1><Bi en={c.header.title.en} ar={c.header.title.ar} /></h1>
        <p class="lede"><Bi en={c.header.lede.en} ar={c.header.lede.ar} /></p>
      </div>
    </div>
  </section>

  <!-- COUNTERS -->
  <section class="on-deep fac-stats">
    <div class="wrap-wide counters-row">
      {c.counters.map((n) => <Counter from={n.from} prefix={n.prefix} value={n.value} label={n.label.en} labelAr={n.label.ar} />)}
    </div>
  </section>

  <!-- DEPARTMENTS -->
  <section class="depts">
    <div class="wrap-wide">
      <div class="section-head">
        <span class="eyebrow"><Bi en={c.departments.eyebrow.en} ar={c.departments.eyebrow.ar} /></span>
        <h2><Bi en={c.departments.title.en} ar={c.departments.title.ar} /></h2>
        <p class="lede"><Bi en={c.departments.lede.en} ar={c.departments.lede.ar} /></p>
      </div>
      <div class="dept-list">
        {c.departments.items.map((d, i) => (
          <article class={"dept-row" + (i % 2 ? " reverse" : "")}>
            <div class="dept-media">
              <div class="card-img">
                {d.img
                  ? <img src={d.img} alt={d.name.en} />
                  : <span class="img-ph" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25"><path d="M3 9l9-5 9 5v11H3z"/><path d="M3 9h18M9 20v-6h6v6"/></svg></span>}
              </div>
            </div>
            <div class="dept-body">
              <span class="dept-num">{String(i + 1).padStart(2, "0")}</span>
              <h3><Bi en={d.name.en} ar={d.name.ar} /></h3>
              <p><Bi en={d.desc.en} ar={d.desc.ar} /></p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="on-navy fac-cta">
    <div class="wrap" style="text-align:center">
      <span class="eyebrow plain" style="color:var(--gold-bright)"><Bi en={c.cta.eyebrow.en} ar={c.cta.eyebrow.ar} /></span>
      <h2 style="margin:14px 0 26px"><Bi en={c.cta.title.en} ar={c.cta.title.ar} /></h2>
      <a href="/contact" class="btn btn-gold"><Bi en={c.cta.button.en} ar={c.cta.button.ar} /></a>
    </div>
  </section>
</Base>

<style>
  .page-head{padding-block:clamp(56px,8vw,104px) clamp(30px,4vw,52px);background:var(--cream);border-bottom:1px solid var(--line)}
  .page-head-inner{max-width:820px}
  .page-head h1{margin:20px 0 22px;font-size:clamp(40px,6vw,78px)}
  .page-head .lede{max-width:60ch}

  .counters-row{display:grid;grid-template-columns:repeat(3,1fr);gap:32px}
  @media(max-width:640px){.counters-row{grid-template-columns:1fr;gap:40px}}

  .dept-list{display:flex;flex-direction:column;gap:clamp(48px,7vw,96px)}
  .dept-row{display:grid;grid-template-columns:1.1fr 1fr;gap:clamp(32px,5vw,72px);align-items:center}
  .dept-row.reverse .dept-media{order:2}
  .dept-media .card-img{aspect-ratio:4/3;border-radius:var(--radius)}
  .img-ph{display:grid;place-items:center;width:100%;height:100%;background:var(--cream);color:var(--faint);border:1px dashed var(--line)}
  .img-ph svg{width:56px;height:56px}
  .dept-num{font-family:var(--display);font-size:14px;font-weight:500;letter-spacing:.2em;color:var(--gold)}
  .dept-body h3{margin:14px 0 16px}
  .dept-body p{color:var(--muted);max-width:52ch}
  @media(max-width:820px){.dept-row,.dept-row.reverse{grid-template-columns:1fr;gap:24px}.dept-row.reverse .dept-media{order:0}}
</style>
