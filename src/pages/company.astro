---
import Base from '../layouts/Base.astro';
import Counter from '../components/Counter.astro';
import Bi from '../components/Bi.astro';
const year = new Date().getFullYear();

// ── EDITABLE CONTENT (bilingual) ─────────────────────────────────────────────
// Each visible string is { en, ar }. The English vision/mission is the client's real
// text; their live site has no Arabic body, so the Arabic here is a natural, Arabic-
// first fusha rendering (not a literal translation), flagged for the client to approve.
const content = {
  meta: {
    title: "The Company - Printopack",
    description: "Printopack, the Saudi Modern Packaging Factory, has produced responsible flexible packaging in Jeddah since 1997. Our history, vision, mission and values.",
  },
  header: {
    eyebrow: { en: "The company", ar: "الشركة" },
    title: { en: "The company behind the packaging.", ar: "الشركة التي تقف وراء التغليف." },
    lede: {
      en: "Printopack, the Saudi Modern Packaging Factory, has developed and produced responsible flexible packaging from Jeddah since 1997, for food, beverage, pharmaceutical and consumer brands across the region and beyond.",
      ar: "برنتوباك، مصنع التغليف السعودي الحديث، تطوّر وتنتج تغليفاً مرناً ومسؤولاً من جدة منذ عام 1997، لعلامات الأغذية والمشروبات والأدوية والسلع الاستهلاكية في المنطقة وخارجها.",
    },
  },
  counters: [
    { from: 1997, value: year, label: { en: "In the market since 1997", ar: "في السوق منذ 1997" } },
    { prefix: "+", value: 35, label: { en: "Countries served", ar: "دولة نخدمها" } },
    { prefix: "~", value: 400, label: { en: "Team members", ar: "عضو في الفريق" } },
    { value: 10, label: { en: "Regional offices", ar: "مكاتب إقليمية" } },
  ],
  history: {
    eyebrow: { en: "Our history", ar: "تاريخنا" },
    title: { en: "From one line in 1997 to brands across 35 countries.", ar: "من خطٍّ واحد عام 1997 إلى علاماتٍ في 35 دولة." },
    image: "/images/factory.jpg",
    imageAlt: "The Printopack plant in Jeddah",
    paragraphs: [
      {
        en: "Printopack, the trading name of Saudi Modern Packaging Factory Co. Ltd., was established in 1997 in Jeddah. What began as a single flexible-packaging operation has grown into a full service converter, with in-house rotogravure printing, cylinder engraving, bag making, finishing and solvent recovery, all under one roof.",
        ar: "تأسّست برنتوباك، الاسم التجاري لمصنع التغليف السعودي الحديث المحدود، عام 1997 في جدة. وما بدأ كخطٍّ واحد للتغليف المرن نما ليصبح مصنعاً متكامل الخدمات يضمّ الطباعة الروتوغرافية وحفر الأسطوانات وصناعة الأكياس والتشطيب واسترجاع المذيبات، جميعها تحت سقفٍ واحد.",
      },
      {
        en: "Today the company is family-owned and Saudi-operated, serving food, beverage, pharmaceutical and consumer brands across more than 35 countries through ten regional offices. Ownership and the full founding story are added by Printopack through the site's admin.",
        ar: "واليوم، تملك الشركةَ عائلةٌ وتُدار سعودياً، وتخدم علامات الأغذية والمشروبات والأدوية والسلع الاستهلاكية في أكثر من 35 دولة عبر عشرة مكاتب إقليمية. وتُضيف برنتوباك تفاصيل الملكية وقصة التأسيس الكاملة عبر لوحة تحكم الموقع.",
      },
    ],
  },
  vision: {
    eyebrow: { en: "Our vision", ar: "رؤيتنا" },
    title: { en: "Empowering brands through creative packaging excellence.", ar: "تمكين العلامات التجارية عبر التميّز الإبداعي في التغليف." },
    paragraphs: [
      {
        en: "Printopack's vision is to redefine packaging as a transformative brand experience, fostering a sustainable and captivating future for industries worldwide. Our dedication to innovative solutions and responsible practices will shape a world where packaging becomes an enduring testament to brand values and consumer trust.",
        ar: "تسعى رؤية برنتوباك إلى إعادة تعريف التغليف بوصفه تجربةً تُحوِّل العلامة التجارية، وترسم مستقبلاً مستداماً وجاذباً للصناعات حول العالم. والتزامنا بالحلول المبتكرة والممارسات المسؤولة يصنع عالماً يغدو فيه التغليف شاهداً راسخاً على قيم العلامة وثقة المستهلك.",
      },
      {
        en: "We envision a world where packaging transcends its functional role, becoming an artful representation of brand values, consumer trust, and environmental responsibility, led by responsible practices that resonate with consumers and contribute to a more sustainable planet.",
        ar: "نتطلّع إلى عالمٍ يتجاوز فيه التغليف دوره الوظيفي ليصبح تعبيراً فنياً عن قيم العلامة وثقة المستهلك والمسؤولية البيئية، تقوده ممارساتٌ مسؤولة تلقى صدى لدى المستهلكين وتُسهم في كوكبٍ أكثر استدامة.",
      },
    ],
  },
  mission: {
    eyebrow: { en: "Our mission", ar: "رسالتنا" },
    title: { en: "The driving force behind brands' packaging evolution.", ar: "القوة الدافعة وراء تطوّر تغليف العلامات التجارية." },
    paragraphs: [
      {
        en: "At Printopack, our mission is to be the driving force behind brands' packaging evolution. With a legacy of expertise in flexible packaging solutions since 1997, we are dedicated to designing, developing, and producing responsible packaging that transcends mere functionality.",
        ar: "رسالتنا في برنتوباك أن نكون القوة الدافعة وراء تطوّر تغليف العلامات التجارية. وبإرثٍ من الخبرة في حلول التغليف المرن منذ عام 1997، نلتزم بتصميم تغليفٍ مسؤول وتطويره وإنتاجه بما يتجاوز مجرّد الوظيفة.",
      },
      {
        en: "Through innovative design, cutting-edge technology, and a commitment to sustainability, we empower brands to create packaging experiences that captivate consumers and align with their values, nurturing lasting partnerships with businesses across the globe.",
        ar: "وعبر التصميم المبتكر والتقنيات المتقدّمة والالتزام بالاستدامة، نُمكّن العلامات من ابتكار تجارب تغليفٍ تأسر المستهلكين وتنسجم مع قيمهم، ونرعى شراكاتٍ دائمة مع الأعمال حول العالم.",
      },
    ],
  },
  values: {
    eyebrow: { en: "What we stand for", ar: "ما نؤمن به" },
    title: { en: "Our values", ar: "قيمنا" },
    items: [
      { title: { en: "Quality without compromise", ar: "جودةٌ بلا تنازل" }, text: { en: "Every reel is held to the Printopack standard, from incoming substrate to final dispatch.", ar: "كل لفّةٍ تخضع لمعيار برنتوباك، من استلام المواد حتى التسليم النهائي." } },
      { title: { en: "Responsible by design", ar: "المسؤولية بالتصميم" }, text: { en: "Food-safe materials, solvent recovery and efficient production run through everything we make.", ar: "موادٌ آمنة غذائياً واسترجاعٌ للمذيبات وإنتاجٌ كفؤ في كل ما نصنع." } },
      { title: { en: "Partnership, not supply", ar: "شراكةٌ لا مجرّد توريد" }, text: { en: "We advise on structure and print from the first brief, so the packaging fits the product and the line.", ar: "نقدّم المشورة في البنية والطباعة منذ أول موجز، ليناسب التغليف المنتج وخط الإنتاج." } },
      { title: { en: "Built to deliver", ar: "التزامٌ بالتسليم" }, text: { en: "Planned materials and export logistics mean orders land on time, run after run.", ar: "تخطيطٌ للمواد ولوجستيات التصدير يضمن وصول الطلبات في وقتها، تشغيلةً بعد أخرى." } },
    ],
  },
  cta: {
    eyebrow: { en: "Work with us", ar: "اعمل معنا" },
    title: { en: "Let's build packaging that performs.", ar: "لنصنع تغليفاً يؤدّي دوره." },
    button: { en: "Request a quote", ar: "اطلب عرض سعر" },
  },
};
const c = content;
---
<Base title={c.meta.title} description={c.meta.description}>
  <!-- PAGE HEADER -->
  <section class="page-head">
    <div class="wrap-wide">
      <div class="page-head-inner">
        <span class="eyebrow"><Bi en={c.header.eyebrow.en} ar={c.header.eyebrow.ar} /></span>
        <h1><Bi en={c.header.title.en} ar={c.header.title.ar} /></h1>
        <p class="lede"><Bi en={c.header.lede.en} ar={c.header.lede.ar} /></p>
      </div>
    </div>
  </section>

  <!-- COUNTERS -->
  <section class="on-deep co-stats">
    <div class="wrap-wide counters-row">
      {c.counters.map((n) => <Counter from={n.from} prefix={n.prefix} value={n.value} label={n.label.en} labelAr={n.label.ar} />)}
    </div>
  </section>

  <!-- HISTORY -->
  <section class="story">
    <div class="wrap-wide story-grid">
      <div class="story-media">
        <div class="card-img"><img src={c.history.image} alt={c.history.imageAlt} /></div>
      </div>
      <div class="story-body">
        <span class="eyebrow"><Bi en={c.history.eyebrow.en} ar={c.history.eyebrow.ar} /></span>
        <h2><Bi en={c.history.title.en} ar={c.history.title.ar} /></h2>
        {c.history.paragraphs.map((p) => <p class="lede"><Bi en={p.en} ar={p.ar} /></p>)}
      </div>
    </div>
  </section>

  <!-- VISION -->
  <section class="on-navy">
    <div class="wrap-wide">
      <div class="section-head">
        <span class="eyebrow"><Bi en={c.vision.eyebrow.en} ar={c.vision.eyebrow.ar} /></span>
        <h2><Bi en={c.vision.title.en} ar={c.vision.title.ar} /></h2>
      </div>
      <div class="prose">{c.vision.paragraphs.map((p) => <p class="lede"><Bi en={p.en} ar={p.ar} /></p>)}</div>
    </div>
  </section>

  <!-- MISSION -->
  <section>
    <div class="wrap-wide">
      <div class="section-head">
        <span class="eyebrow"><Bi en={c.mission.eyebrow.en} ar={c.mission.eyebrow.ar} /></span>
        <h2><Bi en={c.mission.title.en} ar={c.mission.title.ar} /></h2>
      </div>
      <div class="prose">{c.mission.paragraphs.map((p) => <p class="lede"><Bi en={p.en} ar={p.ar} /></p>)}</div>
    </div>
  </section>

  <!-- VALUES -->
  <section class="values" style="background:var(--cream)">
    <div class="wrap-wide">
      <div class="section-head">
        <span class="eyebrow"><Bi en={c.values.eyebrow.en} ar={c.values.eyebrow.ar} /></span>
        <h2><Bi en={c.values.title.en} ar={c.values.title.ar} /></h2>
      </div>
      <div class="values-grid">
        {c.values.items.map((v) => (
          <div class="value">
            <span class="value-rule"></span>
            <h3><Bi en={v.title.en} ar={v.title.ar} /></h3>
            <p><Bi en={v.text.en} ar={v.text.ar} /></p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="on-deep">
    <div class="wrap" style="text-align:center">
      <span class="eyebrow plain" style="color:var(--gold-bright)"><Bi en={c.cta.eyebrow.en} ar={c.cta.eyebrow.ar} /></span>
      <h2 style="margin:14px 0 26px"><Bi en={c.cta.title.en} ar={c.cta.title.ar} /></h2>
      <a href="/contact" class="btn btn-gold"><Bi en={c.cta.button.en} ar={c.cta.button.ar} /></a>
    </div>
  </section>
</Base>

<style>
  .page-head{padding-block:clamp(56px,8vw,104px) clamp(30px,4vw,52px);background:var(--cream);border-bottom:1px solid var(--line)}
  .page-head-inner{max-width:820px}
  .page-head h1{margin:20px 0 22px;font-size:clamp(40px,6vw,78px)}
  .page-head .lede{max-width:60ch}

  .co-stats{padding-block:clamp(52px,6vw,80px)}
  .counters-row{display:grid;grid-template-columns:repeat(4,1fr);gap:32px}
  @media(max-width:760px){.counters-row{grid-template-columns:1fr 1fr;gap:40px 24px}}

  .story-grid{display:grid;grid-template-columns:1fr 1.05fr;gap:clamp(36px,6vw,84px);align-items:center}
  .story-media .card-img{aspect-ratio:4/3;border-radius:var(--radius)}
  .story-body .eyebrow{margin-bottom:16px}
  .story-body h2{margin-bottom:22px}
  .story-body .lede + .lede{margin-top:18px}
  @media(max-width:860px){.story-grid{grid-template-columns:1fr;gap:36px}}

  .prose{max-width:760px}
  .prose .lede + .lede{margin-top:18px}

  .values-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:40px 56px}
  .value-rule{display:block;width:34px;height:2px;background:var(--gold);margin-bottom:20px}
  .value h3{font-size:clamp(20px,2vw,26px);margin-bottom:12px}
  .value p{color:var(--muted)}
  @media(max-width:760px){.values-grid{grid-template-columns:1fr;gap:32px}}
</style>
