---
import Base from '../layouts/Base.astro';
import Counter from '../components/Counter.astro';
// Years in the market: computed live so it is always current (climbs from 1997).
const year = new Date().getFullYear();

// ── EDITABLE CONTENT ────────────────────────────────────────────────────────
// The admin's editable surface for "The Company". Vision/Mission are the client's
// real text (verbatim from printopack.com.sa/about). History is factual; ownership
// is folded into the history as a client-gated note; values are a scaffold.
const content = {
  meta: {
    title: "The Company - Printopack",
    description: "Printopack, the Saudi Modern Packaging Factory, has produced responsible flexible packaging in Jeddah since 1997. Our history, vision, mission and values.",
  },
  header: {
    eyebrow: "The company",
    title: "The company behind the packaging.",
    lede: "Printopack, the Saudi Modern Packaging Factory, has developed and produced responsible flexible packaging from Jeddah since 1997, for food, beverage, pharmaceutical and consumer brands across the region and beyond.",
  },
  counters: [
    { from: 1997, value: year, label: "In the market since 1997" },
    { prefix: "+", value: 26, label: "Countries served" },
    { prefix: "~", value: 400, label: "Team members" },
    { value: 6, label: "Regional offices" },
  ],
  history: {
    eyebrow: "Our history",
    title: "From one line in 1997 to brands across 26 countries.",
    image: "/images/factory.jpg",
    imageAlt: "The Printopack plant in Jeddah",
    paragraphs: [
      "Printopack, the trading name of Saudi Modern Packaging Factory Co. Ltd., was established in 1997 in Jeddah. What began as a single flexible-packaging operation has grown into a full service converter, with in-house rotogravure printing, cylinder engraving, bag making, finishing and solvent recovery, all under one roof.",
      "Today the company is family-owned and Saudi-operated, serving food, beverage, pharmaceutical and consumer brands across more than 26 countries through six regional offices. Ownership and the full founding story are added by Printopack through the site's admin.",
    ],
  },
  vision: {
    eyebrow: "Our vision",
    title: "Empowering brands through creative packaging excellence.",
    paragraphs: [
      "Printopack's vision is to redefine packaging as a transformative brand experience, fostering a sustainable and captivating future for industries worldwide. Our dedication to innovative solutions and responsible practices will shape a world where packaging becomes an enduring testament to brand values and consumer trust.",
      "We envision a world where packaging transcends its functional role, becoming an artful representation of brand values, consumer trust, and environmental responsibility. Our journey is fueled by the ambition to lead industries towards responsible packaging practices that resonate with consumers, empower businesses, and contribute to a more sustainable planet.",
    ],
  },
  mission: {
    eyebrow: "Our mission",
    title: "The driving force behind brands' packaging evolution.",
    paragraphs: [
      "At Printopack, our mission is to be the driving force behind brands' packaging evolution. With a legacy of expertise in flexible packaging solutions since 1997, we are dedicated to designing, developing, and producing responsible packaging that transcends mere functionality.",
      "Through innovative design, cutting-edge technology, and a commitment to sustainability, we empower brands to create packaging experiences that captivate consumers and align with their values, nurturing lasting partnerships with businesses across the globe.",
    ],
  },
  values: {
    eyebrow: "What we stand for",
    title: "Our values",
    items: [
      { title: "Quality without compromise", text: "Every reel is held to the Printopack standard, from incoming substrate to final dispatch." },
      { title: "Responsible by design", text: "Food-safe materials, solvent recovery and efficient production run through everything we make." },
      { title: "Partnership, not supply", text: "We advise on structure and print from the first brief, so the packaging fits the product and the line." },
      { title: "Built to deliver", text: "Planned materials and export logistics mean orders land on time, run after run." },
    ],
  },
  cta: {
    eyebrow: "Work with us",
    title: "Let's build packaging that performs.",
    button: { label: "Request a quote", href: "/contact" },
  },
};
const c = content;
---
<Base title={c.meta.title} description={c.meta.description}>
  <!-- PAGE HEADER -->
  <section class="page-head">
    <div class="wrap-wide">
      <div class="page-head-inner">
        <span class="eyebrow">{c.header.eyebrow}</span>
        <h1>{c.header.title}</h1>
        <p class="lede">{c.header.lede}</p>
      </div>
    </div>
  </section>

  <!-- COUNTERS -->
  <section class="on-deep co-stats">
    <div class="wrap-wide counters-row">
      {c.counters.map((n) => <Counter {...n} />)}
    </div>
  </section>

  <!-- HISTORY -->
  <section class="story">
    <div class="wrap-wide story-grid">
      <div class="story-media">
        <div class="card-img"><img src={c.history.image} alt={c.history.imageAlt} /></div>
      </div>
      <div class="story-body">
        <span class="eyebrow">{c.history.eyebrow}</span>
        <h2>{c.history.title}</h2>
        {c.history.paragraphs.map((p) => <p class="lede">{p}</p>)}
      </div>
    </div>
  </section>

  <!-- VISION -->
  <section class="on-navy">
    <div class="wrap-wide">
      <div class="section-head">
        <span class="eyebrow">{c.vision.eyebrow}</span>
        <h2>{c.vision.title}</h2>
      </div>
      <div class="prose">{c.vision.paragraphs.map((p) => <p class="lede">{p}</p>)}</div>
    </div>
  </section>

  <!-- MISSION -->
  <section>
    <div class="wrap-wide">
      <div class="section-head">
        <span class="eyebrow">{c.mission.eyebrow}</span>
        <h2>{c.mission.title}</h2>
      </div>
      <div class="prose">{c.mission.paragraphs.map((p) => <p class="lede">{p}</p>)}</div>
    </div>
  </section>

  <!-- VALUES -->
  <section class="values" style="background:var(--cream)">
    <div class="wrap-wide">
      <div class="section-head">
        <span class="eyebrow">{c.values.eyebrow}</span>
        <h2>{c.values.title}</h2>
      </div>
      <div class="values-grid">
        {c.values.items.map((v) => (
          <div class="value">
            <span class="value-rule"></span>
            <h3>{v.title}</h3>
            <p>{v.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="on-deep">
    <div class="wrap" style="text-align:center">
      <span class="eyebrow plain" style="color:var(--gold-bright)">{c.cta.eyebrow}</span>
      <h2 style="margin:14px 0 26px">{c.cta.title}</h2>
      <a href={c.cta.button.href} class="btn btn-gold">{c.cta.button.label}</a>
    </div>
  </section>
</Base>

<style>
  .page-head{padding-block:clamp(56px,8vw,104px) clamp(30px,4vw,52px);background:var(--cream);border-bottom:1px solid var(--line)}
  .page-head-inner{max-width:820px}
  .page-head h1{margin:20px 0 22px;font-size:clamp(40px,6vw,78px)}
  .page-head .lede{max-width:60ch}

  .co-stats{padding-block:clamp(52px,6vw,80px)}
  .counters-row{display:grid;grid-template-columns:repeat(4,1fr);gap:32px}
  @media(max-width:760px){.counters-row{grid-template-columns:1fr 1fr;gap:40px 24px}}

  .story-grid{display:grid;grid-template-columns:1fr 1.05fr;gap:clamp(36px,6vw,84px);align-items:center}
  .story-media .card-img{aspect-ratio:4/3;border-radius:var(--radius)}
  .story-body .eyebrow{margin-bottom:16px}
  .story-body h2{margin-bottom:22px}
  .story-body .lede + .lede{margin-top:18px}
  @media(max-width:860px){.story-grid{grid-template-columns:1fr;gap:36px}}

  .prose{max-width:760px}
  .prose .lede + .lede{margin-top:18px}

  .values-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:40px 56px}
  .value-rule{display:block;width:34px;height:2px;background:var(--gold);margin-bottom:20px}
  .value h3{font-size:clamp(20px,2vw,26px);margin-bottom:12px}
  .value p{color:var(--muted)}
  @media(max-width:760px){.values-grid{grid-template-columns:1fr;gap:32px}}
</style>
