---
import Base from '../layouts/Base.astro';
import Counter from '../components/Counter.astro';
// Years in the market: computed live so it is always current (climbs from 1997).
const year = new Date().getFullYear();

// Company hub. The "Company" nav item gathers the sections about the organisation.
// This page introduces Printopack and routes to each sub-section.
const sections = [
  { t: "About Us", d: "History, ownership, mission, vision and values.", href: "/about", img: "/images/factory.jpg" },
  { t: "Factory Departments", d: "Inside the plant: printing, engraving, converting and more.", href: "/factory", img: "/images/dept-1.jpg" },
  { t: "Our Team", d: "The people who run the press floor and the offices.", href: "/team", img: "/images/dept-4.jpg" },
  { t: "Quality & Responsibility", d: "Certification, testing, environment and compliance.", href: "/quality", img: "/images/dept-5.jpg" },
  { t: "Success Partners", d: "The brands we print and pack for across 26 countries.", href: "/partners", img: "/images/lineup.jpg" },
  { t: "Careers", d: "Open roles and how to join the team in Jeddah.", href: "/careers", img: "/images/dept-2.jpg" },
];
---
<Base
  title="Company - Printopack"
  description="Get to know Printopack, the Saudi Modern Packaging Factory: our story, our plant, our people, our standards and the partners we serve since 1997."
>
  <!-- PAGE HEADER -->
  <section class="page-head">
    <div class="wrap-wide">
      <div class="page-head-inner">
        <span class="eyebrow">Company</span>
        <h1>Get to know Printopack.</h1>
        <p class="lede">
          A Saudi flexible-packaging manufacturer with a 25-year record, a full-service plant in Jeddah
          and partners across 26 countries. Start anywhere below.
        </p>
      </div>
    </div>
  </section>

  <!-- COUNTERS -->
  <section class="on-deep co-stats">
    <div class="wrap-wide counters-row">
      <Counter from="1997" value={year} label="In the market since 1997" />
      <Counter prefix="+" value="26" label="Countries served" />
      <Counter prefix="~" value="400" label="Team members" />
      <Counter prefix="" value="6" label="Regional offices" />
    </div>
  </section>

  <!-- SECTION CARDS -->
  <section class="co-sections">
    <div class="wrap-wide">
      <div class="co-grid">
        {sections.map((s) => (
          <a class="co-card" href={s.href}>
            <span class="card-img"><img src={s.img} alt={s.t} /></span>
            <span class="co-card-body">
              <span class="co-card-t">{s.t}</span>
              <span class="co-card-d">{s.d}</span>
              <span class="co-card-go">Explore &rarr;</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .page-head{padding-block:clamp(56px,8vw,104px) clamp(30px,4vw,52px);background:var(--cream);border-bottom:1px solid var(--line)}
  .page-head-inner{max-width:820px}
  .page-head h1{margin:20px 0 22px;font-size:clamp(40px,6vw,78px)}
  .page-head .lede{max-width:60ch}

  .counters-row{display:grid;grid-template-columns:repeat(4,1fr);gap:32px}
  @media(max-width:760px){.counters-row{grid-template-columns:1fr 1fr;gap:40px 24px}}

  .co-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:28px}
  .co-card{display:flex;flex-direction:column;background:var(--paper);border:1px solid var(--line);border-radius:var(--radius);overflow:hidden}
  .co-card:hover{border-color:var(--navy);box-shadow:0 20px 40px rgba(14,35,64,.08)}
  .co-card .card-img{aspect-ratio:16/10}
  .co-card:hover .card-img img{opacity:.92}
  .co-card-body{display:flex;flex-direction:column;padding:24px 24px 26px}
  .co-card-t{font-family:var(--display);font-size:22px;font-weight:var(--w-light);color:var(--ink)}
  .co-card-d{color:var(--muted);font-size:15px;margin:10px 0 18px}
  .co-card-go{font-family:var(--display);font-size:12px;font-weight:500;letter-spacing:.14em;text-transform:uppercase;color:var(--gold);margin-top:auto}
  @media(max-width:900px){.co-grid{grid-template-columns:1fr 1fr}}
  @media(max-width:560px){.co-grid{grid-template-columns:1fr}}
</style>
