---
import Base from '../layouts/Base.astro';
import Counter from '../components/Counter.astro';
// Years in the market: computed live so it is always current (climbs from 1997).
const year = new Date().getFullYear();

// "The Company" subsection of About Us. Vision and Mission are the client's real
// published text, verbatim from printopack.com.sa/about. History is from verified
// facts. Ownership is client-gated (no names invented). Values are a scaffold drawn
// from the mission language, for the client to confirm. Built with the same layout
// patterns as the rest of the site (story block, section heads, values grid).
const vision = [
  "Printopack's vision is to redefine packaging as a transformative brand experience, fostering a sustainable and captivating future for industries worldwide. Our dedication to innovative solutions and responsible practices will shape a world where packaging becomes an enduring testament to brand values and consumer trust.",
  "We envision a world where packaging transcends its functional role, becoming an artful representation of brand values, consumer trust, and environmental responsibility. Our journey is fueled by the ambition to lead industries towards responsible packaging practices that resonate with consumers, empower businesses, and contribute to a more sustainable planet.",
];
const mission = [
  "At Printopack, our mission is to be the driving force behind brands' packaging evolution. With a legacy of expertise in flexible packaging solutions since 1997, we are dedicated to designing, developing, and producing responsible packaging that transcends mere functionality.",
  "Through innovative design, cutting-edge technology, and a commitment to sustainability, we empower brands to create packaging experiences that captivate consumers and align with their values, nurturing lasting partnerships with businesses across the globe.",
];
const values = [
  { t: "Quality without compromise", d: "Every reel is held to the Printopack standard, from incoming substrate to final dispatch." },
  { t: "Responsible by design", d: "Food-safe materials, solvent recovery and efficient production run through everything we make." },
  { t: "Partnership, not supply", d: "We advise on structure and print from the first brief, so the packaging fits the product and the line." },
  { t: "Built to deliver", d: "Planned materials and export logistics mean orders land on time, run after run." },
];
---
<Base
  title="The Company - Printopack"
  description="Printopack, the Saudi Modern Packaging Factory, has produced responsible flexible packaging in Jeddah since 1997. Our history, vision, mission and values."
>
  <!-- PAGE HEADER -->
  <section class="page-head">
    <div class="wrap-wide">
      <div class="page-head-inner">
        <span class="eyebrow">The company</span>
        <h1>The company behind the packaging.</h1>
        <p class="lede">
          Printopack, the Saudi Modern Packaging Factory, has developed and produced responsible
          flexible packaging from Jeddah since 1997, for food, beverage, pharmaceutical and consumer
          brands across the region and beyond.
        </p>
      </div>
    </div>
  </section>

  <!-- COUNTERS (autocounting years from 1997) -->
  <section class="on-deep co-stats">
    <div class="wrap-wide counters-row">
      <Counter from="1997" value={year} label="In the market since 1997" />
      <Counter prefix="+" value="26" label="Countries served" />
      <Counter prefix="~" value="400" label="Team members" />
      <Counter prefix="" value="6" label="Regional offices" />
    </div>
  </section>

  <!-- HISTORY (two-column story block, same as /about) -->
  <section class="story">
    <div class="wrap-wide story-grid">
      <div class="story-media">
        <div class="card-img"><img src="/images/factory.jpg" alt="The Printopack plant in Jeddah" /></div>
      </div>
      <div class="story-body">
        <span class="eyebrow">Our history</span>
        <h2>From one line in 1997 to brands across 26 countries.</h2>
        <p class="lede">
          Printopack, the trading name of Saudi Modern Packaging Factory Co. Ltd., was established in
          1997 in Jeddah. What began as a single flexible-packaging operation has grown into a full
          service converter, with in-house rotogravure printing, cylinder engraving, bag making,
          finishing and solvent recovery, all under one roof.
        </p>
        <p class="lede">
          Today the company is family-owned and Saudi-operated, serving food, beverage, pharmaceutical
          and consumer brands across more than 26 countries through six regional offices. Ownership and
          the full founding story are added by Printopack through the site's admin.
        </p>
      </div>
    </div>
  </section>

  <!-- VISION (navy editorial band) -->
  <section class="on-navy">
    <div class="wrap-wide">
      <div class="section-head">
        <span class="eyebrow">Our vision</span>
        <h2>Empowering brands through creative packaging excellence.</h2>
      </div>
      <div class="prose">{vision.map((p) => <p class="lede">{p}</p>)}</div>
    </div>
  </section>

  <!-- MISSION -->
  <section>
    <div class="wrap-wide">
      <div class="section-head">
        <span class="eyebrow">Our mission</span>
        <h2>The driving force behind brands' packaging evolution.</h2>
      </div>
      <div class="prose">{mission.map((p) => <p class="lede">{p}</p>)}</div>
    </div>
  </section>

  <!-- VALUES (grid, same as /about) -->
  <section class="values" style="background:var(--cream)">
    <div class="wrap-wide">
      <div class="section-head">
        <span class="eyebrow">What we stand for</span>
        <h2>Our values</h2>
      </div>
      <div class="values-grid">
        {values.map((v) => (
          <div class="value">
            <span class="value-rule"></span>
            <h3>{v.t}</h3>
            <p>{v.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA (same as /about) -->
  <section class="on-deep">
    <div class="wrap" style="text-align:center">
      <span class="eyebrow plain" style="color:var(--gold-bright)">Work with us</span>
      <h2 style="margin:14px 0 26px">Let's build packaging that performs.</h2>
      <a href="/contact" class="btn btn-gold">Request a quote</a>
    </div>
  </section>
</Base>

<style>
  .page-head{padding-block:clamp(56px,8vw,104px) clamp(30px,4vw,52px);background:var(--cream);border-bottom:1px solid var(--line)}
  .page-head-inner{max-width:820px}
  .page-head h1{margin:20px 0 22px;font-size:clamp(40px,6vw,78px)}
  .page-head .lede{max-width:60ch}

  .co-stats{padding-block:clamp(52px,6vw,80px)}
  .counters-row{display:grid;grid-template-columns:repeat(4,1fr);gap:32px}
  @media(max-width:760px){.counters-row{grid-template-columns:1fr 1fr;gap:40px 24px}}

  .story-grid{display:grid;grid-template-columns:1fr 1.05fr;gap:clamp(36px,6vw,84px);align-items:center}
  .story-media .card-img{aspect-ratio:4/3;border-radius:var(--radius)}
  .story-body .eyebrow{margin-bottom:16px}
  .story-body h2{margin-bottom:22px}
  .story-body .lede + .lede{margin-top:18px}
  @media(max-width:860px){.story-grid{grid-template-columns:1fr;gap:36px}}

  .prose{max-width:760px}
  .prose .lede + .lede{margin-top:18px}

  .values-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:40px 56px}
  .value-rule{display:block;width:34px;height:2px;background:var(--gold);margin-bottom:20px}
  .value h3{font-size:clamp(20px,2vw,26px);margin-bottom:12px}
  .value p{color:var(--muted)}
  @media(max-width:760px){.values-grid{grid-template-columns:1fr;gap:32px}}
</style>
