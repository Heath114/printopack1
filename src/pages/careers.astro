---
import Base from '../layouts/Base.astro';
import Counter from '../components/Counter.astro';
import Bi from '../components/Bi.astro';
const year = new Date().getFullYear();

// Careers (Nasser's Page 5). His brief: open roles with specs + requirements, a
// correspondence email, and the ability to send a CV "من نفس المكان مباشرة" (directly, in
// place). So the application form lives HERE, not on Contact.
//
// Roles are an accordion (collapsed; expand to reveal full description + requirements).
// "Apply for this role" reveals the in-page application form with the role locked in and
// that role's correspondence email auto-filled/shown. CV upload is Netlify Forms (works on
// deploy, not in local preview; success via ?submitted=1).
//
// TEMPLATE-FIRST / admin-editable: `roles` (incl. each role's `email`) and every label are
// the surface the admin dashboard manages. Roles are client-gated, so these are clearly-
// templated examples (see `.cnote`, strip before production) until real ones arrive.
const roles = [
  {
    key: "production-engineer", email: "hr@printopack.com.sa",
    title: { en: "Production Engineer", ar: "مهندس إنتاج" },
    dept: { en: "Production", ar: "الإنتاج" },
    type: { en: "Full-time", ar: "دوام كامل" },
    location: { en: "Jeddah, KSA", ar: "جدة، السعودية" },
    summary: { en: "Run and improve our rotogravure and lamination lines, keeping output on-spec and on-time.", ar: "تشغيل وتحسين خطوط الطباعة الروتوغرافية والتصفيح، مع الحفاظ على مطابقة الإنتاج للمواصفات وتسليمه في وقته." },
    req: [
      { en: "BSc in mechanical or industrial engineering.", ar: "بكالوريوس في الهندسة الميكانيكية أو الصناعية." },
      { en: "3+ years on rotogravure or flexible-packaging lines.", ar: "خبرة 3 سنوات فأكثر على خطوط الطباعة الروتوغرافية أو التغليف المرن." },
      { en: "A strong grasp of print quality and process control.", ar: "إلمام قوي بجودة الطباعة وضبط العمليات." },
    ],
  },
  {
    key: "qc-specialist", email: "hr@printopack.com.sa",
    title: { en: "Quality Control Specialist", ar: "أخصائي مراقبة الجودة" },
    dept: { en: "Quality", ar: "الجودة" },
    type: { en: "Full-time", ar: "دوام كامل" },
    location: { en: "Jeddah, KSA", ar: "جدة، السعودية" },
    summary: { en: "Check every run against our food-safety and print standards before it ships.", ar: "فحص كل تشغيلة وفق معايير سلامة الغذاء والطباعة قبل شحنها." },
    req: [
      { en: "Background in food-contact materials and lab testing.", ar: "خلفية في المواد الملامِسة للأغذية والفحص المخبري." },
      { en: "Familiarity with BRCGS or similar standards.", ar: "معرفة بمعيار BRCGS أو ما يماثله." },
      { en: "A meticulous, documentation-driven approach.", ar: "منهجية دقيقة قائمة على التوثيق." },
    ],
  },
  {
    key: "sales-account-manager", email: "hr@printopack.com.sa",
    title: { en: "Sales Account Manager", ar: "مدير حسابات مبيعات" },
    dept: { en: "Sales", ar: "المبيعات" },
    type: { en: "Full-time", ar: "دوام كامل" },
    location: { en: "Regional", ar: "إقليمي" },
    summary: { en: "Grow relationships with food, beverage and consumer brands across the region.", ar: "تنمية العلاقات مع علامات الأغذية والمشروبات والمنتجات الاستهلاكية في المنطقة." },
    req: [
      { en: "5+ years of B2B packaging or FMCG sales.", ar: "خبرة 5 سنوات فأكثر في مبيعات التغليف أو السلع الاستهلاكية (B2B)." },
      { en: "Existing brand relationships are a plus.", ar: "وجود علاقات قائمة مع العلامات ميزة إضافية." },
      { en: "Fluent Arabic and English.", ar: "إتقان العربية والإنجليزية." },
    ],
  },
];

const content = {
  meta: {
    title: "Careers - Printopack",
    description: "Join Printopack in Jeddah. Explore open roles in production, quality and sales, and apply with your CV directly from the page.",
  },
  header: {
    eyebrow: { en: "Careers", ar: "الوظائف" },
    title: { en: "Build what protects the product.", ar: "اصنع ما يحمي المنتج." },
    lede: {
      en: "Packaging is made by people. If you want to work at a serious Saudi manufacturer with a legacy since 1997, open a role below to see what it involves and apply.",
      ar: "التغليف يصنعه أناس. إن كنت تطمح للعمل لدى مصنع سعودي عريق يمتد إرثه منذ عام 1997، فافتح إحدى الوظائف أدناه لتطّلع على تفاصيلها وتقدّم عليها.",
    },
  },
  counters: [
    { prefix: "~", value: 400, label: { en: "People on the team", ar: "في فريقنا" } },
    { from: 1997, value: year, label: { en: "Serving since 1997", ar: "نعمل منذ 1997" } },
    { prefix: "+", value: 35, label: { en: "Countries served", ar: "دولة نصل إليها" } },
  ],
  roles: {
    eyebrow: { en: "Now hiring", ar: "نوظّف الآن" },
    title: { en: "Open positions", ar: "الوظائف المتاحة" },
    reqLabel: { en: "What we look for", ar: "ما نبحث عنه" },
    apply: { en: "Apply for this role", ar: "قدّم على هذه الوظيفة" },
    empty: { en: "There are no open positions at the moment. Please check back soon.", ar: "لا توجد وظائف متاحة حالياً. يُرجى العودة قريباً." },
    note: {
      en: "Open roles are posted and kept current by Printopack through the site's admin.",
      ar: "تُنشر الوظائف المتاحة وتُحدَّث من قِبل برنتوباك عبر لوحة تحكم الموقع.",
    },
  },
  apply: {
    eyebrow: { en: "Application", ar: "التقديم" },
    forLabel: { en: "Apply for", ar: "التقديم على وظيفة" },
    lede: {
      en: "Fill in your details and attach your CV. Your application goes straight to our HR team for this role.",
      ar: "املأ بياناتك وأرفق سيرتك الذاتية. يصل طلبك مباشرةً إلى فريق الموارد البشرية لهذه الوظيفة.",
    },
    sentTo: { en: "Applications for this role are sent to", ar: "تُرسَل طلبات هذه الوظيفة إلى" },
    fields: {
      name: { en: "Full name", ar: "الاسم الكامل" },
      email: { en: "Email", ar: "البريد الإلكتروني" },
      phone: { en: "Phone", ar: "رقم الهاتف" },
      message: { en: "Message (optional)", ar: "رسالة (اختياري)" },
      cv: { en: "Attach your CV (PDF or Word)", ar: "أرفق سيرتك الذاتية (PDF أو Word)" },
      cover: { en: "Cover letter (optional, PDF or Word)", ar: "خطاب التقديم (اختياري، PDF أو Word)" },
    },
    submit: { en: "Send application", ar: "إرسال الطلب" },
    success: {
      en: "Thank you. Your application has been received and our HR team will be in touch.",
      ar: "شكراً لك. تم استلام طلبك وسيتواصل معك فريق الموارد البشرية لدينا.",
    },
  },
};
const c = content;
---
<Base title={c.meta.title} description={c.meta.description}>
  <!-- PAGE HEADER -->
  <section class="page-head">
    <div class="wrap-wide">
      <div class="page-head-inner">
        <span class="eyebrow"><Bi en={c.header.eyebrow.en} ar={c.header.eyebrow.ar} /></span>
        <h1><Bi en={c.header.title.en} ar={c.header.title.ar} /></h1>
        <p class="lede"><Bi en={c.header.lede.en} ar={c.header.lede.ar} /></p>
      </div>
    </div>
  </section>

  <!-- COUNTERS -->
  <section class="on-deep car-stats">
    <div class="wrap-wide counters-row">
      {c.counters.map((n) => <Counter from={n.from} prefix={n.prefix} value={n.value} label={n.label.en} labelAr={n.label.ar} />)}
    </div>
  </section>

  <!-- OPEN ROLES (collapsed; expand to reveal the full description) -->
  <section class="roles">
    <div class="wrap-wide">
      <div class="section-head">
        <span class="eyebrow"><Bi en={c.roles.eyebrow.en} ar={c.roles.eyebrow.ar} /></span>
        <h2><Bi en={c.roles.title.en} ar={c.roles.title.ar} /></h2>
      </div>

      {roles.length === 0 ? (
        <p class="roles-empty"><Bi en={c.roles.empty.en} ar={c.roles.empty.ar} /></p>
      ) : (
        <div class="role-list">
          {roles.map((r) => (
            <article class="role">
              <button class="role-head" aria-expanded="false" aria-controls={`role-${r.key}`}>
                <span class="role-head-main">
                  <span class="role-title"><Bi en={r.title.en} ar={r.title.ar} /></span>
                  <span class="role-tags">
                    <span><Bi en={r.dept.en} ar={r.dept.ar} /></span>
                    <span><Bi en={r.type.en} ar={r.type.ar} /></span>
                    <span><Bi en={r.location.en} ar={r.location.ar} /></span>
                  </span>
                </span>
                <span class="role-chevron" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M6 9l6 6 6-6"/></svg>
                </span>
              </button>
              <div class="role-body" id={`role-${r.key}`} hidden>
                <p class="role-summary"><Bi en={r.summary.en} ar={r.summary.ar} /></p>
                <span class="role-req-label"><Bi en={c.roles.reqLabel.en} ar={c.roles.reqLabel.ar} /></span>
                <ul class="role-req">
                  {r.req.map((q) => (
                    <li><span class="req-tick" aria-hidden="true"></span><Bi en={q.en} ar={q.ar} /></li>
                  ))}
                </ul>
                <button class="btn btn-solid role-apply" data-role={r.key} data-role-en={r.title.en} data-role-ar={r.title.ar} data-email={r.email}>
                  <Bi en={c.roles.apply.en} ar={c.roles.apply.ar} />
                </button>
              </div>
            </article>
          ))}
        </div>
      )}
      <!-- build-only helper: remove before production (see PRODUCTION_TODO.md) -->
      <p class="cnote"><Bi en={c.roles.note.en} ar={c.roles.note.ar} /></p>
    </div>
  </section>

  <!-- APPLICATION: in-page, appears once a specific role is chosen (Netlify Forms) -->
  <section class="on-navy apply" id="apply" hidden>
    <div class="wrap apply-inner">
      <div class="apply-intro">
        <span class="eyebrow"><Bi en={c.apply.eyebrow.en} ar={c.apply.eyebrow.ar} /></span>
        <h2 class="apply-heading">
          <Bi en={c.apply.forLabel.en} ar={c.apply.forLabel.ar} /> <span class="apply-role-name"></span>
        </h2>
        <p class="lede"><Bi en={c.apply.lede.en} ar={c.apply.lede.ar} /></p>
        <p class="apply-sentto">
          <Bi en={c.apply.sentTo.en} ar={c.apply.sentTo.ar} />
          <a class="apply-email-target" href="mailto:" dir="ltr"></a>
        </p>
      </div>

      <div class="apply-formwrap">
        <p class="apply-success" role="status" hidden><Bi en={c.apply.success.en} ar={c.apply.success.ar} /></p>
        <form class="apply-form" name="careers" method="POST" data-netlify="true" netlify-honeypot="bot-field" enctype="multipart/form-data" action="/careers?submitted=1#apply">
          <input type="hidden" name="form-name" value="careers" />
          <input type="hidden" name="position" class="apply-position" value="" />
          <!-- autonomous mapper: the chosen role's accepting email + a per-job subject are
               attached to the submission automatically (set from the role's data on apply) -->
          <input type="hidden" name="applications_email" class="apply-email-field" value="" />
          <input type="hidden" name="subject" class="apply-subject" value="" />
          <p class="hp" hidden><label>Do not fill this in: <input name="bot-field" /></label></p>

          <label class="field">
            <span class="field-label"><Bi en={c.apply.fields.name.en} ar={c.apply.fields.name.ar} /></span>
            <input type="text" name="name" required placeholder={c.apply.fields.name.en} data-ph-ar={c.apply.fields.name.ar} />
          </label>
          <div class="field-row">
            <label class="field">
              <span class="field-label"><Bi en={c.apply.fields.email.en} ar={c.apply.fields.email.ar} /></span>
              <input type="email" name="email" required placeholder="name@example.com" dir="ltr" />
            </label>
            <label class="field">
              <span class="field-label"><Bi en={c.apply.fields.phone.en} ar={c.apply.fields.phone.ar} /></span>
              <input type="tel" name="phone" placeholder="+966 5X XXX XXXX" dir="ltr" />
            </label>
          </div>
          <label class="field">
            <span class="field-label"><Bi en={c.apply.fields.message.en} ar={c.apply.fields.message.ar} /></span>
            <textarea name="message" rows="4"></textarea>
          </label>
          <label class="field">
            <span class="field-label"><Bi en={c.apply.fields.cv.en} ar={c.apply.fields.cv.ar} /></span>
            <input type="file" name="cv" required accept=".pdf,.doc,.docx" />
          </label>
          <label class="field">
            <span class="field-label"><Bi en={c.apply.fields.cover.en} ar={c.apply.fields.cover.ar} /></span>
            <input type="file" name="cover_letter" accept=".pdf,.doc,.docx" />
          </label>
          <button type="submit" class="btn btn-gold apply-submit"><Bi en={c.apply.submit.en} ar={c.apply.submit.ar} /></button>
        </form>
      </div>
    </div>
  </section>
</Base>

<style>
  .page-head{padding-block:clamp(56px,8vw,104px) clamp(30px,4vw,52px);background:var(--cream);border-bottom:1px solid var(--line)}
  .page-head-inner{max-width:820px}
  .page-head h1{margin:20px 0 22px;font-size:clamp(40px,6vw,78px)}
  .page-head .lede{max-width:60ch}

  .car-stats{padding-block:clamp(52px,6vw,78px)}
  .counters-row{display:grid;grid-template-columns:repeat(3,1fr);gap:32px}

  /* open roles: accordion */
  .role-list{border-top:1px solid var(--line);margin-top:clamp(26px,3vw,40px)}
  .role{border-bottom:1px solid var(--line)}
  .role-head{width:100%;display:flex;align-items:center;justify-content:space-between;gap:24px;padding:clamp(22px,2.6vw,30px) 0;text-align:start}
  .role-head-main{display:flex;flex-direction:column;gap:12px;min-width:0}
  .role-title{font-family:var(--display);font-weight:400;font-size:clamp(20px,2.2vw,28px);color:var(--ink)}
  .role-head:hover .role-title{color:var(--navy)}
  .role-tags{display:flex;flex-wrap:wrap;gap:8px 10px}
  .role-tags span{font-family:var(--display);font-size:11px;font-weight:500;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);background:var(--cream);border:1px solid var(--line);padding:5px 12px;border-radius:var(--radius)}
  .role-chevron{flex:none;display:inline-flex;color:var(--navy)}
  .role-chevron svg{width:24px;height:24px}
  .role-head[aria-expanded="true"] .role-chevron{transform:rotate(180deg)}
  .role-body{padding:0 0 clamp(26px,3vw,34px)}
  .role-body[hidden]{display:none}
  .role-summary{color:var(--muted);max-width:64ch;margin-bottom:20px}
  .role-req-label{font-family:var(--display);font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--gold);display:block;margin-bottom:12px}
  .role-req{display:grid;gap:9px;margin-bottom:26px}
  .role-req li{display:flex;align-items:flex-start;gap:11px;font-size:14.5px;color:var(--ink);max-width:62ch;line-height:1.5}
  .req-tick{flex:none;width:6px;height:6px;border-radius:50%;background:var(--gold);margin-top:8px}
  .roles-empty{margin-top:30px;color:var(--muted);font-size:clamp(16px,1.6vw,19px)}
  .cnote{margin-top:22px;font-size:13px;font-style:italic;color:var(--faint);max-width:62ch}

  /* application */
  .apply[hidden]{display:none}
  .apply-inner{display:grid;grid-template-columns:1fr 1.15fr;gap:clamp(32px,6vw,72px);align-items:start}
  .apply-intro .lede{color:rgba(250,246,238,.72)}
  .apply-role-name{color:var(--gold-bright)}
  .apply-sentto{margin-top:24px;padding-top:20px;border-top:1px solid var(--line-dark);font-size:14px;color:rgba(250,246,238,.72)}
  .apply-email-target{color:var(--gold-bright);margin-inline-start:6px}
  .apply-email-target:hover{color:var(--paper)}

  .apply-formwrap{background:var(--paper);border-radius:var(--radius);padding:clamp(24px,3vw,36px)}
  .apply-success{background:var(--gold-soft);border:1px solid var(--gold);color:var(--navy);padding:16px 18px;border-radius:var(--radius);font-size:15px}
  .apply-form{display:flex;flex-direction:column;gap:16px}
  .field{display:flex;flex-direction:column;gap:7px}
  .field-row{display:grid;grid-template-columns:1fr 1fr;gap:16px}
  .field-label{font-family:var(--display);font-size:12px;font-weight:500;letter-spacing:.06em;color:var(--muted)}
  .apply-form input,.apply-form textarea{
    font-family:var(--body);font-size:15px;color:var(--ink);background:var(--white);
    border:1px solid var(--line);border-radius:var(--radius);padding:12px 14px;width:100%;
  }
  .apply-form input:focus,.apply-form textarea:focus{outline:none;border-color:var(--navy)}
  .apply-form textarea{resize:vertical;min-height:96px}
  .apply-form input[type="file"]{padding:10px 14px;font-family:var(--display);font-size:13px;color:var(--muted);cursor:pointer}
  .apply-submit{justify-content:center;margin-top:6px}

  @media(max-width:820px){.apply-inner{grid-template-columns:1fr;gap:32px}}
  @media(max-width:640px){
    .counters-row{grid-template-columns:1fr;gap:40px}
    .field-row{grid-template-columns:1fr}
  }
</style>

<script>
  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;

  // Accordion: expand/collapse each role independently. No motion.
  document.querySelectorAll<HTMLButtonElement>('.role-head').forEach((head) => {
    head.addEventListener('click', () => {
      const body = document.getElementById(head.getAttribute('aria-controls') || '');
      const open = head.getAttribute('aria-expanded') === 'true';
      head.setAttribute('aria-expanded', String(!open));
      if (body) body.hidden = open;
    });
  });

  // Application reveals in place for the chosen role, with that role's email auto-filled.
  const applySection = document.getElementById('apply');
  const roleName = document.querySelector<HTMLElement>('.apply-role-name');
  const positionInput = document.querySelector<HTMLInputElement>('.apply-position');
  const emailField = document.querySelector<HTMLInputElement>('.apply-email-field');
  const subjectField = document.querySelector<HTMLInputElement>('.apply-subject');
  const emailTarget = document.querySelector<HTMLAnchorElement>('.apply-email-target');
  let selected: { en: string; ar: string } | null = null;
  const renderRoleName = () => {
    if (selected && roleName) roleName.textContent = document.documentElement.dir === 'rtl' ? selected.ar : selected.en;
  };
  document.querySelectorAll<HTMLElement>('.role-apply').forEach((btn) => {
    btn.addEventListener('click', () => {
      selected = { en: btn.dataset.roleEn || '', ar: btn.dataset.roleAr || '' };
      const email = btn.dataset.email || '';
      if (positionInput) positionInput.value = selected.en;
      if (emailField) emailField.value = email;
      if (subjectField) subjectField.value = 'Job application: ' + selected.en;
      if (emailTarget) { emailTarget.textContent = email; emailTarget.href = 'mailto:' + email; }
      renderRoleName();
      if (applySection) {
        applySection.hidden = false;
        requestAnimationFrame(() => applySection.scrollIntoView({ behavior: reduce ? 'auto' : 'smooth', block: 'start' }));
      }
    });
  });
  new MutationObserver(renderRoleName).observe(document.documentElement, { attributes: true, attributeFilter: ['dir'] });

  // Netlify redirects here with ?submitted=1 on success: reveal the section + thank-you.
  if (new URLSearchParams(location.search).get('submitted') === '1') {
    const ok = document.querySelector<HTMLElement>('.apply-success');
    const form = document.querySelector<HTMLElement>('.apply-form');
    if (applySection) applySection.hidden = false;
    if (ok) ok.hidden = false;
    if (form) form.hidden = true;
  }
</script>
